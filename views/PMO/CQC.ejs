                                        <%- include('../partials/dependencies-js',{Notifications:Notifications}) %>
                                        <% if(lock==true){%>
                                            <script>
                                                elapsedTime = Date.now() - new Date('<%=Log[Object.values(Log).length-1].startTime%>');
                                                start();
                                            </script>
                                            <% } %>
                                          
                                                <script>

                                                    $(document).ready(function() {
                                                        $(".QC_Due_Date_Container").hide();
                                                    $('input[type="radio"][name="autoQC"]').on('click', function() {
                                                        if ($(this).val() === '1') {
                                                            $('.QC_Due_Date_Container').show();
                                                            $('#Sub_QC_Due_Date').attr('required', true);
                                                        } else {
                                                            $('.QC_Due_Date_Container').hide();
                                                            $('#Sub_QC_Due_Date').attr('required', false);
                                                        }
                                                    });
                                                });
                                                    if(elapsedTime==0){
                                                        document.getElementById('Checklist_Url').classList.add("visually-hidden")
                                                        document.getElementById('QC_Link').setAttribute("disabled","")
                                                    }
                                                    document.getElementById("stopBtn").addEventListener('click', (e) => {
                                                        $("#stopBtn").prop("disabled",true)
                                                        stop(e.target)
                                                        axios.post('/api/updateTimeLog/<%=Task.TaskName %>/stop').then(res => {
                                                            window.location.reload();
                                                        }).catch(e => {
                                                            console.log(e);
                                                            if (e.response.data == "Access Denied") {
                                                                alert("Your session got closed.Login again to continue")
                                                            } else {
                                                                alert("Unable to stop the Timer. Try again...!")
                                                            }
                                                        })
                                                    });
                                                    document.getElementById("startBtn").addEventListener('click', (e) => {
                                                       $("#startBtn").prop("disabled",true)
                                                        axios.post('/api/updateTimeLog/<%=Task.TaskName %>/start').then(res => {
                                                            start(e.target);
                                                            window.location.reload();
                                                        }).catch(e => {
                                                            let pendingTask=e.response.data.OngoingTaskInfo;
                                                            if(pendingTask){

                                                                let URL="#";
                                                                if(pendingTask.TaskName.startsWith("SUB")){
                                                                    URL=`/SubTask/${pendingTask.TaskName}`
                                                                }else if(pendingTask.TaskName.startsWith("MKUP")){
                                                                URL=`/Markup/${pendingTask.TaskName}`
                                                            }else{
                                                                URL=`/ViewTask/${pendingTask.Customer}/${pendingTask.Milestone_Name}/${pendingTask.TaskName}`
                                                            }
                                                            document.getElementById("TaskURL").setAttribute("href",URL);
                                                            document.getElementById("taskID").innerHTML=pendingTask.TaskLabel?pendingTask.TaskLabel:pendingTask.TaskName;
                                                            var myModal=new bootstrap.Modal(document.getElementById("staticBackdrop"),{
                                                                keyboard:false
                                                            });
                                                            myModal.show();
                                                            }else if (e.response.data == "Access Denied") {
                                                                alert("Your session got closed.Login again to continue")
                                                            } else {
                                                                console.log(e)
                                                                alert("Unable to start the Timer. Try again...!")
                                                            }
                                                        })
                                                    });
                                                    const ProjectStatus = '<%= Task.Status %>'
                                                    const techInfo = document.querySelectorAll('input[type=number].techInfo');
                                                    techInfo.forEach(input => {
                                                        input.addEventListener('change', saveTechInfo);
                                                        if (ProjectStatus === 'WIP' && input.getAttribute("name")!="Total") {
                                                            input.removeAttribute('readonly')
                                                        } else {
                                                            input.setAttribute('readonly', '')
                                                        }
                                                    });

                                                    function saveTechInfo() {
                                                        document.getElementById("autosaveStatus").innerHTML = '<span><i class="bi bi-arrow-repeat"></i></span>'
                                                        let values = {};
                                                        techInfo.forEach(input => {
                                                            values[input.name] = input.value ? parseInt(input.value) : 0;
                                                        });
                                                        axios.post("/api/updateTechInfo/<%= Task.TaskName %>", { values }).then(res => {
                                                            document.getElementById("autosaveStatus").innerHTML = '<span><i class="bi bi-cloud-check"></i></span>';
                                                            toasts.push(res.data.Notification)
                                                        }).catch(error => {
                                                            toasts.push(error.response.data.Notification)
                                                            document.getElementById("autosaveStatus").innerHTML = '<span class="text-danger">Error <i class="bi bi-info-circle"></i></span>'
                                                        })
                                                    }

                                                    document.getElementById("markTaskCompleted").addEventListener("click", (e) => {
                                                        if (elapsedTime != 0) {
                                                            alert("Please stop the timer before submitting the task.");
                                                        } else if (elapsedTime == 0) {
                                                            const Iteration = parseInt($("#Iteration").val());
                                                            const Score = parseFloat($("#Score").val());
                                                            const Total_Footage = parseInt($("#Total_Footage").val());
                                                            const No_Nodes = parseInt($("#No_Nodes").val());
                                                            const Total_Home_Passing = parseInt($("#Total_Home_Passing").val());
                                                            let isTechInfoFilled=true;
                                                            techInfo.forEach(input=>{
                                                                console.log(parseInt(input.value),!isNaN(parseInt(input.value)));
                                                                if(parseInt(input.value)>=0 && (!isNaN(parseInt(input.value)))){
                                                                    isTechInfoFilled= (isTechInfoFilled&&true)
                                                                }else{
                                                                    isTechInfoFilled=false
                                                                }
                                                            });
                                                            let temp = false;
                                                            if (Iteration && Score && isTechInfoFilled) {
                                                                temp = confirm('Are you sure you wan to submit this task...?\nYour total working time is <%=secondsToMinutes(Task.TotalTime) %>.');
                                                            } else {
                                                                if(isTechInfoFilled==false){
                                                                    alert("Please fill the Technical Information.")
                                                                }else{
                                                                    alert("Please fill the QC Checklist before submitting the Task.")
                                                                }
                                                            }

                                                            if (temp) {
                                                                e.target.setAttribute("disabled", "")
                                                                e.target.innerHTML = `<span class="spinner-grow spinner-grow-sm" aria-hidden="true"></span><span role="status">Submitting...</span>`
                                                                axios.post('/api/MarkTaskCompleted/<%= Task.TaskName %>/Task').then(res => {
                                                                    toasts.push(res.data.Notification)
                                                                    window.location.reload();
                                                                }).catch(error => {
                                                                    console.log(error)
                                                                    e.target.innerHTML = `Error <i class="bi bi-x-circle m-1"></i>`
                                                                    toasts.push(error.response.data.Notification)
                                                                })
                                                            }
                                                        } else if (parseInt('<%=secondsToMinutes(Task.TotalTime) %>') < 10) {
                                                            alert("You can't submit this job now.\nMin of 10 min working is required.")
                                                        }
                                                    });
                                                    const CompletedSubTaskLength='<%= Object.values(CompletedSubtask).length %>';
                                                    let temp = document.querySelector("#QC_Link").href;
                                                    document.querySelector("#QC_Link").href = temp + `?Token=${btoa('<%= userData.Employee_ID %>')}&cfas_no=${btoa('<%= Milestone_Info.Project_ID %>')}&qc_state=${btoa('<%= Milestone_Info.Region %>')}&qc_city=${btoa('<%= Milestone_Info.Region %>')}&qc_type=${btoa('<%= Task.Type==="Production"?"Self QC":Task.Type %>')}&Task_ID=${btoa('<%= Task.TaskName %>')}`;
                                                    try {
                                                        axios.get('https://172.17.1.22:5000/api/QGPMS/Checklist/<%-Task.Project_ID%>/<%-Task.QC_Name %>/<%- Task.Type==="Production"?"Self QC":Task.Type %>/<%-Task.TaskName%>', {
                                                            crossdomain: true, headers: {
                                                                "Cache-Control": "no-cache",
                                                                "Content-Type": "application/x-www-form-urlencoded",
                                                                "Access-Control-Allow-Origin": "*"
                                                            },
                                                        }).then(res => {
                                                            console.log(res)
                                                            const data = res.data;
                                                            if (data.Iteration > 0 && data.url) {
                                                                document.getElementById('Checklist_Url').href = data.url;
                                                                document.getElementById("Iteration").value = data.Iteration;
                                                                document.getElementById("Score").value = data.Score + '%';
                                                            } else {
                                                                document.getElementById('Checklist_Url').classList.add("visually-hidden")
                                                            }
                                                        }).catch(e => {
                                                            console.log(e)
                                                            document.getElementById('Checklist_Url').classList.add("visually-hidden")
                                                        })
                                                    } catch (error) {
                                                        console.log(e)
                                                    }
                                                    const commentDeleteBtn = document.querySelectorAll('.deleteBtn');
                                                    commentDeleteBtn.forEach(btn => btn.addEventListener("click", e => {
                                                        e.target.setAttribute('disabled', '')
                                                        const commentID = e.target.getAttribute('data-comment-id');
                                                        const projectID = e.target.getAttribute('data-project-id');
                                                        const Customer = e.target.getAttribute('data-Customer');
                                                        const Target = e.target.getAttribute("data-target");
                                                        axios.delete('/api/deleteComment', {
                                                            data: {
                                                                Customer: Customer,
                                                                commentID: commentID,
                                                                projectID: projectID,
                                                                Target: Target
                                                            }
                                                        }).then(res => {
                                                            window.location.reload();
                                                            console.log(res)
                                                        }).catch(error => {
                                                            console.log(error);
                                                            e.target.removeAttribute('disabled')
                                                        })
                                                    }));
                                                    $("#Arial").change(function(e){
                                                        $("#Total").val(parseInt($("#Arial").val())+parseInt($("#Buried").val()))
                                                    })
                                                    $("#Buried").change(function(e){
                                                        $("#Total").val(parseInt($("#Arial").val())+parseInt($("#Buried").val()))
                                                    })
                                                        $("#Sub_QC_Due_Date").change(function (){
                                                        if(( $("#Sub_Due_Date").val()) && $(this).val()<=$("#Sub_Due_Date").val()){
                                                            alert("Date of QC Due cannot be less than the deadline for production.")
                                                            $(this).val("")
                                                            $("#Sub_Due_Date").val("")
                                                        }
                                                        
                                                        });
                                                        $("#Sub_Due_Date").change(function (){
                                                        if(( $("#Sub_QC_Due_Date").val()) && $(this).val()<=$("#Sub_QC_Due_Date").val()){
                                                            alert("Date of QC Due cannot be less than the deadline for production.")
                                                            $(this).val("");
                                                            $("#Sub_QC_Due_Date").val("");
                                                        }
                                                    });
                                                </script>