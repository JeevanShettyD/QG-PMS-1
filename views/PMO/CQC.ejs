<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CQC Task</title>
    <%- include('../partials/dependencies') %>
</head>
<% if (userData.Role=="Employee" ) { %>
    <%- include('../partials/Employee-header',{userData:userData}) %>
        <% }else if(userData.Role=="Admin" ){ %>
            <%- include('../partials/Admin-header',{userData:userData}) %>
                <% }else if(userData.Role=="PMO" ){ %>
                    <%- include('../partials/PMO-header',{userData:userData}) %>
                        <%}if(userData.Role=="Manager"){ %>
                            <%- include('../partials/Manager-header',{userData:userData}) %>
                                <%}%>

                                    <body>
                                        <main class="d-flex h-100">
                                            <section class="shadow w-75 p-2 rounded  scrollbar-style-3"
                                                style="height: calc(100vh - 46px); overflow-y: scroll; overflow-x: hidden;">
                                                <div class="d-flex  justify-content-between  align-items-center">
                                                    <div class="d-flex">
                                                        <img width="40" height="40"
                                                            src="https://img.icons8.com/nolan/64/checklist.png"
                                                            alt="checklist" />
                                                        <div class="d-flex align-items-center">
                                                            <p class="rounded bg-primary bg-gradient bg-opacity-50  p-1 m-1 text-light"
                                                                style="width:fit-content; font-size: 14px;">
                                                                Task
                                                            </p>
                                                            <p class="m-0 p-0 fs-5 text-bold">
                                                                <%= Task.TaskLabel?Task.TaskLabel:"-" %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <p class="p-0 m-0 d-inline">Current Status: <span class="bg-gradient bg-opacity-75  text-light me-2
                                                                                            <% if(Task.Status ==='YTS'){%> bg-danger <% }else if(Task.Status==='WIP' ){ %>
                                                                                            bg-warning <% }else if(Task.Status==='Completed'){ %> bg-success <% }else{%> bg-primary <%}%>rounded-5
                                                                                                                                px-2 py-1">
                                                                                                                            <%= Task.Status %>
                                                            </span>
                                                        </p>
                                                        <button type="button" id="markTaskCompleted"
                                                            class="d-inline rounded bg-primary bg-gradient btn btn-primary btn-sm mx-2 <% if (Task.Status!='WIP' || Task.Owner!=userData.Employee_ID) { %> visually-hidden <% } %>">Submit<i class="ms-2 bi bi-arrow-right"></i></button>
                                                    </div>
                                                </div>
                                                <div>
                                                    <section class="qg-tab bg-primary bg-gradient bg-opacity-75  rounded-3 shadow-sm">
                                                        <input type="checkbox" name="accordion-1" id="cb1" checked>
                                                        <label for="cb1" class="qg-tab__label">Information</label>
                                                        <div class="qg-tab__content bg-light">
                                                        <div class="row">
                                                            <p class="col ">Task ID:<br>
                                                                <input type="text"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%=Task.TaskName %>" readonly></input>
                                                                <!-- <a class="d-block bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1" href="/ViewTask/<%=Customer%>/<%= Milestone_Info.Milestone_Name %>/<%=Task.TaskName %>"><%=Task.TaskName %></a> -->
                                                            </p>
                                                            <p class="col">Job-ID: <span data-bs-toggle="modal"
                                                                    data-bs-target="#Project_Info_Modal"
                                                                    title="Click to View the Project Details"><i
                                                                        class="bi bi-info-circle text-primary d-none"></i></span>
                                                                <br>
                                                                <a href="/Project/<%= Milestone_Info.Customer %>/<%= Milestone_Info.Project_ID %>/<%= Milestone_Info.idProjects %>"
                                                                    class="d-block bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1">
                                                                    <%= Milestone_Info.Project_ID %>
                                                                </a>
                                                            </p>
                                                            <p class="col">Milestone: <br>
                                                                <a class="d-block bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    href="/ViewMilestone/<%=Customer%>/<%= Milestone_Info.idProjects %>/<%= Milestone_Info.Milestone_Name %>">
                                                                    <%= Milestone_Info.Milestone_Name %>
                                                                </a>
                                                            </p>
                                                            <p class="col">Task Type:<br> <input type="text"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%= Task.Type %>" readonly></input>
                                                            </p>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col">
                                                                <span class="d-inline">Owner:</span><br>
                                                                <% if ((userData.Role=="PMO" || userData.Role=="Manager"
                                                                    )&&(Task.Status!='Completed')) { %>
                                                                    <select name="" id="TaskOwner"
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1 w-auto select-list hidden"
                                                                        data-OwnerFor="Task"
                                                                        data-ID="<%=Task.TaskName %>">
                                                                        <% for( let index=0; index <
                                                                            Object.values(Owners).length; index++){%>
                                                                            <% if (Owners[index].Role!="PMO" ) { %>
                                                                                <option
                                                                                    value="<%= Owners[index].Employee_ID %>"
                                                                                    <%
                                                                                    if(Owners[index].Employee_ID==Task.Owner)
                                                                                    { %>
                                                                                    selected
                                                                                    <% } %>>
                                                                                        <%= Owners[index].Full_Name %> (
                                                                                            <%= Owners[index].Employee_ID
                                                                                                %>
                                                                                                )
                                                                                </option>
                                                                                <% } %>
                                                                                    <% } %>
                                                                    </select>
                                                                    <p
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1 m-0 user-info">
                                                                        <span class="Owner"
                                                                            data-userID="<%= Task.Owner %>">
                                                                            <%= Task.Owner %>
                                                                        </span><span class="toggle-button"><i
                                                                                class="bi bi-pencil-fill"></i></span>
                                                                    </p>
                                                                    <% } else { %>
                                                                        <p
                                                                            class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1 m-0">
                                                                            <span class="Owner"
                                                                                data-userID="<%= Task.Owner %>">
                                                                                <%= Task.Owner %>
                                                                            </span>
                                                                        </p>
                                                                        <% } %>

                                                            </div>
                                                            <p class="col" data-bs-toggle="tooltip"
                                                                data-bs-placement="top"
                                                                data-bs-title="Open this checklist in another Browser/Private window.">
                                                                <span class="required">Checklist:</span> <a href=""
                                                                    title="Download the Filled Checklist" class=""
                                                                    id="Checklist_Url"><i
                                                                        class="bi bi-arrow-down-circle"></i></a><br>
                                                                <a id="QC_Link" title="<%= Task.QC_Name %>" class="d-block bg-secondary bg-gradient bg-opacity-25 fw-bold text-dark rounded-3 p-1 <% if (Task.Owner != userData.Employee_ID || Task.Status=='Completed' || Task.Status=='YTS') { %>
                                     disabled
                                    <% } %>" href="https://172.17.1.22:5000/Engineer/QC/<%= Task.QC_Name %>"
                                                                    target="_blank">
                                                                    <%= Task.QC_Name %>
                                                                </a>
                                                            </p>
                                                            <p class="col"><span class="required">Iteration:</span><br>
                                                                <input type="text" id="Iteration"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%= Task.Iteration %>" readonly>
                                                            </p>
                                                            <p class="col"><span class="required">QC Score:</span><br>
                                                                <input type="text" id="Score"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%= Task.Score %>" readonly>
                                                            </p>
                                                        </div>
                                                        <div class="row">
                                                            <p class="col"><span class="required">Total Time:</span><br>
                                                                <input type="text"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%=secondsToMinutes(Task.TotalTime+subTaskTotalTime) %>"
                                                                    readonly></input>
                                                            </p>
                                                            <% if (Task.Type=='Production') { %>
                                                                <p class="col">Due Date:<br> <input
                                                                        type="text"
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        value="<%= Task.DueDate?Task.DueDate:"-" %>"
                                                                        readonly></input> </p>
                                                                <p class="col">Start Date:<br> <input
                                                                        type="text"
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        value="<%= Task.StartDate %>"
                                                                        readonly></input> </p>
                                                                <p class="col">End Date:<br> <input
                                                                        type="text"
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        value="<%= Task.EndDate %>"
                                                                        readonly></input> </p>

                                                                <% }else if(Task.Type=='IQC' || Task.Type=='RQC' ){%>
                                                                    <% if(Task.Prod_Task){%>
                                                                    <p class="col ">Production Task ID:<br>
                                                                <input type="text" hidden
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    value="<%=Task.Prod_Task %>" readonly></input>
                                                               <a class="d-block bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1" href="/ViewTask/<%=Customer%>/<%= Milestone_Info.Milestone_Name %>/<%=Task.Prod_Task %>"><%=Task.Prod_Task %></a>
                                                            </p>
                                                            <%}%>
                                                                    <p class="col">Start Date:<br> <input
                                                                            type="text"
                                                                            class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                            value="<%= Task.StartDate %>"
                                                                            readonly></input> </p>
                                                                    <p class="col">End Date:<br> <input
                                                                            type="text"
                                                                            class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                            value="<%= Task.EndDate %>"
                                                                            readonly></input> </p>
                                                                    <% } %>
                                                        </div>
                                                        <div class="row mb-2">
                                                            <% if (Task.Type!='Production') { %>
                                                            <p class="col ">Due Date:<br> <input
                                                                        type="text"
                                                                        class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        value="<%= Task.DueDate?Task.DueDate:"-" %>"
                                                                        readonly></input> </p>
                                                                        <%}%>
                                                            <p class="col">Manager Remark:
                                                                <input type="text" name="Remark" id="Remark"
                                                                    value="<%= Task.Remark?Task.Remark:"N/A" %>"
                                                                    class="bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                    placeholder="Remark" readonly>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    </section>

                                                    <!--Tech Info Section-->
                                                    <section class="qg-tab bg-primary bg-gradient bg-opacity-75 mt-2 rounded-3 shadow-sm">
                                                        <input type="checkbox" name="accordion-1" id="cb2">
                                                        <label for="cb2" class="qg-tab__label">Technical Details</label>
                                                        <div class="position-absolute end-0 top-0 m-2">
                                                            <p class="m-0 p-0 btn text-light" id="autosaveStatus">
                                                                <i class="bi bi-cloud-check fw-bold rounded-3 p-1"></i>
                                                            </p>
                                                        </div>
                                                        <div class="qg-tab__content bg-light">
                                                        <div class="row">
                                                            <% let techDetails=JSON.parse(Task.TechInfo); %>
                                                            <% if(Customer=="ATX"){%>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Total_Home_Passing">Total
                                                                        Home Passing :</label>
                                                                    <input type="number" id="Total_Home_Passing"
                                                                        minlength="3"
                                                                        value="<%= Milestone_Info.Total_Home_Passing?Milestone_Info.Total_Home_Passing:null %>"
                                                                        min="0" name="Total_Home_Passing"
                                                                        class="techInfo bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        placeholder="Enter the Total Home Passing"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" required>
                                                                </div>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Arial">Aerial(Act):</label>
                                                                <div class="input-group flex-nowrap p-0">
                                                                    <input type="number" id="Arial"
                                                                        value="<%= Milestone_Info.Arial?Milestone_Info.Arial:null %>"
                                                                        min="0" name="Arial"
                                                                        class="techInfo  bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-start-3 p-1"
                                                                        placeholder="Enter the Aerial"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" required>
                                                                        <span class="input-group-text  bg-secondary bg-gradient bg-opacity-25 border-0 rounded-start-0 m-0 px-2"
                                                                        id="basic-addon2">ft</span>
                                                                </div>
                                                                </div>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Buried">Buried (Act):</label>
                                                                        <div class="input-group flex-nowrap p-0">
                                                                    <input type="number" id="Buried" minlength="3"
                                                                        value="<%= Milestone_Info.Buried?Milestone_Info.Buried:null %>"
                                                                        min="0" name="Buried"
                                                                        class="techInfo  bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-start-3 p-1"
                                                                        placeholder="Enter the No of Nodes"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" required>
                                                                        <span class="input-group-text  bg-secondary bg-gradient bg-opacity-25 border-0 rounded-start-0 m-0 px-2"
                                                                        id="basic-addon2">ft</span>
                                                                        </div>
                                                                </div>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Total">Total (Act):</label>
                                                                        <div class="input-group flex-nowrap p-0">
                                                                    <input type="number" id="Total" minlength="3"
                                                                        value="<%= Milestone_Info.Buried+Milestone_Info.Arial %>"
                                                                        min="0" name="Total"
                                                                        class="techInfo  bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-start-3 p-1"
                                                                        placeholder="Enter the No of Nodes"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" readonly required>
                                                                        <span class="input-group-text  bg-secondary bg-gradient bg-opacity-25 border-0 rounded-start-0 m-0 px-2"
                                                                        id="basic-addon2">ft</span>
                                                                        </div>
                                                                </div>
                                                                <%}else{%> 
                                                                    <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Total_Home_Passing">Total
                                                                        Home Passing :</label>
                                                                    <input type="number" id="Total_Home_Passing"
                                                                        minlength="3"
                                                                        value="<%= Milestone_Info.Total_Home_Passing?Milestone_Info.Total_Home_Passing:null %>"
                                                                        min="0" name="Total_Home_Passing"
                                                                        class="techInfo bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        placeholder="Enter the Total Home Passing"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" required>
                                                                </div>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="No_Nodes">No of
                                                                        Nodes :</label>
                                                                    <input type="number" id="No_Nodes" minlength="3"
                                                                        value="<%= Milestone_Info.No_Nodes?Milestone_Info.No_Nodes:null %>"
                                                                        min="0" name="No_Nodes"
                                                                        class="techInfo bg-secondary bg-gradient bg-opacity-25 fw-bold rounded-3 p-1"
                                                                        placeholder="Enter the No of Nodes"
                                                                        title="Positive Integers Only..."
                                                                        pattern="[0-9]+" required>
                                                                </div>
                                                                <div class="col">
                                                                    <label class="mb-1 text-nowrap required"
                                                                        for="Total_Footage ">Total Footage :</label>
                                                                    <div class="input-group flex-nowrap p-0">
                                                                        <input type="number" name="Total_Footage"
                                                                            id="Total_Footage" min="0"
                                                                            class="techInfo bg-secondary bg-gradient bg-opacity-25 fw-bold  rounded-start-3 p-1"
                                                                            placeholder="Enter the Total Footage"
                                                                            minlength="8"
                                                                            value="<%= Milestone_Info.Total_Footage?Milestone_Info.Total_Footage:null %>"
                                                                            title="Positive Integers Only..."
                                                                            pattern="[0-9]+">
                                                                        <span
                                                                            class="input-group-text bg-secondary bg-gradient bg-opacity-25 border-0 rounded-start-0 m-0 p-0 px-2"
                                                                            id="basic-addon2">ft</span>
                                                                    </div>

                                                                </div>
                                                                <%}%>
                                                        </div>
                                                    </section>

                                                    <!--Subtask Section-->
                                                    <section class="qg-tab bg-primary bg-gradient bg-opacity-75 mt-2 rounded-3 shadow-sm">
                                                        <input type="checkbox" name="accordion-1" id="cb3">
                                                        <label for="cb3" class="qg-tab__label">Subtask</label>
                                                        <div class="position-absolute end-0 top-0 m-2">
                                                            <p class="m-0 p-0 btn text-light <% if ((Task.Status!='WIP' || Task.Owner != userData.Employee_ID) && (userData.Role!="PMO" || Task.Status=="YTS")) { %> visually-hidden <% }%>"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#create-Subtask-Task-Modal"><i
                                                                    class="bi bi-plus-circle"></i>
                                                            </p>
                                                        </div>
                                                        <div class="qg-tab__content bg-light">
                                                                <table class="table table-hover overflow-hidden rounded-3"
                                                                    aria-label="task table" style="font-size: 14px;">
                                                                    <thead class="bg-primary  bg-opacity-50 bg-gradient">
                                                                        <th scope="col" class="text-light"></th>
                                                                        <th scope="col" class="text-light">Subtask ID</th>
                                                                        <th scope="col" class="text-light">Subtask Name</th>
                                                                        <th scope="col" class="text-light">Task Name</th>
                                                                        <th scope="col" class="text-light">Owner</th>
                                                                        <th scope="col" class="text-light">Status</th>
                                                                        <th scope="col" class="text-light">ACT Start Date
                                                                        </th>
                                                                        <th scope="col" class="text-light">ACT End Date</th>
                                                                    </thead>
                                                                    <tbody>
                                                                        <% if (Object.values(subTask).length>0) { %>
                                                                            <% for( let index=0; index <
                                                                                Object.values(subTask).length; index++ ) {
                                                                                %>
                                                                                <tr>
                                                                                    <td>
                                                                                        <%= index+1 %>
                                                                                    </td>
                                                                                    <td class="text-nowrap">
                                                                                        <a
                                                                                            href="/SubTask/<%= subTask[index].SubTaskName %>">
                                                                                            <%= subTask[index].SubTaskName
                                                                                                %>
                                                                                        </a>
                                                                                    </td>
                                                                                    <td class="text-wrap">
                                                                                        <%= subTask[index].SubTaskLabel?subTask[index].SubTaskLabel:"-"%>
                                                                                        </td>
                                                                                    <td class="text-nowrap">
                                                                                        <%= subTask[index].Task_Name %>
                                                                                    </td>
                                                                                    <td class="Owner"
                                                                                        data-userID="<%= subTask[index].Owner %>">
                                                                                        <%= subTask[index].Owner %>
                                                                                    </td>
                                                                                    <td>
                                                                                        <%= subTask[index].Status %>
                                                                                    </td>
                                                                                    <td>
                                                                                        <%= subTask[index].StartDate?subTask[index].StartDate:"-"
                                                                                            %>
                                                                                    </td>
                                                                                    <td>
                                                                                        <%= subTask[index].EndDate?subTask[index].EndDate:"-"
                                                                                            %>
                                                                                    </td>
                                                                                </tr>
                                                                                <% } %>
                                                                                    <% } else { %>
                                                                                        <tr>
                                                                                            <td colspan="8"
                                                                                                class="text-center">No
                                                                                                Subtask</td>
                                                                                        </tr>
                                                                                        <% } %>
                                                                    </tbody>
                                                                </table>
                                                        </div>
                                                    </section>

                                                    <!--Markup Section-->
                                                    <section class="qg-tab bg-primary bg-gradient bg-opacity-75 mt-2 rounded-3 shadow-sm <% if(Task.Type=='Production'){%> d-none <%}%>">
                                                        <input type="checkbox" name="accordion-1" id="cb4">
                                                        <label for="cb4" class="qg-tab__label">Markups</label>
                                                        <div class="position-absolute end-0 top-0 m-2">
                                                            <p class="m-0 p-0 btn text-light <% if (Task.Owner != userData.Employee_ID && Task.Status!="WIP" && Task.Status!="Completed" && userData.Role!="PMO") { %> visually-hidden <% }%>"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#create-Markup-Task-Modal"><i
                                                                    class="bi bi-plus-circle"></i></p>
                                                        </div>
                                                        <div class="qg-tab__content bg-light">
                                                            <table class="table table-hover overflow-hidden rounded-3"
                                                                aria-label="markup table" style="font-size: 14px;">
                                                                <thead class="bg-primary  bg-opacity-50 bg-gradient">
                                                                    <th scope="col" class="text-light"></th>
                                                                    <th scope="col" class="text-light">Markup Name</th>
                                                                    <th scope="col" class="text-light">Task Name</th>
                                                                    <th scope="col" class="text-light">Owner</th>
                                                                    <th scope="col" class="text-light">Status</th>
                                                                    <th scope="col" class="text-light">ACT Start Date
                                                                    </th>
                                                                    <th scope="col" class="text-light">ACT End Date</th>
                                                                </thead>
                                                                <tbody>
                                                                    <% if (Object.values(markup).length>0) { %>
                                                                        <% for( let index=0; index <
                                                                            Object.values(markup).length; index++ ) { %>
                                                                            <tr>
                                                                                <td>
                                                                                    <%= index+1 %>
                                                                                </td>
                                                                                <td>
                                                                                    <a
                                                                                        href="/Markup/<%= markup[index].Sub_Task_Name %>">
                                                                                        <%= markup[index].Sub_Task_Name
                                                                                            %>
                                                                                    </a>
                                                                                </td>
                                                                                <td>
                                                                                    <%= markup[index].Task_Name %>
                                                                                </td>
                                                                                <td class="Owner"
                                                                                    data-userID="<%= markup[index].Owner %>">
                                                                                    <%= markup[index].Owner %>
                                                                                </td>
                                                                                <td>
                                                                                    <%= markup[index].Status %>
                                                                                </td>
                                                                                <td>
                                                                                    <%= markup[index].StartDate?markup[index].StartDate:"-"
                                                                                        %>
                                                                                </td>
                                                                                <td>
                                                                                    <%= markup[index].EndDate?markup[index].EndDate:"-"
                                                                                        %>
                                                                                </td>
                                                                            </tr>
                                                                            <% } %>
                                                                                <% } else { %>
                                                                                    <tr>
                                                                                        <td colspan="8"
                                                                                            class="text-center">No
                                                                                            Markup</td>
                                                                                    </tr>
                                                                                    <% } %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </section>
                                                </div>
                                            </section>
                                            <button type="button" data-bs-toggle="modal"
                                                data-bs-target="#Add_Comment_Modal"
                                                class="position-absolute bottom-0 end-0 btn btn-primary z-3 bordre border-1 m-1 rounded-circle bg-gradient"><i
                                                    class="bi bi-chat-dots fs-4"></i></button>
                                            <section class="w-25 px-2 pt-2  scrollbar-style-3 z-1"
                                                style="height: calc(100vh - 46px); overflow-y: scroll; ">
                                                <%let completedStatus=['Ready for QC','Completed','IQC-YTS','IQC-WIP','IQC-Completed']%>
                                                <div class="shadow-sm bg-body-tertiary rounded">
                                                    <div
