<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task</title>
  <%- include('../partials/dependencies') %>
</head>

<% if (userData.Role=="Employee") { %>
  <%- include('../partials/Employee-header',{userData:userData}) %>
<% } else if(userData.Role=="Admin") { %>
  <%- include('../partials/Admin-header',{userData:userData}) %>
<% } else if(userData.Role=="PMO") { %>
  <%- include('../partials/PMO-header',{userData:userData}) %>
<% } if(userData.Role=="Manager") { %>
  <%- include('../partials/Manager-header',{userData:userData}) %>
<% } %>

<style>
  /* ══════════════════════════════════════
     DESIGN SYSTEM — exact match to Milestone
  ══════════════════════════════════════ */
  :root {
    --navy-900: #0f1e36;
    --navy-800: #152844;
    --navy-700: #1b3258;
    --blue-500: #2d7dd2;
    --blue-400: #4a96e8;
    --accent:   #00c6ff;
    --page-bg:  #f0f4fa;
    --card-bg:  #ffffff;
    --border:   #e2e8f4;
    --text:     #1e2d45;
    --muted:    #7a8aaa;
    --radius:   10px;
    --shadow:   0 1px 4px rgba(15,30,80,0.06), 0 4px 16px rgba(15,30,80,0.07);
    --tr:       all 0.18s cubic-bezier(0.4,0,0.2,1);
  }
  html, body { background: var(--page-bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; }
  main { display: grid; grid-template-columns: 1fr 280px; gap: 12px; padding: 12px 18px 40px; height: calc(100vh - 52px); }

  /* ══════════════════════════════════════
     PAGE HEADER BAR — dark navy gradient
  ══════════════════════════════════════ */
  .vt-header {
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-800) 55%, var(--navy-700) 100%);
    border-radius: var(--radius); padding: 11px 16px;
    margin-bottom: 10px;
    box-shadow: 0 4px 18px rgba(15,30,80,0.18);
    position: relative; overflow: hidden;
  }
  .vt-header::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--blue-500), var(--accent), transparent);
    opacity: 0.7;
  }
  .vt-header-left { display: flex; align-items: center; gap: 10px; }
  .vt-header-icon {
    width: 38px; height: 38px; border-radius: 9px;
    background: rgba(45,125,210,0.25); border: 1px solid rgba(45,125,210,0.3);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .vt-header-icon i { font-size: 17px; color: var(--accent); }
  .vt-header-name { font-size: 14px; font-weight: 800; color: #fff; letter-spacing: 0.2px; }
  .vt-header-sub {
    font-size: 11px; color: rgba(255,255,255,0.5); font-weight: 500;
    display: flex; align-items: center; gap: 5px; margin-top: 2px;
  }
  .vt-header-sub a { color: var(--accent); font-weight: 700; text-decoration: none; }
  .vt-header-sub a:hover { text-decoration: underline; }
  .vt-header-right { display: flex; align-items: center; gap: 8px; }

  /* Status pill */
  .vt-status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 13px; border-radius: 20px;
    font-size: 11px; font-weight: 700;
    background: rgba(45,125,210,0.22); color: #90c8ff;
    border: 1px solid rgba(45,125,210,0.35);
  }
  .vt-status::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); display: block; box-shadow: 0 0 5px var(--accent);
  }
  .vt-status.wip   { background: rgba(196,154,0,0.2); color: #ffd966; border-color: rgba(196,154,0,0.3); }
  .vt-status.wip::before { background: #ffd966; box-shadow: 0 0 5px #ffd966; }
  .vt-status.done  { background: rgba(13,159,106,0.2); color: #6dffc0; border-color: rgba(13,159,106,0.3); }
  .vt-status.done::before { background: #6dffc0; }
  .vt-status.yts   { background: rgba(220,53,69,0.2); color: #ff9aa2; border-color: rgba(220,53,69,0.3); }
  .vt-status.yts::before { background: #ff9aa2; }

  /* Submit button */
  .vt-submit-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 8px;
    font-size: 12px; font-weight: 700; cursor: pointer; border: none;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    color: #fff; box-shadow: 0 3px 10px rgba(45,125,210,0.35);
    transition: var(--tr);
  }
  .vt-submit-btn:hover { box-shadow: 0 5px 16px rgba(45,125,210,0.5); transform: translateY(-1px); }

  /* ══════════════════════════════════════
     LEFT COLUMN SCROLL
  ══════════════════════════════════════ */
  .vt-left {
    overflow-y: auto; overflow-x: hidden;
    height: calc(100vh - 64px);
  }
  .vt-left::-webkit-scrollbar { width: 5px; }
  .vt-left::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }

  /* ══════════════════════════════════════
     SECTION — same as Milestone
  ══════════════════════════════════════ */
  .vt-section {
    background: var(--card-bg); border: 1px solid #dce8ff;
    border-radius: var(--radius); overflow: hidden;
    box-shadow: 0 2px 10px rgba(45,125,210,0.08); margin-bottom: 10px;
  }
  .vt-section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 14px;
    background: linear-gradient(135deg, #eef5ff 0%, #e4effe 100%);
    border-bottom: 1px solid #d0e4ff;
    cursor: pointer; user-select: none;
  }
  .vt-section-header .sec-left { display: flex; align-items: center; gap: 8px; }
  .vt-section-header .sec-title { font-size: 12.5px; font-weight: 800; color: var(--navy-700); }
  .vt-section-header .sec-icon { font-size: 13px; color: var(--blue-500); }
  .vt-section-header .sec-toggle { font-size: 11px; color: var(--blue-500); transition: transform 0.2s; }
  .vt-section-header.collapsed .sec-toggle { transform: rotate(-90deg); }
  .vt-section-body { padding: 12px 14px; background: #fafcff; }

  /* Add button in section header */
  .vt-add-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 700; cursor: pointer;
    border: 1px solid rgba(45,125,210,0.25);
    background: rgba(45,125,210,0.08); color: var(--blue-500);
    transition: var(--tr);
  }
  .vt-add-btn:hover { background: rgba(45,125,210,0.16); transform: translateY(-1px); }

  /* ══════════════════════════════════════
     INFO GRID — same as Milestone
  ══════════════════════════════════════ */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 9px;
  }
  .info-field {
    display: flex; flex-direction: column; gap: 4px;
    border-radius: 9px; padding: 10px 13px;
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, #ffffff 0%, #f5f9ff 100%);
    border: 1px solid #dce8ff;
    box-shadow: 0 1px 4px rgba(45,125,210,0.07);
    transition: var(--tr);
  }
  .info-field::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, var(--blue-400), var(--blue-500));
    border-radius: 9px 0 0 9px;
  }
  .info-field:hover {
    border-color: rgba(45,125,210,0.4);
    box-shadow: 0 3px 14px rgba(45,125,210,0.14);
    transform: translateY(-1px);
    background: linear-gradient(135deg, #f0f7ff, #e8f2ff);
  }
  .info-field label {
    font-size: 9px; font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.9px; color: var(--blue-500);
    display: flex; align-items: center; gap: 4px; margin: 0; opacity: 0.85;
  }
  .info-field label i { font-size: 10px; }
  .info-field .info-val {
    font-size: 13px; font-weight: 800; color: var(--navy-700);
    display: flex; align-items: center; gap: 6px; min-height: 20px;
  }
  .info-field .info-val a { color: var(--blue-500); text-decoration: none; font-weight: 800; }
  .info-field .info-val a:hover { text-decoration: underline; }
  .info-field .edit-wrap { display: flex; align-items: center; gap: 6px; width: 100%; }
  .info-field select.select-list,
  .info-field input.select-list {
    font-size: 12px; font-weight: 700; color: var(--text);
    border: 1px solid #c8daff; border-radius: 6px;
    padding: 3px 8px; background: #f0f6ff; flex: 1; min-width: 0; transition: var(--tr);
  }
  .info-field select.select-list:focus,
  .info-field input.select-list:focus {
    border-color: var(--blue-500); outline: none;
    box-shadow: 0 0 0 3px rgba(45,125,210,0.18); background: #fff;
  }
  .toggle-button { color: var(--blue-500); cursor: pointer; font-size: 12px; opacity: 0.55; transition: opacity 0.15s; }
  .toggle-button:hover { opacity: 1; }
  .reset-btn { color: var(--blue-500); cursor: pointer; font-size: 14px; opacity: 0.65; }
  .reset-btn:hover { opacity: 1; }

  /* ══════════════════════════════════════
     TABLE — same dark navy as Milestone
  ══════════════════════════════════════ */
  .vt-table-wrap { overflow-x: auto; }
  .vt-table-wrap::-webkit-scrollbar { height: 4px; }
  .vt-table-wrap::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }
  .vt-table {
    width: 100%; border-collapse: collapse;
    font-size: 11.5px; margin: 0; table-layout: auto;
  }
  .vt-table thead th {
    background: linear-gradient(135deg, #1a3060, #1e3a5f);
    color: rgba(255,255,255,0.88);
    font-size: 9.5px; font-weight: 700; letter-spacing: 0.4px;
    text-transform: uppercase; padding: 8px 11px; white-space: nowrap;
    border-bottom: 2px solid rgba(45,125,210,0.35);
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .vt-table thead th:last-child { border-right: none; }
  .vt-table tbody tr {
    border-bottom: 1px solid #edf1fa;
    transition: background 0.12s, box-shadow 0.12s;
  }
  .vt-table tbody tr:nth-child(even) { background: #fafcff; }
  .vt-table tbody tr:hover {
    background: #f0f6ff !important;
    box-shadow: inset 3px 0 0 var(--blue-500);
  }
  .vt-table tbody tr:last-child { border-bottom: none; }
  .vt-table tbody td {
    padding: 7px 11px; color: var(--text); vertical-align: middle;
    border-right: 1px solid #f0f4fc;
  }
  .vt-table tbody td:last-child { border-right: none; }
  .vt-table a { color: var(--blue-500); text-decoration: none; font-weight: 600; }
  .vt-table a:hover { text-decoration: underline; }

  /* Empty state */
  .vt-empty { text-align: center; padding: 22px 16px; }
  .vt-empty i { font-size: 20px; color: rgba(45,125,210,0.3); display: block; margin-bottom: 6px; }
  .vt-empty p { font-size: 11.5px; color: var(--muted); margin: 0; font-weight: 500; }

  /* Delivery status badges */
  .ds-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px; border-radius: 20px;
    font-size: 10px; font-weight: 700; white-space: nowrap;
  }
  .ds-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; display: block; }
  .ds-on-time    { background: #e8faf2; color: #0d9f6a; }
  .ds-approach   { background: #fff8e6; color: #c07a00; }
  .ds-today      { background: #eef4ff; color: #2d6ec0; }
  .ds-delayed    { background: #fff0f2; color: #c02038; }
  .ds-escalation { background: #fff0f2; color: #c02038; }
  .ds-default    { background: #f4f4f8; color: var(--muted); }

  /* Status badge */
  .st-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px; border-radius: 20px; font-size: 10.5px; font-weight: 600;
  }
  .st-wip       { background: #eef4ff; color: #2d6ec0; }
  .st-completed { background: #e8faf2; color: #0d9f6a; }
  .st-yts       { background: #fff0f2; color: #c02038; }
  .st-other     { background: #f4f4f8; color: var(--muted); }

  /* Time badge */
  .time-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 9px; border-radius: 7px; font-size: 11px; font-weight: 800;
    background: linear-gradient(135deg, rgba(45,125,210,0.12), rgba(45,125,210,0.06));
    color: var(--blue-500); border: 1px solid rgba(45,125,210,0.2);
  }
  .time-badge i { color: var(--accent); font-size: 10px; }

  /* ══════════════════════════════════════
     RIGHT PANEL — Timer + Comments
  ══════════════════════════════════════ */
  .vt-right {
    overflow-y: auto; overflow-x: hidden;
    height: calc(100vh - 64px);
  }
  .vt-right::-webkit-scrollbar { width: 4px; }
  .vt-right::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }

  /* Timer card */
  .vt-timer-card {
    background: var(--card-bg); border: 1px solid #dce8ff;
    border-radius: var(--radius); overflow: hidden;
    box-shadow: 0 2px 10px rgba(45,125,210,0.08); margin-bottom: 10px;
  }
  .vt-timer-display {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-700));
    padding: 12px 14px; text-align: center;
  }
  .vt-timer-display .display {
    font-size: 22px; font-weight: 900; color: #fff;
    font-variant-numeric: tabular-nums; letter-spacing: 2px;
    text-shadow: 0 2px 8px rgba(0,198,255,0.4);
    display: block; margin-bottom: 8px;
    font-family: 'Courier New', monospace;
  }
  .vt-timer-btns { display: flex; justify-content: center; gap: 8px; }
  .vt-timer-btns button {
    width: 36px; height: 36px; border-radius: 50%; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; font-size: 16px;
    transition: var(--tr);
  }
  #startBtn { background: linear-gradient(135deg, #0d9f6a, #0b8058); color: #fff; box-shadow: 0 3px 10px rgba(13,159,106,0.4); }
  #startBtn:hover { transform: scale(1.1); }
  #stopBtn  { background: linear-gradient(135deg, #c02038, #a01028); color: #fff; box-shadow: 0 3px 10px rgba(192,32,56,0.4); }
  #stopBtn:hover  { transform: scale(1.1); }

  /* Timesheet section */
  .vt-panel-header {
    display: flex; align-items: center; gap: 7px;
    padding: 9px 14px;
    background: linear-gradient(135deg, #eef5ff, #e4effe);
    border-bottom: 1px solid #d0e4ff;
  }
  .vt-panel-header i { color: var(--blue-500); font-size: 13px; }
  .vt-panel-header span { font-size: 12px; font-weight: 800; color: var(--navy-700); }
  .vt-panel-header .panel-action { margin-left: auto; color: var(--blue-500); cursor: pointer; font-size: 14px; }
  .vt-panel-header .panel-action:hover { opacity: 0.7; }

  /* Timesheet table */
  .ts-table { width: 100%; border-collapse: collapse; font-size: 11px; }
  .ts-table thead th {
    background: linear-gradient(135deg, #1a3060, #1e3a5f);
    color: rgba(255,255,255,0.85);
    font-size: 9px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.4px; padding: 6px 10px; white-space: nowrap;
  }
  .ts-table tbody tr { border-bottom: 1px solid #edf1fa; }
  .ts-table tbody tr:hover { background: #f4f8ff; }
  .ts-table tbody td { padding: 6px 10px; color: var(--text); }

  /* Comments */
  .comment-block {
    padding: 8px 12px; border-bottom: 1px solid #f0f4fc;
    font-size: 11.5px;
  }
  .comment-block:last-child { border-bottom: none; }
  .comment-meta { color: var(--muted); font-size: 10.5px; margin-bottom: 4px; display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
  .comment-text {
    padding: 7px 10px; border-radius: 8px;
    line-height: 1.5; font-size: 11.5px; color: var(--text);
    border: 1px solid var(--border); background: #f8fbff;
  }
  .comment-text.is-owner {
    background: linear-gradient(135deg, rgba(45,125,210,0.08), rgba(45,125,210,0.04));
    border-color: rgba(45,125,210,0.2);
  }
  .comment-del { color: #c02038; cursor: pointer; opacity: 0.6; font-size: 11px; }
  .comment-del:hover { opacity: 1; }

  /* Closure checklist items */
  .closure-item {
    display: flex; flex-direction: column; gap: 3px;
    padding: 9px 12px; border-radius: 8px; margin-bottom: 6px;
    background: linear-gradient(135deg, #f8fbff, #f0f6ff);
    border: 1px solid #dce8ff; font-size: 12px;
  }
  .closure-item label { color: var(--muted); font-size: 10.5px; font-weight: 600; }
  .closure-status { font-weight: 700; color: var(--text); }

  /* Production lock notice */
  .prod-notice {
    background: rgba(196,154,0,0.08); border: 1px solid rgba(196,154,0,0.2);
    border-radius: 8px; padding: 8px 12px; font-size: 11px; color: #c07a00;
    text-align: center; margin-top: 8px;
  }

  /* hidden */
  .hidden { display: none !important; }
</style>

<body>
<%
  let bgColour = "";
  let bgMap = {
    "On Time":"on-time","Approaching Due Date":"approach",
    "Due Today":"today","Delayed":"delayed","Escalation":"escalation"
  };
  function dsBadge(status) {
    if (!status) return '<span class="ds-badge ds-default">—</span>';
    const cls = bgMap[status] || 'default';
    return '<span class="ds-badge ds-' + cls + '">' + status + '</span>';
  }
  function stBadge(s) {
    if (!s) return '<span class="st-badge st-yts">—</span>';
    const l = s.toLowerCase();
    const c = l.includes('wip') ? 'wip' : l.includes('complet') || l.includes('ready') ? 'completed' : l.includes('yts') ? 'yts' : 'other';
    return '<span class="st-badge st-' + c + '">' + s + '</span>';
  }
  let completedStatus = ['Ready for QC','Completed','IQC-YTS','IQC-WIP','IQC-Completed'];
  let lock = false;
  if(Object.values(Log).length){
    let last = Log[Object.values(Log).length-1];
    if(last.startTime != null && last.endTime == null) lock = true;
  }
  let statusCls = Task.Status==='WIP' ? 'wip' : Task.Status==='Completed'||Task.Status==='Ready for QC' ? 'done' : 'yts';
  let x = (Milestone_Info.Customer!="AT&T") ? "Job ID" : "F2 CFAS-ID";
%>

<main>

  <!-- ══ LEFT COLUMN ══ -->
  <div class="vt-left">

    <!-- PAGE HEADER -->
    <div class="vt-header">
      <div class="vt-header-left">
        <div class="vt-header-icon"><i class="bi bi-check2-square"></i></div>
        <div>
          <div class="vt-header-name">
            <% if((userData.Role=="PMO"||userData.Role=="Manager")&&Task.Status=='WIP'){ %>
              <span class="user-info">
                <%= Task.TaskLabel || Task.TaskName %>
                <span class="toggle-button" style="color:var(--accent);font-size:12px;margin-left:4px;"><i class="bi bi-pencil-square"></i></span>
              </span>
              <input type="text" name="TaskLabel" id="TaskLabel"
                class="select-list hidden" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.3);color:#fff;border-radius:6px;padding:3px 8px;font-size:13px;font-weight:700;"
                data-Target="Task" data-ID="<%= Task.idTask %>"
                value="<%= Task.TaskLabel || '' %>">
              <span class="reset-btn hidden" style="color:var(--accent);"><i class="bi bi-x-square-fill fs-5"></i></span>
            <% } else { %>
              <%= Task.TaskLabel || Task.TaskName %>
            <% } %>
          </div>
          <div class="vt-header-sub">
            <i class="bi bi-folder2-open"></i>
            <a href="/ViewMilestone/<%= Milestone_Info.Customer %>/<%= Milestone_Info.idProjects %>/<%= Milestone_Info.Milestone_Name %>"><%= Milestone_Info.Milestone_Name %></a>
            <span style="color:rgba(255,255,255,0.2)">|</span>
            <i class="bi bi-building"></i> <%= Milestone_Info.Customer %>
          </div>
        </div>
      </div>
      <div class="vt-header-right">
        <span class="vt-status <%= statusCls %>"><%= Task.Status %></span>
        <button type="button" id="markTaskCompleted"
          class="vt-submit-btn <%= Task.Status!='WIP'||Task.Owner!=userData.Employee_ID ? 'hidden' : '' %>">
          Submit <i class="bi bi-arrow-right"></i>
        </button>
      </div>
    </div>

    <!-- INFORMATION SECTION -->
    <div class="vt-section">
      <div class="vt-section-header" onclick="toggleSection(this)">
        <div class="sec-left">
          <i class="bi bi-card-list sec-icon"></i>
          <span class="sec-title">Information</span>
        </div>
        <i class="bi bi-chevron-down sec-toggle"></i>
      </div>
      <div class="vt-section-body">
        <div class="info-grid">

          <!-- Task ID -->
          <div class="info-field">
            <label><i class="bi bi-hash"></i> Task ID</label>
            <div class="info-val"><%= Task.TaskName %></div>
          </div>

          <!-- Job ID -->
          <div class="info-field">
            <label><i class="bi bi-briefcase"></i> <%= x %></label>
            <div class="info-val">
              <a href="/Project/<%= Milestone_Info.Customer %>/<%= Milestone_Info.Project_ID %>/<%= Milestone_Info.idProjects %>">
                <%= Milestone_Info.Project_ID %>
              </a>
            </div>
          </div>

          <!-- Milestone -->
          <div class="info-field">
            <label><i class="bi bi-signpost-split"></i> Milestone</label>
            <div class="info-val">
              <a href="/ViewMilestone/<%= Customer %>/<%= Milestone_Info.idProjects %>/<%= Milestone_Info.Milestone_Name %>">
                <%= Milestone_Info.Milestone_Name %>
              </a>
            </div>
          </div>

          <!-- Task Type -->
          <div class="info-field">
            <label><i class="bi bi-tag"></i> Task Type</label>
            <div class="info-val"><%= Task.Type %></div>
          </div>

          <!-- Owner -->
          <div class="info-field">
            <label><i class="bi bi-person"></i> Owner</label>
            <div class="info-val">
              <div class="edit-wrap">
                <% if((userData.Role=="PMO"||userData.Role=="Manager")&&Task.Status!='Completed'){ %>
                  <select name="" id="TaskOwner" class="select-list hidden" data-OwnerFor="Task" data-ID="<%= Task.TaskName %>">
                    <% for(let i=0;i<Object.values(Owners).length;i++){ %>
                      <option value="<%= Owners[i].Employee_ID %>" <%= Owners[i].Employee_ID==Task.Owner?"selected":"" %>>
                        <%= Owners[i].Full_Name %> (<%= Owners[i].Employee_ID %>)
                      </option>
                    <% } %>
                  </select>
                  <span class="position-absolute reset-btn hidden"><i class="bi bi-x-square-fill fs-5 text-primary opacity-75 m-1"></i></span>
                  <span class="Owner user-info" data-userID="<%= Task.Owner %>"><%= Task.Full_Name %></span>
                  <span class="toggle-button"><i class="bi bi-pencil-square"></i></span>
                <% } else { %>
                  <span class="Owner" data-userID="<%= Task.Owner %>"><%= Task.Full_Name %></span>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Total Time -->
          <div class="info-field">
            <label><i class="bi bi-stopwatch"></i> Total Time</label>
            <div class="info-val">
              <span class="time-badge"><i class="bi bi-clock"></i> <%= secondsToMinutes(Task.TotalTime+subTaskTotalTime) %></span>
            </div>
          </div>

          <!-- Iteration -->
          <div class="info-field">
            <label><i class="bi bi-arrow-repeat"></i> Iteration</label>
            <div class="info-val">
              <input type="text" id="Iteration" name="Iteration" readonly
                style="background:transparent;border:none;font-size:13px;font-weight:800;color:var(--navy-700);padding:0;width:100%;"
                value="<%= Task.Type=='CQC' ? CQCIteration : Task.Type=='USQC' ? USQCIteration : Task.Iteration %>">
            </div>
          </div>

          <!-- QC Score -->
          <div class="info-field">
            <label><i class="bi bi-star"></i> <%= Task.Type=='CQC'||Task.Type=='USQC' ? 'Customer Score' : 'QC Score' %></label>
            <div class="info-val">
              <input type="text" id="Score" readonly
                style="background:transparent;border:none;font-size:13px;font-weight:800;color:var(--navy-700);padding:0;width:100%;"
                value="<%= Task.Score || '0' %>">
            </div>
          </div>

          <!-- Due Date -->
          <div class="info-field">
            <label><i class="bi bi-calendar-event"></i> Due Date</label>
            <div class="info-val">
              <div class="edit-wrap">
                <% if((userData.Role=="PMO"||userData.Role=="Manager")&&Task.Status!='Completed'){ %>
                  <span class="user-info"><%= Task.DueDate || "—" %></span>
                  <span class="toggle-button"><i class="bi bi-pencil-square"></i></span>
                  <input type="date" name="DueDate" id="DueDate"
                    class="select-list hidden today-date"
                    data-Target="Task" data-ID="<%= Task.idTask %>"
                    value="<%= Task.n_DueDate ? formatDateString(Task.n_DueDate) : null %>">
                  <span class="position-absolute reset-btn hidden"><i class="bi bi-x-square-fill fs-5 text-primary opacity-75 m-1"></i></span>
                <% } else { %>
                  <span><%= Task.DueDate || "—" %></span>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Start Date -->
          <div class="info-field">
            <label><i class="bi bi-play-circle"></i> Start Date</label>
            <div class="info-val"><%= Task.StartDate || "—" %></div>
          </div>

          <!-- End Date -->
          <div class="info-field">
            <label><i class="bi bi-stop-circle"></i> End Date</label>
            <div class="info-val"><%= Task.EndDate || "—" %></div>
          </div>

          <!-- Production Task (IQC/RQC only) -->
          <% if((Task.Type=='IQC'||Task.Type=='RQC')&&Task.Prod_Task){ %>
          <div class="info-field">
            <label><i class="bi bi-gear"></i> Production Task</label>
            <div class="info-val">
              <a href="/ViewTask/<%= Customer %>/<%= Milestone_Info.Milestone_Name %>/<%= Task.Prod_Task %>">
                <%= Task.Prod_Task %>
              </a>
            </div>
          </div>
          <% } %>

          <!-- Remark -->
          <div class="info-field" style="grid-column: span 2;">
            <label><i class="bi bi-chat-left-text"></i> Manager Remark</label>
            <div class="info-val" style="font-weight:600;color:var(--muted);font-size:12px;">
              <%= Task.Remark || "N/A" %>
            </div>
          </div>

          <!-- QC Checklist -->
          <% if(Task.QC_Name){ %>
          <div class="info-field" style="grid-column: span 2;">
            <label>
              <i class="bi bi-clipboard-check"></i> QC Checklist
              <a href="" title="Download Filled Checklist" id="Checklist_Url" class="ms-1" style="color:var(--blue-500);font-size:10px;">
                <i class="bi bi-arrow-down-circle"></i>
              </a>
            </label>
            <div class="info-val">
              <div class="edit-wrap">
                <% let restrictedStatus=['Ready for QC','IQC-YTS','IQC-WIP','Completed']; %>
                <% if((userData.Role=="PMO"||userData.Role=="Manager")&&!restrictedStatus.includes(Task.Status)){ %>
                  <select name="QC_Name" id="QC_Name" data-Target="Task" data-ID="<%= Task.idTask %>" class="select-list hidden" required>
                    <option value="">Select QC-Checklist</option>
                    <% for(let i=0;i<Object.keys(QC_List).length;i++){ %>
                      <option value="<%= QC_List[i].Checklist_Name %>" <%= Task.QC_Name==QC_List[i].Checklist_Name?"selected":"" %>>
                        <%= QC_List[i].Checklist_Name %>
                      </option>
                    <% } %>
                  </select>
                  <span class="position-absolute reset-btn hidden"><i class="bi bi-x-square-fill fs-5 text-primary opacity-75 m-1"></i></span>
                  <a id="QC_Link" href="https://172.17.1.22:5000/Engineer/QC/<%= Task.QC_Name %>" target="_blank"
                    class="user-info <%= Task.Owner!=userData.Employee_ID||Task.Status=='Completed'||Task.Status=='YTS' ? 'disabled' : '' %>"
                    style="font-weight:700;">
                    <%= Task.QC_Name %>
                  </a>
                  <span class="toggle-button"><i class="bi bi-pencil-square"></i></span>
                <% } else { %>
                  <a id="QC_Link" href="https://172.17.1.22:5000/Engineer/QC/<%= Task.QC_Name %>" target="_blank"
                    class="<%= Task.Owner!=userData.Employee_ID||Task.Status=='Completed'||Task.Status=='YTS' ? 'disabled' : '' %>"
                    style="font-weight:700;">
                    <%= Task.QC_Name %>
                  </a>
                <% } %>
              </div>
            </div>
          </div>
          <% } %>

        </div>
      </div>
    </div>

    <!-- SUBTASK SECTION -->
    <div class="vt-section">
      <div class="vt-section-header" onclick="toggleSection(this)">
        <div class="sec-left">
          <i class="bi bi-diagram-3 sec-icon"></i>
          <span class="sec-title">Subtask</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <% if(Task.Status=="WIP"&&Task.Owner==userData.Employee_ID){ %>
            <span class="vt-add-btn" data-bs-toggle="modal" data-bs-target="#create-Subtask-Task-Modal" onclick="event.stopPropagation()">
              <i class="bi bi-plus-lg"></i> Add
            </span>
          <% } %>
          <i class="bi bi-chevron-down sec-toggle"></i>
        </div>
      </div>
      <div class="vt-section-body p-0">
        <%
          function subtaskTable(rows) {
            if (!rows || rows.length === 0) return;
          }
          let ProdSubtasks = Object.values(subTask).filter(r => r.Type=="Production");
          let QCSubtasks   = Object.values(subTask).filter(r => r.Type!="Production");
        %>
        <% if(Task.Type=="Production" && (ProdSubtasks.length||QCSubtasks.length)){ %>
          <div style="display:flex;gap:0;border-bottom:1px solid var(--border);background:#f4f8ff;padding:6px 12px;">
            <% if(ProdSubtasks.length){ %>
              <button class="vt-add-btn me-2 active-tab-btn" onclick="switchSubTab('prod',this)">Production</button>
            <% } %>
            <% if(QCSubtasks.length){ %>
              <button class="vt-add-btn" onclick="switchSubTab('qc',this)">QC</button>
            <% } %>
          </div>
          <div id="sub-prod" class="vt-table-wrap">
  <% if(ProdSubtasks.length > 0){ %>
    <table class="vt-table">
      <thead><tr>
        <th>S.No</th><th>Subtask ID</th><th>Subtask Name</th>
        <th>Task</th><th>Owner</th><th>Due</th><th>Start</th><th>End</th>
        <th>Status</th>
      </tr></thead>
      <tbody>
        <% ProdSubtasks.forEach(function(s, idx){ %>
        <tr>
          <td style="color:var(--muted);font-weight:700;font-size:10px;"><%= idx+1 %></td>
          <td><a href="/SubTask/<%= s.SubTaskName %>"><%= s.SubTaskName %></a></td>
          <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= s.SubTaskLabel %>"><%= s.SubTaskLabel||"—" %></td>
          <td><%= s.Task_Name %></td>
          <td><p class="Owner m-0 text-truncate" style="max-width:90px;" data-userID="<%= s.Owner %>"><%= s.Full_Name %></p></td>
          <td><%= s.DueDate||"—" %></td>
          <td><%= s.StartDate||"—" %></td>
          <td><%= s.EndDate||"—" %></td>
          <td><%- stBadge(s.Status) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <div class="vt-empty"><i class="bi bi-diagram-3"></i><p>No production subtasks</p></div>
  <% } %>
</div>
<div id="sub-qc" class="vt-table-wrap" style="display:none;">
  <% if(QCSubtasks.length > 0){ %>
    <table class="vt-table">
      <thead><tr>
        <th>S.No</th><th>Subtask ID</th><th>Subtask Name</th>
        <th>Task</th><th>Owner</th><th>Due</th><th>Start</th><th>End</th>
        <th>Status</th>
      </tr></thead>
      <tbody>
        <% QCSubtasks.forEach(function(s, idx){ %>
        <tr>
          <td style="color:var(--muted);font-weight:700;font-size:10px;"><%= idx+1 %></td>
          <td><a href="/SubTask/<%= s.SubTaskName %>"><%= s.SubTaskName %></a></td>
          <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= s.SubTaskLabel %>"><%= s.SubTaskLabel||"—" %></td>
          <td><%= s.Task_Name %></td>
          <td><p class="Owner m-0 text-truncate" style="max-width:90px;" data-userID="<%= s.Owner %>"><%= s.Full_Name %></p></td>
          <td><%= s.DueDate||"—" %></td>
          <td><%= s.StartDate||"—" %></td>
          <td><%= s.EndDate||"—" %></td>
          <td><%- stBadge(s.Status) %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <div class="vt-empty"><i class="bi bi-diagram-3"></i><p>No QC subtasks</p></div>
  <% } %>
</div>
        <% } else { %>
          <div class="vt-table-wrap">
            <%
              let allSubs = Object.values(subTask);
            %>
            <% if(allSubs.length > 0) { %>
              <table class="vt-table">
                <thead><tr>
                  <th>S.No</th><th>Subtask ID</th><th>Subtask Name</th>
                  <th>Task</th><th>Owner</th><th>Due</th><th>Start</th><th>End</th>
                  <th>Status</th><th>Delivery</th>
                </tr></thead>
                <tbody>
                  <% allSubs.forEach(function(s, idx) {
                    let dd=s.f_DueDate, ed=s.f_EndDate||"";
                    let ds=compareDates(dd,ed,s.Status);
                  %>
                  <tr>
                    <td style="color:var(--muted);font-weight:700;font-size:10px;"><%= idx+1 %></td>
                    <td><a href="/SubTask/<%= s.SubTaskName %>"><%= s.SubTaskName %></a></td>
                    <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= s.SubTaskLabel %>"><%= s.SubTaskLabel||"—" %></td>
                    <td><%= s.Task_Name %></td>
                    <td><p class="Owner m-0 text-truncate" style="max-width:90px;" data-userID="<%= s.Owner %>"><%= s.Full_Name %></p></td>
                    <td><%= s.DueDate||"—" %></td>
                    <td><%= s.StartDate||"—" %></td>
                    <td><%= s.EndDate||"—" %></td>
                    <td><%- stBadge(s.Status) %></td>
                    <td><%- dsBadge(ds) %></td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %>
              <div class="vt-empty"><i class="bi bi-diagram-3"></i><p>No subtasks</p></div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- MARKUP SECTION (hidden for Production/CQC/USQC) -->
    <% if(Task.Type!='Production'&&Task.Type!='CQC'&&Task.Type!='USQC'){ %>
    <div class="vt-section">
      <div class="vt-section-header" onclick="toggleSection(this)">
        <div class="sec-left">
          <i class="bi bi-pencil sec-icon"></i>
          <span class="sec-title">Markups</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <% if(Task.Status=="WIP"&&Task.Owner==userData.Employee_ID){ %>
            <span class="vt-add-btn" data-bs-toggle="modal" data-bs-target="#create-Markup-Task-Modal" onclick="event.stopPropagation()">
              <i class="bi bi-plus-lg"></i> Add
            </span>
          <% } %>
          <i class="bi bi-chevron-down sec-toggle"></i>
        </div>
      </div>
      <div class="vt-section-body p-0">
        <div class="vt-table-wrap">
          <% if(Object.values(markup).length > 0) { %>
            <table class="vt-table">
              <thead><tr>
                <th>S.No</th><th>Markup</th><th>Task</th><th>Owner</th>
                <th>Start</th><th>End</th><th>Due</th><th>Status</th><th>Delivery</th>
              </tr></thead>
              <tbody>
                <% Object.values(markup).forEach(function(m,i){ let dd=m.f_DueDate,ed=m.f_EndDate||"",ds=compareDates(dd,ed,m.Status); %>
                <tr>
                  <td style="color:var(--muted);font-weight:700;font-size:10px;"><%= i+1 %></td>
                  <td><a href="/Markup/<%= m.Sub_Task_Name %>"><%= m.Sub_Task_Name %></a></td>
                  <td><%= m.Task_Name %></td>
                  <td><p class="Owner m-0 text-truncate" style="max-width:90px;" data-userID="<%= m.Owner %>"><%= m.Full_Name %></p></td>
                  <td><%= m.StartDate||"—" %></td>
                  <td><%= m.EndDate||"—" %></td>
                  <td><%= m.DueDate||"—" %></td>
                  <td><%- stBadge(m.Status) %></td>
                  <td><%- dsBadge(ds) %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="vt-empty"><i class="bi bi-pencil"></i><p>No markups</p></div>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- ATTACHMENTS SECTION -->
    <div class="vt-section">
      <div class="vt-section-header" onclick="toggleSection(this)">
        <div class="sec-left">
          <i class="bi bi-paperclip sec-icon"></i>
          <span class="sec-title">Attachments</span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <% if(Task.Status!="YTS"&&Task.Owner==userData.Employee_ID){ %>
            <span class="vt-add-btn" data-bs-toggle="modal" data-bs-target="#AttachmentDialog" onclick="event.stopPropagation()">
              <i class="bi bi-plus-lg"></i> Add
            </span>
          <% } %>
          <p class="m-0 p-0 btn visually-hidden" id="zipDownload" data-FileName="<%= Task.TaskName %>">
            <i class="bi bi-cloud-arrow-down-fill" style="color:var(--blue-500);font-size:14px;"></i>
          </p>
          <i class="bi bi-chevron-down sec-toggle"></i>
        </div>
      </div>
      <div class="vt-section-body p-0">
        <% if(Object.values(attachments).length > 0) { %>
          <div class="vt-table-wrap">
            <table class="vt-table" id="AttachmentsTable">
              <thead><tr>
                <th><div class="d-flex align-items-center gap-1">
                  <input type="checkbox" id="selectAll" class="form-check-input m-0"> S.No
                </div></th>
                <th>File Name</th><th>Date</th><th>Size</th><th>Type</th><th>Owner</th><th></th>
              </tr></thead>
              <tbody>
                <% Object.values(attachments).forEach(function(a,i){ %>
                <tr>
                  <td><div class="form-check"><input type="checkbox" class="record-checkbox form-check-input" value="<%= a.idattachments %>" id="ATT-<%= a.idattachments %>"><label for="ATT-<%= a.idattachments %>"><%= i+1 %></label></div></td>
                  <td><a href="../../..<%= a.path %>" target="_blank"><p class="m-0" title="<%= a.Name %>" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= a.Name.substring(0,60) %></p></a></td>
                  <td style="white-space:nowrap;"><%= a.Created_Date %></td>
                  <td><%= a.Size %>MB</td>
                  <td><img width="20" height="20" src="/static/icons/<%= a.Type.substring(1) %>.png" alt="<%= a.Type %>"/></td>
                  <td style="white-space:nowrap;"><%= a.Full_Name %></td>
                  <td><i class="bi bi-trash3-fill text-secondary archive-btn fs-6 <%= a.Owner!=userData.Employee_ID?'visually-hidden':'' %>" data-fileID="<%= a.idattachments %>" style="cursor:pointer;"></i></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <%
            let noteFound = false;
            let relevantNote = '';
          %>
          <% Object.keys(Comments).forEach(function(gk) { %>
            <% for(const k in Comments[gk]) { %>
              <% if(k.startsWith('Note') && Comments[gk][k].startsWith("Reason For No Attachment")) { %>
                <div style="padding:12px;display:flex;align-items:center;gap:12px;">
                  <div style="flex:1;padding:8px 12px;border-radius:8px;background:rgba(45,125,210,0.06);border:1px solid rgba(45,125,210,0.15);font-size:12px;color:var(--muted);">
                    <%= Comments[gk][k] %>
                  </div>
                  <img src="../../../static/images/empty-animate.svg" width="100" height="100" alt="">
                </div>
                <% noteFound = true; %>
              <% } %>
            <% } %>
          <% }); %>
          <% if(!noteFound) { %>
            <div class="vt-empty">
              <img src="../../../static/images/empty-animate.svg" width="100" height="100" alt="" style="margin:0 auto 8px;display:block;">
              <p>No attachments</p>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>

  </div><!-- end vt-left -->

  <!-- ══ RIGHT COLUMN ══ -->
  <div class="vt-right">

    <!-- TIMER CARD -->
    <div class="vt-timer-card">
      <% if(!completedStatus.includes(Task.Status) && Task.Owner==userData.Employee_ID){ %>
        <div class="vt-timer-display">
          <span class="display" id="display">00:00:00:00</span>
          <div class="vt-timer-btns">
            <button id="startBtn" class="<%= lock ? 'd-none' : '' %>"
              <%= (Task.Type=='IQC'||Task.Type=='RQC')&&!ProductionStatus ? 'disabled' : '' %>>
              <i class="bi bi-play-fill"></i>
            </button>
            <button id="stopBtn" class="<%= !lock ? 'd-none' : '' %>"
              <%= (Task.Type=='IQC'||Task.Type=='RQC')&&!ProductionStatus ? 'disabled' : '' %>>
              <i class="bi bi-stop-fill"></i>
            </button>
          </div>
          <% if((Task.Type=='IQC'||Task.Type=='RQC')&&!ProductionStatus){ %>
            <div class="prod-notice">Production is still ongoing — QC cannot start yet.</div>
          <% } %>
        </div>
      <% } %>

      <!-- Timesheet -->
      <div class="vt-panel-header">
        <i class="bi bi-clock-history"></i>
        <span>Time Sheet</span>
      </div>
      <div style="overflow-x:auto; max-height:220px; overflow-y:auto;">
        <% if(Object.values(Log).length > 0) { %>
          <table class="ts-table">
            <thead><tr><th>S.No</th><th>User</th><th>Start</th><th>End</th><th>Duration</th></tr></thead>
            <tbody>
              <% Object.values(Log).forEach(function(l,i){ %>
              <tr>
                <td><%= i+1 %></td>
                <td><p class="Owner text-truncate m-0" style="max-width:80px;" data-userID="<%= l.UserID %>"><%= l.Full_Name %></p></td>
                <td style="white-space:nowrap;font-size:10px;"><%= l.startTime %></td>
                <td style="white-space:nowrap;font-size:10px;"><%= l.endTime %></td>
                <td style="white-space:nowrap;"><%= secondsToMinutes(l.duration) %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <div style="text-align:center;padding:16px;">
            <img src="/static/images/Data report-amico.svg" width="120" height="120" alt="">
            <p style="font-size:11px;color:var(--muted);margin:0;">No time logs yet</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- COMMENTS CARD -->
    <div class="vt-timer-card">
      <div class="vt-panel-header">
        <i class="bi bi-chat-dots"></i>
        <span>Comments</span>
        <span class="panel-action" data-bs-toggle="modal" data-bs-target="#Add_Comment_Modal">
          <i class="bi bi-plus-circle"></i>
        </span>
      </div>
      <%
        let relevantComments = Object.keys(Comments).filter(function(gk){
          return Object.keys(Comments[gk]).some(function(k){
            return k.startsWith('Note') && !Comments[gk][k].startsWith("Reason For No Attachments");
          });
        });
      %>
      <% if(relevantComments.length > 0) { %>
        <% relevantComments.forEach(function(gk){ %>
          <% let c = Comments[gk]; let isOwner = userData.Employee_ID===c.Author_ID; %>
          <div class="comment-block">
            <div class="comment-meta">
              <i class="bi bi-person-fill"></i> <%= c.Author_Name %>
              <span style="color:var(--border)">|</span>
              <i class="bi bi-calendar3"></i> <%= c.On %>
              <% for(const k in c){ if(k.startsWith('attachment')&&c[k]){ %>
                <a href="../public/uploads/ReferenceDoc/<%= c[k] %>" class="text-decoration-none" download title="Attachment">
                  <i class="bi bi-paperclip" style="color:var(--blue-500);"></i>
                </a>
              <% }} %>
              <% if(isOwner){ %>
                <i class="bi bi-trash3-fill comment-del deleteBtn" style="margin-left:auto;"
                  data-project-id="<%= Task.TaskName %>" data-target="Task"
                  data-comment-id="<%= gk %>" data-customer="<%= Customer %>"></i>
              <% } %>
            </div>
            <% for(const k in c){ if(k.startsWith('Note')&&!c[k].startsWith("Reason For No Attachments")){ %>
              <div class="comment-text <%= isOwner ? 'is-owner' : '' %>"><%- c[k] %></div>
            <% }} %>
          </div>
        <% }); %>
      <% } else { %>
        <div style="text-align:center;padding:12px;">
          <img src="../../../static/images/co-workers-animate.svg" width="140" height="140" alt="" style="display:block;margin:0 auto;">
          <p style="font-size:11px;color:var(--muted);margin:0;">No comments yet</p>
        </div>
      <% } %>
    </div>

  </div><!-- end vt-right -->

</main>
</body>

