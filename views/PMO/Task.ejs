<% if(lock==true){ %>
<script>
  elapsedTime = Date.now() - new Date('<%= Log[Object.values(Log).length-1].startTime %>');
  start();
</script>
<% } %>

<script>
/* ── Section toggle ── */
function toggleSection(header) {
  var body = header.nextElementSibling;
  header.querySelector('.sec-toggle').style.transform =
    body.style.display === 'none' ? '' : 'rotate(-90deg)';
  body.style.display = body.style.display === 'none' ? '' : 'none';
}

/* ── Sub-tab switching (Production/QC subtasks) ── */
function switchSubTab(name, btn) {
  document.querySelectorAll('.active-tab-btn').forEach(function(b){ b.classList.remove('active-tab-btn'); });
  btn.classList.add('active-tab-btn');
  var prod = document.getElementById('sub-prod');
  var qc   = document.getElementById('sub-qc');
  if(prod) prod.style.display = name==='prod' ? '' : 'none';
  if(qc)   qc.style.display   = name==='qc'  ? '' : 'none';
}

/* ── QC checklist link ── */
var Checklist_Url = document.getElementById('Checklist_Url');
var QC_Link       = document.getElementById('QC_Link');

$(".QC_Due_Date_Container").hide();
$('input[type="radio"][name="autoQC"]').on('click', function() {
  if ($(this).val() === '1') {
    $('.QC_Due_Date_Container').show();
    $('#Sub_QC_Due_Date').attr('required', true);
  } else {
    $('.QC_Due_Date_Container').hide();
    $('#Sub_QC_Due_Date').attr('required', false);
  }
});

if(elapsedTime == 0) {
  Checklist_Url ? document.getElementById('Checklist_Url').classList.add("visually-hidden") : null;
  QC_Link ? document.getElementById('QC_Link').setAttribute("disabled","") : null;
}

/* ── Timer stop ── */
document.getElementById("stopBtn").addEventListener('click', function(e) {
  $("#stopBtn").prop("disabled", true);
  stop(e.target);
  axios.post('/api/updateTimeLog/<%= Task.TaskName %>/stop').then(function(res){
    window.location.reload();
  }).catch(function(e){
    if(e.response.data=="Access Denied") alert("Session closed. Login again.");
    else { alert("Unable to stop timer."); window.location.reload(); }
  });
});

/* ── Timer start ── */
document.getElementById("startBtn").addEventListener('click', async function(e) {
  $("#startBtn").prop("disabled", true);
  try {
    await axios.post('/api/updateTimeLog/<%= Task.TaskName %>/start');
    start(e.target);
    window.location.reload();
  } catch(err) {
    let pending = err.response.data.OngoingTaskInfo;
    if(pending) {
      let URL = pending.TaskName.startsWith("SUB") ? `/SubTask/${pending.TaskName}` :
                pending.TaskName.startsWith("MKUP") ? `/Markup/${pending.TaskName}` :
                `/ViewTask/${pending.Customer}/${pending.Milestone_Name}/${pending.TaskName}`;
      document.getElementById("TaskURL").setAttribute("href", URL);
      document.getElementById("taskID").innerHTML = pending.TaskLabel || pending.TaskName;
      new bootstrap.Modal(document.getElementById("staticBackdrop"),{keyboard:false}).show();
    } else if(err.response.data=="Access Denied") {
      alert("Session closed. Login again.");
    } else {
      alert("Unable to start timer."); window.location.reload();
    }
  }
});

/* ── Tech info (unchanged) ── */
const ProjectStatus = '<%= Task.Status %>';
const techInfo = document.querySelectorAll('input[type=number].techInfo');
techInfo.forEach(function(input) {
  input.addEventListener('change', saveTechInfo);
  if(ProjectStatus==='WIP'&&input.getAttribute("name")!="Total"&&input.getAttribute("name")!="Total_Fib_Act"){
    input.removeAttribute('readonly');
  } else { input.setAttribute('readonly',''); }
});
function saveTechInfo() {
  document.getElementById("autosaveStatus") && (document.getElementById("autosaveStatus").innerHTML='<i class="bi bi-arrow-repeat"></i>');
  let values = {};
  techInfo.forEach(function(i){ values[i.name]=i.value?parseInt(i.value):0; });
  axios.post("/api/updateTechInfo/<%= Task.TaskName %>",{values}).then(function(res){
    document.getElementById("autosaveStatus") && (document.getElementById("autosaveStatus").innerHTML='<i class="bi bi-cloud-check"></i>');
    toasts.push(res.data.Notification);
  }).catch(function(error){
    toasts.push(error.response.data.Notification);
    document.getElementById("autosaveStatus") && (document.getElementById("autosaveStatus").innerHTML='<span class="text-danger">Error</span>');
  });
}

/* ── Submit task ── */
let AttachmentLength = parseInt('<%= Object.values(attachments).length %>');
document.getElementById("markTaskCompleted").addEventListener("click", async function(e) {
  const myModal = new bootstrap.Modal('#SubmissionBackdrop',{keyboard:false});
  const Iteration = parseInt($("#Iteration").val());
  const Score     = parseInt($("#Score").val());
  let temp = false, attachConfirm = false, reason = "";

  if(elapsedTime==0) {
    document.getElementById("timerStatus").innerHTML='<i class="bi bi-check-circle-fill text-success me-1"></i> Yes';
  }
  let SubtaskResult = await axios.get("/api/checkSubtaskClosed/<%= Task.TaskName %>");
  let MarkupResult  = await axios.get("/api/checkMarkupClosed/<%= Task.TaskName %>");
  if(SubtaskResult.data.status=="All Clear"&&MarkupResult.data.status=="All Clear"){
    document.getElementById("subTaskStatus").innerHTML='<i class="bi bi-check-circle-fill text-success me-1"></i> Yes';
  }
  if((Iteration&&Score)||'<%= Task.QC_Name %>'=="") {
    document.getElementById("checklistStatus").innerHTML='<i class="bi bi-check-circle-fill text-success me-1"></i> Yes';
  }
  if(AttachmentLength!=0) {
    document.getElementById("attachmentStatus").innerHTML='<i class="bi bi-check-circle-fill text-success me-1"></i> Yes';
    temp=true; myModal.show();
  } else {
    attachConfirm=confirm("Proceed without attachment? OK to continue, Cancel to add one.");
    if(attachConfirm) {
      reason=prompt("Reason for no attachments (Min 5 chars):");
      if(!reason||reason.trim().length<6) { alert("Submission cancelled."); }
      else { temp=true; myModal.show(); }
    } else {
      new bootstrap.Modal('#AttachmentDialog',{keyboard:false}).show();
    }
  }

  if(temp&&elapsedTime==0&&SubtaskResult.data.status=="All Clear"&&((Iteration&&Score)||'<%= Task.QC_Name %>'=="")) {
    e.target.setAttribute("disabled","");
    e.target.innerHTML='<span class="spinner-grow spinner-grow-sm" aria-hidden="true"></span> Submitting...';
    document.getElementById("ClosureSubmitBtn").innerHTML='<span class="spinner-grow spinner-grow-sm" aria-hidden="true"></span> Submitting...';
    axios.post('/api/MarkTaskCompleted/<%= Task.TaskName %>/Task',{Iteration,Score,NoAttachmentReason:reason}).then(function(res){
      toasts.push(res.data.Notification);
      if(res.status==200&&reason?.trim()){
        axios.post("/api/AddCommentTo/Task/<%= Task.TaskName %>",{Comment:"Reason For No Attachments: "+reason}).then(function(){location.reload();});
      } else { location.reload(); }
    }).catch(function(error){
      e.target.innerHTML='Error <i class="bi bi-x-circle m-1"></i>';
      toasts.push(error.response.data.Notification);
      location.reload();
    });
  }
});

/* ── QC Link ── */
if(document.querySelector("#QC_Link")) {
  let temp2 = document.querySelector("#QC_Link").href;
  document.querySelector("#QC_Link").href = temp2 +
    `?Token=${btoa('<%= userData.Employee_ID %>')}&cfas_no=${btoa('<%= Milestone_Info.Project_ID %>')}&qc_state=${btoa('<%= Milestone_Info.Region %>')}&qc_city=${btoa('<%= Milestone_Info.Region %>')}&qc_type=${btoa('<%= Task.Type==="Production"?"Self QC":Task.Type %>')}&Task_ID=${btoa('<%= Task.TaskName %>')}`;
}

/* ── Checklist fetch ── */
try {
  axios.get('https://172.17.1.22:5000/api/QGPMS/Checklist/<%-Task.Project_ID%>/<%-Task.QC_Name%>/<%- Task.Type==="Production"?"Self QC":Task.Type %>/<%-Task.TaskName%>',{
    crossdomain:true, headers:{"Cache-Control":"no-cache","Content-Type":"application/x-www-form-urlencoded","Access-Control-Allow-Origin":"*"}
  }).then(function(res){
    let data=res.data;
    if(data.Score=="NaN") data.Score=0;
    if(data.Iteration>0&&data.url){
      document.getElementById('Checklist_Url').href=data.url;
      document.getElementById("Iteration").value=data.Iteration;
      document.getElementById("Score").value=data.Score?data.Score:"0"+"%";
    } else { Checklist_Url?document.getElementById('Checklist_Url').classList.add("visually-hidden"):null; }
  }).catch(function(){ Checklist_Url?document.getElementById('Checklist_Url').classList.add("visually-hidden"):null; })
  .finally(function(){
    const score=parseInt(document.getElementById("Score").value);
    $("[data-bs-target='#create-Markup-Task-Modal']").attr("disabled",(score>99||score<1));
  });
} catch(error){ console.log(error); }

/* ── Comment delete ── */
document.querySelectorAll('.deleteBtn').forEach(function(btn){
  btn.addEventListener("click", function(e){
    e.target.setAttribute('disabled','');
    axios.delete('/api/deleteComment',{data:{
      Customer:e.target.getAttribute('data-Customer'),
      commentID:e.target.getAttribute('data-comment-id'),
      projectID:e.target.getAttribute('data-project-id'),
      Target:e.target.getAttribute("data-target")
    }}).then(function(){ window.location.reload(); })
    .catch(function(){ e.target.removeAttribute('disabled'); });
  });
});

/* ── ATX/AT&T totals ── */
$("#Arial").change(function(){ $("#Total").val(parseInt($("#Arial").val())+parseInt($("#Buried").val())); });
$("#Buried").change(function(){ $("#Total").val(parseInt($("#Arial").val())+parseInt($("#Buried").val())); });
$("#UG_Fib_Act").change(function(){ $("#Total_Fib_Act").val(parseInt($("#UG_Fib_Act").val())+parseInt($("#Air_Fib_Act").val())); });
$("#Air_Fib_Act").change(function(){ $("#Total_Fib_Act").val(parseInt($("#UG_Fib_Act").val())+parseInt($("#Air_Fib_Act").val())); });

/* ── Date validation ── */
$("#Sub_QC_Due_Date").change(function(){
  if($("#Sub_Due_Date").val()&&$(this).val()<=$("#Sub_Due_Date").val()){
    alert("QC Due Date cannot be less than production deadline.");
    $(this).val(""); $("#Sub_Due_Date").val("");
  }
});
$("#Sub_Due_Date").change(function(){
  if($("#Sub_QC_Due_Date").val()&&$(this).val()<=$("#Sub_QC_Due_Date").val()){
    alert("QC Due Date cannot be less than production deadline.");
    $(this).val(""); $("#Sub_QC_Due_Date").val("");
  }
});
</script>
