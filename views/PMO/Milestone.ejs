<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Milestone</title>
  <%- include('../partials/dependencies') %>
</head>

<% if (userData.Role=="Employee") { %>
  <%- include('../partials/Employee-header',{userData:userData}) %>
<% } else if(userData.Role=="Admin") { %>
  <%- include('../partials/Admin-header',{userData:userData}) %>
<% } else if(userData.Role=="PMO") { %>
  <%- include('../partials/PMO-header',{userData:userData}) %>
<% } if(userData.Role=="Manager") { %>
  <%- include('../partials/Manager-header',{userData:userData}) %>
<% } %>

<style>
  /* ══════════════════════════════════════
     DESIGN SYSTEM — matches PMO palette
  ══════════════════════════════════════ */
  :root {
    --navy-900: #0f1e36;
    --navy-800: #152844;
    --navy-700: #1b3258;
    --blue-500: #2d7dd2;
    --blue-400: #4a96e8;
    --accent:   #00c6ff;
    --page-bg:  #f0f4fa;
    --card-bg:  #ffffff;
    --border:   #e2e8f4;
    --text:     #1e2d45;
    --muted:    #7a8aaa;
    --radius:   10px;
    --shadow:   0 1px 4px rgba(15,30,80,0.06), 0 4px 16px rgba(15,30,80,0.07);
    --tr:       all 0.18s cubic-bezier(0.4,0,0.2,1);
  }

  html, body { background: var(--page-bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; }
  main { padding: 12px 18px 40px; min-height: calc(100vh - 52px); }

  /* ══════════════════════════════════════
     PAGE HEADER BAR — vibrant gradient
  ══════════════════════════════════════ */
  .vm-header {
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-800) 55%, var(--navy-700) 100%);
    border: none;
    border-radius: var(--radius); padding: 12px 18px;
    margin-bottom: 12px;
    box-shadow: 0 4px 18px rgba(15,30,80,0.18), 0 1px 0 rgba(255,255,255,0.04) inset;
    position: relative; overflow: hidden;
  }
  .vm-header::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--blue-500), var(--accent), transparent);
    opacity: 0.7;
  }
  .vm-header-left { display: flex; align-items: center; gap: 12px; }
  .vm-header-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: rgba(45,125,210,0.25);
    border: 1px solid rgba(45,125,210,0.3);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .vm-header-icon i { font-size: 18px; color: var(--accent); }
  .vm-header-name {
    font-size: 15px; font-weight: 800; color: #fff;
    letter-spacing: 0.2px;
  }
  .vm-header-project {
    font-size: 11.5px; color: rgba(255,255,255,0.55); font-weight: 500;
    display: flex; align-items: center; gap: 5px; margin-top: 2px;
  }
  .vm-header-project a {
    color: var(--accent); font-weight: 700; text-decoration: none;
  }
  .vm-header-project a:hover { text-decoration: underline; }
  .vm-status-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 14px; border-radius: 20px;
    font-size: 11.5px; font-weight: 700;
    background: rgba(45,125,210,0.22);
    color: #90c8ff;
    border: 1px solid rgba(45,125,210,0.35);
  }
  .vm-status-pill::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); display: block;
    box-shadow: 0 0 6px var(--accent);
  }

  /* ══════════════════════════════════════
     CONTROL TABS — same pill style, stronger
  ══════════════════════════════════════ */
  .vm-tabs-wrap {
    display: flex; justify-content: center;
    margin-bottom: 14px;
  }
  .vm-tabs {
    display: inline-flex; align-items: center;
    background: var(--card-bg);
    border: 1px solid #d0e4ff;
    border-radius: 14px; padding: 4px; gap: 3px;
    box-shadow: 0 2px 12px rgba(45,125,210,0.1), 0 1px 3px rgba(45,125,210,0.06);
  }
  .vm-tab {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 18px; border-radius: 10px;
    font-size: 12px; font-weight: 700; cursor: pointer;
    border: none; background: transparent; color: var(--muted);
    transition: var(--tr); white-space: nowrap; letter-spacing: 0.1px;
  }
  .vm-tab i { font-size: 12px; }
  .vm-tab:hover {
    background: linear-gradient(135deg, #eef5ff, #e4effe);
    color: var(--blue-500);
    box-shadow: 0 1px 6px rgba(45,125,210,0.12);
  }
  .vm-tab.active {
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    color: #fff;
    box-shadow: 0 3px 12px rgba(45,125,210,0.35);
  }

  /* ══════════════════════════════════════
     INFO GRID — vibrant, gradient, bold keys
  ══════════════════════════════════════ */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }
  .info-field {
    display: flex; flex-direction: column; gap: 4px;
    border-radius: 10px; padding: 11px 14px;
    position: relative; overflow: hidden;
    transition: var(--tr);
    background: linear-gradient(135deg, #ffffff 0%, #f5f9ff 100%);
    border: 1px solid #dce8ff;
    box-shadow: 0 1px 4px rgba(45,125,210,0.07);
  }
  /* Left accent bar */
  .info-field::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--blue-400), var(--blue-500));
    border-radius: 10px 0 0 10px;
  }
  .info-field:hover {
    border-color: rgba(45,125,210,0.4);
    box-shadow: 0 3px 14px rgba(45,125,210,0.14);
    transform: translateY(-1px);
    background: linear-gradient(135deg, #f0f7ff 0%, #e8f2ff 100%);
  }
  /* Key label — bold, uppercase, blue-tinted */
  .info-field label {
    font-size: 9px; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.9px;
    color: var(--blue-500);
    display: flex; align-items: center; gap: 5px; margin: 0;
    opacity: 0.85;
  }
  .info-field label i { font-size: 10px; }
  /* Value — large, bold, dark */
  .info-field .info-val {
    font-size: 13.5px; font-weight: 800; color: var(--navy-700);
    display: flex; align-items: center; gap: 6px;
    min-height: 22px;
    letter-spacing: -0.1px;
  }
  .info-field .info-val a {
    color: var(--blue-500); text-decoration: none; font-weight: 800;
  }
  .info-field .info-val a:hover { text-decoration: underline; }
  .info-field .info-val .edit-wrap {
    display: flex; align-items: center; gap: 6px; width: 100%;
  }
  /* Editable inputs — compact */
  .info-field select.select-list,
  .info-field input.select-list {
    font-size: 12.5px; font-weight: 700; color: var(--text);
    border: 1px solid #c8daff; border-radius: 7px;
    padding: 4px 9px; background: #f0f6ff;
    flex: 1; min-width: 0; transition: var(--tr);
  }
  .info-field select.select-list:focus,
  .info-field input.select-list:focus {
    border-color: var(--blue-500); outline: none;
    box-shadow: 0 0 0 3px rgba(45,125,210,0.18);
    background: #fff;
  }
  .info-field .toggle-button {
    color: var(--blue-500); cursor: pointer; font-size: 12px;
    opacity: 0.55; transition: opacity 0.15s; flex-shrink: 0;
  }
  .info-field .toggle-button:hover { opacity: 1; }
  .info-field .reset-btn {
    color: var(--blue-500); cursor: pointer; font-size: 14px;
    opacity: 0.65; transition: opacity 0.15s; flex-shrink: 0;
  }
  .info-field .reset-btn:hover { opacity: 1; }

  /* Section headers inside card */
  .vm-section {
    background: var(--card-bg); border: 1px solid #dce8ff;
    border-radius: var(--radius); overflow: hidden;
    box-shadow: 0 2px 10px rgba(45,125,210,0.08), 0 1px 3px rgba(45,125,210,0.05);
    margin-bottom: 10px;
  }
  .vm-section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    background: linear-gradient(135deg, #eef5ff 0%, #e4effe 100%);
    border-bottom: 1px solid #d0e4ff;
    cursor: pointer; user-select: none;
  }
  .vm-section-header .sec-left { display: flex; align-items: center; gap: 9px; }
  .vm-section-header .sec-title {
    font-size: 12.5px; font-weight: 800; color: var(--navy-700);
    letter-spacing: 0.2px;
  }
  .vm-section-header .sec-icon { font-size: 14px; color: var(--blue-500); }
  .vm-section-header .sec-toggle { font-size: 11px; color: var(--blue-500); transition: transform 0.2s; }
  .vm-section-header.collapsed .sec-toggle { transform: rotate(-90deg); }
  .vm-section-body { padding: 14px; background: #fafcff; }

  /* ══════════════════════════════════════
     TWO-COLUMN LAYOUT
  ══════════════════════════════════════ */
  .vm-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 12px;
    align-items: start;
  }
  .vm-left { min-width: 0; }
  .vm-right { min-width: 0; }

  /* ══════════════════════════════════════
     ENHANCED TABLE (same as Milestone page)
  ══════════════════════════════════════ */
  .vm-table-card {
    background: var(--card-bg); border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: 0 1px 4px rgba(15,30,80,0.05), 0 4px 14px rgba(15,30,80,0.06);
    overflow: hidden;
  }
  .vm-table-wrap { overflow-x: auto; }
  .vm-table-wrap::-webkit-scrollbar { height: 5px; }
  .vm-table-wrap::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }

  .vm-table {
    width: 100%; border-collapse: collapse;
    font-size: 12px; margin: 0; table-layout: auto;
  }
  .vm-table thead th {
    background: linear-gradient(135deg, #1a3060, #1e3a5f);
    color: rgba(255,255,255,0.88);
    font-size: 10px; font-weight: 700; letter-spacing: 0.4px;
    text-transform: uppercase; padding: 9px 12px; white-space: nowrap;
    border-bottom: 2px solid rgba(45,125,210,0.35);
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .vm-table thead th:last-child { border-right: none; }
  .vm-table tbody tr {
    border-bottom: 1px solid #edf1fa;
    transition: background 0.12s, box-shadow 0.12s;
  }
  .vm-table tbody tr:nth-child(even) { background: #fafcff; }
  .vm-table tbody tr:hover {
    background: #f0f6ff !important;
    box-shadow: inset 3px 0 0 var(--blue-500);
  }
  .vm-table tbody tr:last-child { border-bottom: none; }
  .vm-table tbody td {
    padding: 8px 12px; color: var(--text);
    vertical-align: middle;
    border-right: 1px solid #f0f4fc;
  }
  .vm-table tbody td:last-child { border-right: none; }
  .vm-table a { color: var(--blue-500); text-decoration: none; font-weight: 600; }
  .vm-table a:hover { text-decoration: underline; }

  /* Table add button row */
  .vm-table-toolbar {
    display: flex; justify-content: flex-end; align-items: center;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    background: rgba(45,125,210,0.02);
  }
  .vm-add-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 7px;
    font-size: 11.5px; font-weight: 600; cursor: pointer;
    border: 1px solid rgba(45,125,210,0.25);
    background: rgba(45,125,210,0.06); color: var(--blue-500);
    transition: var(--tr);
  }
  .vm-add-btn:hover {
    background: rgba(45,125,210,0.14); border-color: rgba(45,125,210,0.4);
    transform: translateY(-1px);
  }

  /* ── Delivery status badges ── */
  .ds-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 2px 9px; border-radius: 20px;
    font-size: 10px; font-weight: 700; white-space: nowrap;
  }
  .ds-badge::before {
    content: ''; width: 5px; height: 5px; border-radius: 50%;
    background: currentColor; display: block; flex-shrink: 0;
  }
  .ds-on-time    { background: #e8faf2; color: #0d9f6a; }
  .ds-approach   { background: #fff8e6; color: #c07a00; }
  .ds-today      { background: #eef4ff; color: #2d6ec0; }
  .ds-delayed    { background: #fff0f2; color: #c02038; }
  .ds-escalation { background: #fff0f2; color: #c02038; }
  .ds-default    { background: #f4f4f8; color: var(--muted); }

  /* Status badge */
  .st-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 9px; border-radius: 20px;
    font-size: 11px; font-weight: 600;
  }
  .st-wip       { background: #eef4ff; color: #2d6ec0; }
  .st-completed { background: #e8faf2; color: #0d9f6a; }
  .st-pending   { background: #fff8e6; color: #c07a00; }
  .st-yts       { background: #f4f4f8; color: var(--muted); }

  /* ── Time badge ── */
  .time-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 8px;
    font-size: 11.5px; font-weight: 800;
    background: linear-gradient(135deg, rgba(45,125,210,0.12), rgba(45,125,210,0.06));
    color: var(--blue-500);
    border: 1px solid rgba(45,125,210,0.2);
  }
  .time-badge i { color: var(--accent); font-size: 11px; }

  /* Attachment section headers — gradient */
  .vm-section .vm-section-header {
    background: linear-gradient(135deg, #eef5ff, #e4effe);
  }

  /* Right panel attachment sections — slightly different tint */
  .vm-right .vm-section {
    border-color: #d0e4ff;
  }
  .vm-right .vm-section-header {
    background: linear-gradient(135deg, #e8f2ff, #dceaff);
    border-bottom-color: #c8dcff;
  }

  /* ══════════════════════════════════════
     ATTACHMENT TABLE — compact
  ══════════════════════════════════════ */
  .att-table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
  .att-table thead th {
    background: linear-gradient(135deg, #1a3060, #1e3a5f);
    color: rgba(255,255,255,0.85);
    font-size: 9.5px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.4px; padding: 7px 10px; white-space: nowrap;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .att-table tbody tr { border-bottom: 1px solid #edf1fa; }
  .att-table tbody tr:hover { background: #f4f8ff; }
  .att-table tbody td { padding: 7px 10px; vertical-align: middle; }
  .att-table a { color: var(--blue-500); text-decoration: none; font-weight: 600; font-size: 11.5px; }
  .att-table a:hover { text-decoration: underline; }

  /* ZIP download FAB */
  #zipDownload {
    position: fixed; bottom: 24px; right: 24px; z-index: 400;
    width: 46px; height: 46px; border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    color: #fff; border: none; font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(45,125,210,0.4);
    transition: var(--tr); cursor: pointer;
  }
  #zipDownload:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(45,125,210,0.5); }

  /* Empty state */
  .vm-empty { text-align: center; padding: 28px 16px; }
  .vm-empty i { font-size: 24px; color: rgba(45,125,210,0.3); display: block; margin-bottom: 8px; }
  .vm-empty p { font-size: 12px; color: var(--muted); margin: 0; font-weight: 500; }

  /* Tab panes */
  .vm-tab-pane { display: none; }
  .vm-tab-pane.active { display: block; }

  /* Hidden helper */
  .hidden { display: none !important; }

  /* Scrollable columns */
  .vm-scroll-col {
    height: calc(100vh - 148px);
    overflow-y: auto;
    overflow-x: hidden;
  }
  .vm-scroll-col::-webkit-scrollbar { width: 5px; }
  .vm-scroll-col::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }

  /* Info section — old accordion style removed, use vm-section instead */
  .vm-section-body .info-grid { padding: 0; }
</style>

<body>
<%
  let bgColour = "";
  let bgMap = {
    "On Time":"on-time",
    "Approaching Due Date":"approach",
    "Due Today":"today",
    "Delayed":"delayed",
    "Escalation":"escalation"
  };
  function dsBadge(status) {
    if (!status) return '<span class="ds-badge ds-default">—</span>';
    const cls = bgMap[status] || 'default';
    return '<span class="ds-badge ds-' + cls + '">' + status + '</span>';
  }
  function stBadge(s) {
    if (!s) return '<span class="st-badge st-yts">—</span>';
    const l = s.toLowerCase();
    const c = l.includes('wip') ? 'st-wip' : l.includes('complet') ? 'st-completed' : l.includes('yts') ? 'st-yts' : 'st-pending';
    return '<span class="st-badge ' + c + '">' + s + '</span>';
  }
  let MilestoneStatus = ['YTS','WIP','Completed','CQC-YTS','CQC-WIP','USQC-YTS','USQC-WIP','Submitted - Awaiting Approval','Approved','Short-Closed'];
  let Billing_Category = ['Billable','Non-Billable'];
%>

<main>

  <!-- ── PAGE HEADER ── -->
  <div class="vm-header">
    <div class="vm-header-left">
      <div class="vm-header-icon"><i class="bi bi-signpost-split-fill"></i></div>
      <div>
        <div class="vm-header-name"><%= Milestone_Info.Milestone_Name %></div>
        <div class="vm-header-project">
          <i class="bi bi-folder2-open"></i>
          <a href="/Project/<%= Milestone_Info.Customer %>/<%= Milestone_Info.Project_ID %>/<%= Milestone_Info.idProjects %>">
            <%= Milestone_Info.Project_ID %>
          </a>
          <span style="color:var(--border)">|</span>
          <i class="bi bi-building"></i> <%= Milestone_Info.Customer %>
        </div>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <span class="vm-status-pill"><%= Milestone_Info.Milestone_Status %></span>
      <span class="time-badge"><i class="bi bi-clock"></i> <%= secondsToMinutes(MilestoneTotalProductionTime + MilestoneTotalQCTime) %></span>
    </div>
  </div>

  <!-- ── TABS ── -->
  <div class="vm-tabs-wrap">
    <div class="vm-tabs">
      <button class="vm-tab active" onclick="vmTab('info',this)"><i class="bi bi-info-circle"></i> Info</button>
      <button class="vm-tab" onclick="vmTab('prod',this)"><i class="bi bi-gear"></i> Production</button>
      <button class="vm-tab" onclick="vmTab('qc',this)"><i class="bi bi-check-circle"></i> QC</button>
      <button class="vm-tab" onclick="vmTab('subtask',this)"><i class="bi bi-diagram-3"></i> Subtask</button>
      <button class="vm-tab" onclick="vmTab('markup',this)"><i class="bi bi-pencil"></i> Markup</button>
      <button class="vm-tab" onclick="vmTab('active',this)"><i class="bi bi-activity"></i> Active Task</button>
    </div>
  </div>

  <!-- ══════════ INFO TAB ══════════ -->
  <div class="vm-tab-pane active" id="pane-info">
    <div class="vm-layout">

      <!-- LEFT — Info sections -->
      <div class="vm-left vm-scroll-col">

        <!-- General Information -->
        <div class="vm-section">
          <div class="vm-section-header" onclick="toggleSection(this)">
            <div class="sec-left">
              <i class="bi bi-card-list sec-icon"></i>
              <span class="sec-title">General Information</span>
            </div>
            <i class="bi bi-chevron-down sec-toggle"></i>
          </div>
          <div class="vm-section-body">
            <div class="info-grid">

              <!-- Job ID -->
              <div class="info-field">
                <label><i class="bi bi-hash"></i> <%= Customer=="AT&T" ? "F2 CFAS-ID" : "Job ID" %></label>
                <div class="info-val">
                  <a href="/Project/<%= Milestone_Info.Customer %>/<%= Milestone_Info.Project_ID %>/<%= Milestone_Info.idProjects %>">
                    <%= Milestone_Info.Project_ID %>
                  </a>
                </div>
              </div>

              <!-- Owner -->
              <div class="info-field">
                <label><i class="bi bi-person"></i> Owner</label>
                <div class="info-val">
                  <div class="edit-wrap">
                    <% if (userData.Role=="PMO") { %>
                      <select name="" class="select-list hidden" data-OwnerFor="Milestone" data-ID="<%= Milestone_Info.Milestone_Name %>">
                        <% for(let i=0; i<Object.values(Owners).length; i++){ %>
                          <% if(Owners[i].Role=="Manager"){ %>
                            <option value="<%= Owners[i].Employee_ID %>" <%= Owners[i].Employee_ID==Milestone_Info.Milestone_Owner?"selected":"" %>>
                              <%= Owners[i].Full_Name %> (<%= Owners[i].Employee_ID %>)
                            </option>
                          <% } %>
                        <% } %>
                      </select>
                      <span class="Owner user-info" data-userID="<%= Milestone_Info.Milestone_Owner %>"><%= Milestone_Info.Full_Name %></span>
                      <span class="toggle-button"><i class="bi bi-pencil-square"></i></span>
                      <span class="position-absolute reset-btn hidden"><i class="bi bi-x-square-fill"></i></span>
                    <% } else { %>
                      <span class="Owner" data-userID="<%= Milestone_Info.Milestone_Owner %>"><%= Milestone_Info.Full_Name %></span>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- SOW -->
              <div class="info-field">
                <label><i class="bi bi-file-text"></i> SOW</label>
                <div class="info-val"><%= Milestone_Info.SOW || "—" %></div>
              </div>

              <!-- Status -->
              <div class="info-field">
                <label><i class="bi bi-activity"></i> Status</label>
                <div class="info-val">
                  <div class="edit-wrap">
                    <% if(userData.Role=="PMO"){ %>
