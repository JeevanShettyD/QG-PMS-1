<script>
/* ── Tab switching ── */
function vmTab(name, btn) {
  document.querySelectorAll('.vm-tab').forEach(function(b){ b.classList.remove('active'); });
  document.querySelectorAll('.vm-tab-pane').forEach(function(p){ p.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('pane-' + name).classList.add('active');
}

/* ── Section collapse/expand ── */
function toggleSection(header) {
  var body = header.nextElementSibling;
  var toggle = header.querySelector('.sec-toggle');
  var isOpen = body.style.display !== 'none';
  body.style.display = isOpen ? 'none' : '';
  header.classList.toggle('collapsed', isOpen);
}

/* ── Modal events (UNCHANGED) ── */
const Input_Modal = document.getElementById('AttachmentDialog');
if (Input_Modal) {
  Input_Modal.addEventListener('show.bs.modal', function(event) {
    fileList = document.getElementById("filelist");
    const recipient = event.relatedTarget.getAttribute('data-bs-Category');
    axios.post("/api/updateSessionDetails",{
      "Project_ID":"<%- Milestone_Info.Project_ID %>",
      "Customer":"<%- Customer %>",
      "Category":recipient,
      "Milestone":"<%= Milestone_Info.Milestone_Name %>",
      "Type":"Inputs"
    });
  });
}

const Deliverables_Modal = document.getElementById('FinalUploaderAttachmentDialog');
if (Deliverables_Modal) {
  Deliverables_Modal.addEventListener('show.bs.modal', function(event) {
    fileList = document.getElementById("Final_filelist");
    const recipient = event.relatedTarget.getAttribute('data-bs-Category');
    document.getElementById("revision-counter").innerText = recipient.split("-")[3];
    axios.post("/api/updateSessionDetails",{
      "Project_ID":"<%- Milestone_Info.Project_ID %>",
      "Customer":"<%- Customer %>",
      "Category":recipient,
      "Milestone":"<%= Milestone_Info.Milestone_Name %>",
      "Type":"Final Deliverables"
    });
  });
  Deliverables_Modal.addEventListener('hidden.bs.modal', function() {
    document.getElementById("fileInput2").value = "";
    filesQueue.length = 0;
    successLength = 0;
    $("#startUpload2").attr("disabled", false);
  });
}

$(".QC_Due_Date_Container").hide();
$('input[type="radio"][name="autoQC"]').on('click', function() {
  if ($(this).val() === '1') {
    $('.QC_Due_Date_Container').show();
    $('#QC_Due_Date').attr('required', true);
  } else {
    $('.QC_Due_Date_Container').hide();
    $('#QC_Due_Date').attr('required', false);
  }
});

let Customer = "<%- Customer %>";
let Milestone_Name = '<%= Milestone_Info.Milestone_Name %>';
setInterval(function() {
  socket.emit("getAllActiveStatus", { Milestone_Name: Milestone_Name, Customer: Customer, ResponseFor: "Milestone" });
}, 2000);

$("#QC_Due_Date").change(function() {
  if ($("#ProdDueDate").val() && $(this).val() <= $("#ProdDueDate").val()) {
    $(this).val(""); $("#ProdDueDate").val("");
    alert("QC Due Date cannot be less than production deadline.");
  }
});
$("#ProdDueDate").change(function() {
  if ($("#QC_Due_Date").val() && $(this).val() <= $("#QC_Due_Date").val()) {
    $(this).val(""); $("#QC_Due_Date").val("");
    alert("QC Due Date cannot be less than production deadline.");
  }
});

$("#requiredQC").change(function() {
  const qcNameEl = document.getElementById("Create-Prod-Task-Modal").querySelector("#QC_Name");
  if (!$(this).is(":checked")) {
    qcNameEl.removeAttribute("required"); qcNameEl.value = null;
    qcNameEl.parentElement.parentElement.classList.add("visually-hidden");
    document.getElementsByName("autoQC").forEach(function(e){ e.setAttribute("disabled",""); });
    document.getElementById("autoQC2").setAttribute("checked","checked");
    document.getElementById("Create-Prod-Task-Modal").querySelector("#QC_Due_Date").parentElement.parentElement.classList.add("visually-hidden");
    $('#QC_Due_Date').attr('required', false);
  } else {
    qcNameEl.setAttribute("required","");
    document.getElementById("autoQC2").removeAttribute("checked");
    qcNameEl.parentElement.parentElement.classList.remove("visually-hidden");
    document.getElementsByName("autoQC").forEach(function(e){ e.removeAttribute("disabled"); });
    document.getElementById("Create-Prod-Task-Modal").querySelector("#QC_Due_Date").parentElement.parentElement.classList.remove("visually-hidden");
  }
});
</script>
