<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <%- include('../partials/dependencies') %>
</head>
<%- include('../partials/PMO-header',{userData:userData}) %>

  <body>
    <main>
      <div class="scrollbar-style-3 mt-1 rounded-3">
        <table class="table table-hover overflow-hidden rounded-3" aria-label="Project List" id="Project-List" style="font-size: 14px;">
          <thead class="bg-primary bg-opacity-75 fg-white bg-gradient">
            <tr class="text-center">
              <th class="text-light" scope="col" data-dt-order="disable">
                <input type="checkbox" name="selectAll" id="selectAll" class="form-check-input">
                <span>Sl.No</span>
              </th>
              <th class="text-light" scope="col">JOB ID</th>
              <th class="text-light" scope="col">SOW</th>
              <th class="text-light" scope="col">Work Type</th>
              <th class="text-light" scope="col">Division</th>
              <th class="text-light" scope="col">Received Date</th>
              <th class="text-light" scope="col">Due Date</th>
              <!-- <th class="text-light" scope="col">Approved Date</th> -->
              <th class="text-light" scope="col">Status</th>
            </tr>
          </thead>
          <tbody id="content-area">
            <% if (Object.values(Data).length>0) { %>
              <% for( let index=0; index < Object.values(Data).length; index++ ) { %>
                <tr>
                  <td>
                    <input type="checkbox" class="record-checkbox form-check-input" value="<%= Data[index].JOB_ID %>">
                    <%= index+1%>
                  </td>
                  <!-- <td onclick="viewProject('<%= Data[index].JOB_ID %>')" class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover">
                    <a href="#">
                      <%= Data[index].JOB_ID %>
                  </a>
                  </td> -->
                  <td
                    class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover">
                    <a href="/Project/SkyTec/<%= Data[index].JOB_ID  %>">
                      <%= Data[index].JOB_ID %>
                    </a>
                  </td>
                  <td><span>
                      <%= Data[index].SOW %>
                    </span>
                  </td>
                  <td>
                    <span>
                      <%= Data[index].Worktype %>
                    </span>
                  </td>
                  <td>
                    <span>
                      <%= Data[index].Division %>
                    </span>
                  </td>
                  <td>
                    <span>
                      <%= Data[index].n_ReceivedDate %>
                    </span>
                  </td>
                  <td>
                    <span>
                      <%= Data[index].n_DueDate %>
                    </span>
                  </td>
                  <!-- <td>
                    <span>
                      <%= Data[index].n_ApprovedDate %>
                    </span>
                  </td> -->
                  <td>
                    <p>
                      <%= Data[index].Status %>
                    </p>
                  </td>

                </tr>
                <% } } %>

          </tbody>
        </table>
        <div style="transition: all .3s ease;"
          class="position-fixed translate-middle-x bottom-0 start-50  mb-2 visually-hidden bulk-milestone-creation-btn">
          <button type="button" data-bs-toggle="modal" data-bs-target="#createMilestoneModal"
            class="btn btn-success bg-gradient rounded-pill ">Create <span id="ActiveCount"></span>
            Milestone</button>
          <button type="button" data-bs-toggle="modal" data-bs-target="#UpdateStatusModal"
            class="btn btn-success bg-gradient rounded-pill">Update Status</button>
        </div>
        <button type="button" class="floating-btn btn btn-secondary bg-gradient rounded-pill">Filter <i
            class="bi bi-funnel"></i></button>
        <form action="/<%= userData.Role  %>/Projects/SkyTec" method="get">
          <div class="floating-container bg-light shadow rounded-3 p-1">
            <label for="JOB_ID" class="from-label">JOB ID</label>
            <input type="search" name="JOB_ID" id="JOB_ID" value="" placeholder="Enter the JOB ID"
              class="form-control bg-white border">

            <label for="SOW" class="from-label">SOW</label>
            <select name="SOW" id="SOW" class="form-select">
              <option value="" selected>All</option>
              <% const SOW=FilterData.SOW %>
                <% for( let index=0; index < SOW.length; index++ ) { %>
                  <option value="<%=SOW[index]%>">
                    <%=SOW[index]%>
                  </option>
                  <% } %>
            </select>
            <label for="Worktype" class="from-label">Work Type</label>
            <select name="Worktype" id="Worktype" class="form-select">
              <option value="" selected>All</option>
              <% const Worktype=FilterData.WorkType %>
                <% for( let index=0; index < Worktype.length; index++ ) { %>
                  <option value="<%=Worktype[index]%>">
                    <%=Worktype[index]%>
                  </option>
                  <% } %>
            </select>
            <label for="Division" class="from-label">Division</label>
            <select name="Division" id="Division" class="form-select">
              <option value="" selected>All</option>
              <% const Division=FilterData.Division %>
                <% for( let index=0; index < Division.length; index++ ) { %>
                  <option value="<%=Division[index]%>">
                    <%=Division[index]%>
                  </option>
                  <% } %>
            </select>
            <label for="Status" class="from-label">Status</label>
            <select name="Status" id="Status" class="form-select">
              <option value="" selected>All</option>
              <% const Status=FilterData.Status %>
                <% for( let index=0; index < Status.length; index++ ) { %>
                  <option value="<%=Status[index]%>">
                    <%=Status[index]%>
                  </option>
                  <% } %>
            </select>
            <button type="submit" class="btn btn-primary bg-gradient btn-sm m-1" id="filter-btn">Show</button>
        </form>
      </div>
      </div>
    </main>
  </body>
  <!-- Project Modal -->
