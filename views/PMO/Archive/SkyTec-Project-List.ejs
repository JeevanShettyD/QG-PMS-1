      $(".floating-btn").click(function () {
        $(".floating-container").toggleClass("slide-in");
      });

      document.addEventListener('DOMContentLoaded', function () {
        const selectAllCheckbox = document.getElementById('selectAll');
        const recordCheckboxes = document.querySelectorAll('.record-checkbox');
        const selectedRecords = [];

        // Function to update selected records
        function updateSelectedRecords() {
          selectedRecords.length = 0; // Clear the array
          recordCheckboxes.forEach(checkbox => {
            if (checkbox.checked) {
              selectedRecords.push(checkbox.value);
            }
          });
          console.log('Selected records:', selectedRecords);
          console.log('Selected record count:', selectedRecords.length);
          const ActiveCountLabels = document.querySelectorAll("#ActiveCount");
          ActiveCountLabels.forEach(label => {
            label.innerText = selectedRecords.length ? selectedRecords.length : '';
          })
          if (selectedRecords.length > 0) {
            document.querySelectorAll(".bulk-milestone-creation-btn").forEach(item => {
              item.classList.remove("visually-hidden");
            })
            const containers = document.querySelectorAll("div .job-id-container");
            containers.forEach(container => {
              container.innerHTML = null;
              selectedRecords.forEach((job, index) => {
                container.innerHTML += `<div class='d-flex align-items-center'><span>${index + 1}-</span><input type="text" class="border-bottom bg-body-tertiary m-1" id="Project_ID" name="Project_ID" placeholder="Enter Job ID"
                  value="${job}" readonly required> </div>`
              });
            });
          } else {
            document.querySelectorAll(".bulk-milestone-creation-btn").forEach(item => {
              item.classList.add("visually-hidden");
            })
          }
        }

        // Event listener for the "Select All" checkbox
        selectAllCheckbox.addEventListener('change', function () {
          const isChecked = this.checked;
          recordCheckboxes.forEach(checkbox => {
            checkbox.checked = isChecked;
          });
          updateSelectedRecords();
        });

        // Event listener for individual record checkboxes
        recordCheckboxes.forEach(checkbox => {
          checkbox.addEventListener('change', function () {
            if (!this.checked) {
              selectAllCheckbox.checked = false;
            } else {
              // Check if all record checkboxes are checked
              let allChecked = true
              recordCheckboxes.forEach(checkbox => { if (!checkbox.checked) { allChecked = false } });
              if (allChecked) {
                selectAllCheckbox.checked = true;
              }
            }
            updateSelectedRecords();
          });
        });

        const params = getUrlParams();
        const selects = document.querySelectorAll('select');
        const search = document.querySelectorAll('input[type="search"]');
        selects.forEach(select => {
          for (const paramName in params) {
            if (params.hasOwnProperty(paramName) && paramName === select.name) {
              const selectValue = params[paramName];
              const option = select.querySelector(`option[value="${selectValue}"]`);
              if (option) {
                option.selected = true;
                break; // Exit loop after setting selected option
              }
            }
          }
        });
        search.forEach(input => {
          for (const paramName in params) {
            if (params.hasOwnProperty(paramName) && paramName === input.name) {
              const selectValue = params[paramName];
              input.value = selectValue;
            }
          }
        })
      });

      var Prod_TGT_Start_Date = document.getElementById('Prod_TGT_Start_Date');
      var Prod_TGT_End_Date = document.getElementById('Prod_TGT_End_Date');
      var QC_TGT_Start_Date = document.getElementById('QC_TGT_Start_Date');
      var QC_TGT_End_Date = document.getElementById('QC_TGT_End_Date');
      let dateInput = [Prod_TGT_Start_Date, Prod_TGT_End_Date, QC_TGT_Start_Date, QC_TGT_End_Date];
      dateInput.forEach(input => {
        input.addEventListener('change', () => {
          validateDate(Prod_TGT_Start_Date.value, Prod_TGT_End_Date.value, QC_TGT_Start_Date.value, QC_TGT_End_Date.value);
        });
      })
      function validateDate(PSDate, PEDate, QSDate, QEDate) {
        if (PSDate && PEDate && QSDate && QEDate) {
          if (!((new Date(PEDate) >= new Date(PSDate)) && (new Date(QEDate) >= new Date(QSDate)) && (new Date(QSDate) >= new Date(PEDate)))) {
            Prod_TGT_Start_Date.value = "";
            Prod_TGT_End_Date.value = "";
            QC_TGT_Start_Date.value = "";
            QC_TGT_End_Date.value = "";
            toasts.push({
              title: "Error",
              content: "Please provide the valid dates.",
              style: "error",
              dismissAfter: '10s',
            });

          }
        }
      }
      let Table=new DataTable('#Project-List',{
        paging:true,
        pageLength: 50,
        order: {
        idx: 6,
        dir: 'desc'
    }
      })
      function sortTable(columnIndex) {
        let table, rows, switching, i, x, y, shouldSwitch;
        table = document.querySelector('table');
        switching = true;
        while (switching) {
          switching = false;
          rows = table.rows;
          for (i = 1; i < (rows.length - 1); i++) {
            shouldSwitch = false;
            x = rows[i].getElementsByTagName('td')[columnIndex];
            y = rows[i + 1].getElementsByTagName('td')[columnIndex];
            console.log(x.innerText)
            if (parseInt(x.innerText) < parseInt(y.innerText)) {
              shouldSwitch = true;
              break;
            }
          }
          if (shouldSwitch) {
            rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
            switching = true;
          }
        }
      }

    </script>

