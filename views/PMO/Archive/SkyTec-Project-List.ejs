  <!--Create Milestone Modal -->
  <div class="modal fade" id="createMilestoneModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5" id="staticBackdropLabel">Create Milestone</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/<%= userData.Role  %>/CreateMilestone/SkyTec" method="post" id="createMilestoneForm">
          <div class="modal-body">
            <div class="row g-2">
              <div class="col-md">
                <label for="Project_ID">Selected Job (Total: <span id="ActiveCount"></span>)</label>
                <div class="form-floating job-id-container overflow-y-auto "
                  style="height: fit-content; max-height: 25dvh;">
                </div>
              </div>
              <div class="col-md">
                <div class="row">
                  <div class="col form-floating">
                    <input type="date" class="form-control" id="Prod_TGT_Start_Date" name="Prod_TGT_Start_Date"
                      placeholder="" required>
                    <label for="Prod_TGT_Start_Date">Prod TGT Start Date</label>
                  </div>
                  <div class="col form-floating">
                    <input type="date" class="form-control" id="Prod_TGT_End_Date" name="Prod_TGT_End_Date"
                      placeholder="" required>
                    <label for="Prod_TGT_End_Date">Prod TGT End Date</label>
                  </div>
                </div>
                <div class="row">
                  <div class="col form-floating">
                    <input type="date" class="form-control" id="QC_TGT_Start_Date" name="QC_TGT_Start_Date"
                      placeholder="" required>
                    <label for="QC_TGT_Start_Date">QC TGT Start Date</label>
                  </div>
                  <div class="col form-floating">
                    <input type="date" class="form-control" id="QC_TGT_End_Date" name="QC_TGT_End_Date" placeholder=""
                      required>
                    <label for="QC_TGT_End_Date">QC TGT End Date</label>
                  </div>
                </div>
                <div class="row">
                  <div class="form-floating">
                    <select name="Owner" id="milestone_owner" class="form-select" required>
                      <option value="" selected>Choose Owner</option>
                      <% for( let index=0; index < Object.values(Owners).length; index++ ) { %>
                        <option value="<%= Owners[index].Employee_ID %>">
                          <%= Owners[index].Full_Name %>
                        </option>
                        <% } %>

                    </select>
                    <label for="milestone_owner">Owner</label>
                  </div>

                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="reset" class="btn btn-secondary" data-bs-dismiss="modal" data-bs-toggle="modal"
              data-bs-target="#createMilestoneModal">Close</button>
            <button type="submit" class="btn btn-success">Create</button>
          </div>
        </form>
      </div>
    </div>
