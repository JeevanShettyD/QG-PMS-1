  <%- include('../partials/dependencies-js',{Notifications:Notifications}) %>
    <script>
      function viewProject(id) {
        axios.get('/api/projectInfo/SkyTec', {
          params: {
            ID: id
          }
        }).then(res => {
          const object = res.data.project[0];
          for (const key in object) {
            if (Object.hasOwnProperty.call(object, key)) {
              var element = object[key];
              try {
                if (key == 'Note') {
                  var area = document.getElementById('Note');
                  area.innerHTML = `<p><b>Comment's</b></p>`;
                  element = JSON.parse(element);
                  if (Object.keys(element).length) {
                    for (const group in element) {
                      const note = element[group];
                      let values = Object.values(note);
                      let attachmentName = values[4];
                      area.innerHTML += `
                                <div class="row  m-1">
                                      <div class="col-sm-12">
                                        <p><small><span><i class="bi bi-person-fill"></i>&nbsp;${values[3]}</span> <b>|</b> <span><i class="bi bi-calendar3"></i>&nbsp;${values[0]}</span>${(attachmentName !== null && attachmentName != undefined && attachmentName != "") ? `<b> | </b> <span> <a href="../public/uploads/ReferenceDoc/${attachmentName}" class="text-decoration-none btn btn-outline-secondary border-0 btn-sm" download>
                                          <span id="type" class="text-uppercase"> </span><i class="bi bi-paperclip"></i></a></span> `: ``} </small></p>
                                          <p class='border comment-section p-2 m-0'>${values[1]}</p>
                                          </div>
                                          
                                          </div>`;
                    }
                  } else {
                    area.innerHTML += `
                                <div class="row  m-1">
                                     
                                          <p class='mx-auto'>No Comments</p>
                                     
                                        </div>`;
                  }
                } else if (key == 'idProjects') {
                  document.getElementById("editButton").setAttribute('href', `/PMO/editProject/SkyTec/${object[key]}`)
                  //document.getElementById("milestoneButton").setAttribute('href', `/PMO/milestone/SkyTec/${object[key]}`)
                } else if (key == 'ReceivedDate' || key == 'DueDate' || key == 'ApprovedDate' || key == 'Owner') {
                } else {
                  if (key == 'JOB_ID') {
                    const list = document.querySelectorAll('#JOB_ID')
                    list.forEach(item => {
                      item.innerText = element;
                    });
                    document.getElementById("Project_ID").value = element;
                  }
                  document.getElementById(`${key}`).innerText = element;
                }
              } catch (error) {
                console.log(error)
              }
            }
          }
          const milestones = res.data.milestone;
          const body = document.getElementById('milestoneBody');
          body.innerHTML = null;
          milestones.forEach((roeData, index) => {
            const row = body.insertRow(-1);
            // Add Serial Number in the first column
            row.insertCell(0).textContent = index + 1;
            row.insertCell(1).innerHTML = `<a href="/ViewMilestone/SkyTec/${roeData.Milestone_Name}">${roeData.Milestone_Name}</a>`;
            row.insertCell(2).textContent = roeData.Prod_TGT_Start_Date;
            row.insertCell(3).textContent = roeData.Prod_ACT_Start_Date;
            row.insertCell(4).textContent = roeData.Prod_TGT_End_Date;
            row.insertCell(5).textContent = roeData.Prod_ACT_End_Date;
            row.insertCell(6).textContent = roeData.QC_TGT_Start_Date;
            row.insertCell(7).textContent = roeData.QC_ACT_Start_Date;
            row.insertCell(8).textContent = roeData.QC_TGT_End_Date;
            row.insertCell(9).textContent = roeData.QC_ACT_End_Date;
          });
        }).catch(error => {
          console.log(error);
        })
        $("#projectModal").modal('show')
      }

