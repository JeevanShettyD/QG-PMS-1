<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= Customer+'-' %>Project</title>
  <%- include('../partials/dependencies') %>
</head>
<%- include('../partials/PMO-header',{userData:userData}) %>

<style>
/* ══════════════════════════════════════
   QGPMS DESIGN SYSTEM — Project List
   Exact same palette as Milestone List
══════════════════════════════════════ */
:root {
  --ms-navy:   #0f1e36;
  --ms-navy2:  #152844;
  --ms-navy3:  #1b3258;
  --ms-blue:   #2d7dd2;
  --ms-blue2:  #4a96e8;
  --ms-cyan:   #00c6ff;
  --ms-light:  #f0f4fa;
  --ms-card:   #ffffff;
  --ms-border: #e2e8f4;
  --ms-text:   #1e2d45;
  --ms-muted:  #7a8aaa;
  --ms-radius: 10px;
  --ms-shadow: 0 2px 12px rgba(15,30,80,0.08), 0 8px 28px rgba(15,30,80,0.06);
  --ms-tr:     all 0.18s cubic-bezier(0.4,0,0.2,1);
}

html, body { background: var(--ms-light); }
.ms-page { padding: 14px 18px 60px; background: var(--ms-light); }

/* ── Toolbar ── */
.ms-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 10px; margin-bottom: 10px;
}
.ms-toolbar-left  { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.ms-toolbar-right { display: flex; align-items: center; gap: 8px; }

.ms-page-title {
  font-size: 15px; font-weight: 700; color: var(--ms-text);
  display: flex; align-items: center; gap: 8px;
}
.ms-page-title i { color: var(--ms-blue); font-size: 16px; }

.customer-pill {
  background: rgba(45,125,210,0.1); color: var(--ms-blue);
  border: 1px solid rgba(45,125,210,0.2);
  border-radius: 20px; padding: 3px 12px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.3px;
}

/* ── Buttons ── */
.ms-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 14px; border-radius: 8px;
  font-size: 12px; font-weight: 600; cursor: pointer;
  border: none; transition: var(--ms-tr); text-decoration: none;
}
.ms-btn-primary {
  background: linear-gradient(135deg, var(--ms-blue), #1a60b8);
  color: #fff; box-shadow: 0 2px 8px rgba(45,125,210,0.3);
}
.ms-btn-primary:hover {
  background: linear-gradient(135deg, #3a8ae0, #2266cc);
  box-shadow: 0 4px 14px rgba(45,125,210,0.4);
  transform: translateY(-1px); color: #fff;
}

/* ── Column selector ── */
.ms-field-selector { position: relative; }
.ms-field-trigger {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 13px; border-radius: 8px;
  background: #fff; border: 1px solid var(--ms-border);
  font-size: 12px; font-weight: 600; color: var(--ms-text);
  cursor: pointer; transition: var(--ms-tr);
  box-shadow: 0 1px 4px rgba(0,0,0,0.06); user-select: none;
}
.ms-field-trigger:hover { border-color: var(--ms-blue); background: #eef5ff; }
.ms-field-trigger i { color: var(--ms-blue); }
.ms-field-panel {
  position: absolute; top: calc(100% + 8px); left: 0;
  background: #fff; border: 1px solid var(--ms-border);
  border-radius: var(--ms-radius);
  box-shadow: 0 8px 32px rgba(15,30,80,0.14);
  z-index: 999; min-width: 220px; padding: 10px; display: none;
  animation: dropIn 0.18s cubic-bezier(0.34,1.56,0.64,1);
}
.ms-field-panel.open { display: block; }
@keyframes dropIn {
  from { opacity:0; transform:translateY(-6px) scale(0.98); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.ms-field-panel-header {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 8px; border-bottom: 1px solid var(--ms-border); margin-bottom: 8px;
}
.ms-field-panel-header span { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:0.8px; color:var(--ms-muted); }
.ms-field-panel-header button { font-size:10px; color:var(--ms-blue); background:none; border:none; cursor:pointer; font-weight:600; padding:0; }
.ms-field-item {
  display: flex; align-items: center; gap: 8px;
  padding: 5px 4px; border-radius: 6px; font-size: 12px; color: var(--ms-text);
  cursor: pointer; transition: background 0.12s;
}
.ms-field-item:hover { background: #f0f6ff; }
.ms-field-item input[type="checkbox"] { accent-color: var(--ms-blue); width: 14px; height: 14px; }

/* ── Tabs — exact Milestone pill tabs ── */
.ms-tabs-wrap { display: flex; justify-content: center; margin-bottom: 10px; }
.ms-tabs {
  display: inline-flex; align-items: center;
  background: #fff; border: 1px solid var(--ms-border);
  border-radius: 12px; padding: 4px; gap: 3px;
  box-shadow: var(--ms-shadow);
}
.ms-tab {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 7px 18px; border-radius: 9px;
  font-size: 12.5px; font-weight: 600; cursor: pointer;
  border: none; background: transparent; color: var(--ms-muted);
  transition: var(--ms-tr); white-space: nowrap;
}
.ms-tab i { font-size: 13px; }
.ms-tab:hover { background: #f0f6ff; color: var(--ms-blue); }
.ms-tab.active {
  background: linear-gradient(135deg, var(--ms-blue2), var(--ms-blue));
  color: #fff; box-shadow: 0 3px 12px rgba(45,125,210,0.3);
}
.ms-tab .ms-tab-count {
  background: rgba(255,255,255,0.25); border-radius: 20px;
  padding: 1px 7px; font-size: 10px; font-weight: 700;
}
.ms-tab:not(.active) .ms-tab-count { background: rgba(45,125,210,0.1); color: var(--ms-blue); }

/* ── Table card ── */
.ms-table-card {
  background: #fff; border-radius: 12px;
  border: 1px solid var(--ms-border);
  box-shadow: 0 1px 4px rgba(15,30,80,0.06), 0 6px 20px rgba(15,30,80,0.07);
  overflow: hidden;
}
.ms-table-scroll { overflow-x: auto; overflow-y: visible; }
.ms-table-scroll::-webkit-scrollbar { height: 5px; }
.ms-table-scroll::-webkit-scrollbar-track { background: #f0f4fc; }
.ms-table-scroll::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }
.ms-table-scroll::-webkit-scrollbar-thumb:hover { background: var(--ms-blue); }

/* ── Table ── */
.ms-table { width: 100%; border-collapse: collapse; font-size: 12.5px; table-layout: auto; }

.ms-table thead tr th {
  background: linear-gradient(135deg, #1a3060, #1e3a5f);
  color: rgba(255,255,255,0.9);
  font-size: 11px; font-weight: 700; letter-spacing: 0.2px;
  padding: 9px 12px; white-space: nowrap;
  border-bottom: 2px solid rgba(45,125,210,0.4);
  border-right: 1px solid rgba(255,255,255,0.06);
  position: sticky; top: 0; z-index: 10; cursor: pointer;
}
.ms-table thead tr th:last-child { border-right: none; }
.ms-table thead tr th[data-sort="asc"]::after  { content: ' ↑'; opacity: 0.8; font-size: 10px; }
.ms-table thead tr th[data-sort="desc"]::after { content: ' ↓'; opacity: 0.8; font-size: 10px; }
.ms-table thead tr th:hover { background: linear-gradient(135deg, #1e3a6e, #244480); }
.ms-table thead th { position: relative; }
.col-resize-handle {
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 4px; cursor: col-resize; background: transparent; transition: background 0.15s;
}
.col-resize-handle:hover { background: rgba(0,198,255,0.6); }

/* Data rows */
.ms-table tbody tr.ms-data-row {
  border-bottom: 1px solid #edf1fa; transition: background 0.12s, box-shadow 0.12s;
}
.ms-table tbody tr.ms-data-row:hover {
  background: #f0f6ff !important; box-shadow: inset 3px 0 0 var(--ms-blue);
}
.ms-table tbody tr.ms-data-row:nth-child(4n+1) { background: #fff; }
.ms-table tbody tr.ms-data-row:nth-child(4n+3) { background: #fafcff; }
.ms-table tbody td {
  padding: 9px 12px; color: var(--ms-text); vertical-align: middle;
  border-right: 1px solid #f0f4fc;
}
.ms-table tbody td:last-child { border-right: none; }

/* Detail expand row */
.ms-table tbody tr.ms-detail-row td {
  background: #f4f8ff !important;
  padding: 0 !important;
  border-top: none !important;
  border-bottom: 2px solid #d8e4f8 !important;
}

/* Row toggle */
.ms-row-toggle {
  width: 22px; height: 22px; border-radius: 6px;
  background: #eef4ff; border: 1px solid #d0e0f8;
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer; transition: var(--ms-tr); flex-shrink: 0;
  color: var(--ms-blue); font-size: 10px;
}
.ms-row-toggle:hover { background: var(--ms-blue); color: #fff; }

/* S.No cell */
.td-sno {
  font-weight: 700; color: var(--ms-muted);
  font-size: 11px; text-align: center;
  width: 54px; padding-left: 14px !important;
}

/* Links */
.ms-table a { color: var(--ms-blue); text-decoration: none; font-weight: 600; }
.ms-table a:hover { text-decoration: underline; }

/* Delivery status badges */
.ms-delivery {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 9px; border-radius: 20px;
  font-size: 10.5px; font-weight: 700; white-space: nowrap;
}
.ms-delivery i { font-size: 9px; }
.ms-delivery.on-time    { background: #e8faf2; color: #0d9f6a; }
.ms-delivery.approaching{ background: #fff8e6; color: #c07a00; }
.ms-delivery.due-today  { background: #eef4ff; color: #2d6ec0; }
.ms-delivery.delayed    { background: #fff0f2; color: #c02038; }
.ms-delivery.escalation { background: #fff0f2; color: #c02038; }

/* Status badge */
.ms-status {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 9px; border-radius: 20px;
  font-size: 10.5px; font-weight: 700; white-space: nowrap;
  background: #f0f4fc; color: var(--ms-muted);
}
.ms-status.yta        { background: #fff8e6; color: #c07a00; }
.ms-status.yts        { background: #eef3ff; color: #3a6ec0; }
.ms-status.approved   { background: #e8faf2; color: #0d9f6a; }
.ms-status.rejected   { background: #fff0f2; color: #c02038; }
.ms-status.cancel     { background: #f4f4f4; color: #666; }
.ms-status.reassigned { background: #fff4e6; color: #a05000; }

/* Milestone expand detail */
.ms-milestone-detail { padding: 12px 18px; }
.ms-milestone-detail-header {
  display: grid; grid-template-columns: 2fr 1fr 1.5fr 1fr 1fr 1fr;
  gap: 0; background: linear-gradient(135deg, #1a3060, #1e3a5f);
  border-radius: 8px 8px 0 0; overflow: hidden;
}
.ms-milestone-detail-header span {
  padding: 7px 12px; font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.4px; color: rgba(255,255,255,0.85);
  border-right: 1px solid rgba(255,255,255,0.07);
}
.ms-milestone-detail-header span:last-child { border-right: none; }
.ms-milestone-row {
  display: grid; grid-template-columns: 2fr 1fr 1.5fr 1fr 1fr 1fr;
  border-bottom: 1px solid #edf1fa; transition: background 0.12s;
}
.ms-milestone-row:hover { background: #f0f6ff; }
.ms-milestone-row:last-child { border-bottom: none; }
.ms-milestone-row span {
  padding: 8px 12px; font-size: 12px; color: var(--ms-text);
  border-right: 1px solid #f0f4fc; vertical-align: middle;
}
.ms-milestone-row span:last-child { border-right: none; }
.ms-milestone-list { border: 1px solid var(--ms-border); border-radius: 8px; overflow: hidden; }
.ms-milestone-loading {
  padding: 16px; text-align: center; color: var(--ms-muted);
  font-size: 12px; display: flex; align-items: center; justify-content: center; gap: 8px;
}

/* Empty state */
.ms-empty { text-align: center; padding: 44px 20px; }
.ms-empty .ms-empty-icon {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, rgba(45,125,210,0.1), rgba(45,125,210,0.05));
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12px; font-size: 20px; color: rgba(45,125,210,0.4);
}
.ms-empty p { font-size: 13px; color: var(--ms-muted); font-weight: 500; margin: 0; }

/* ── Filter FAB + Panel ── */
.ms-filter-fab {
  position: fixed; bottom: 28px; right: 24px; z-index: 400;
  display: flex; align-items: center; gap: 7px;
  padding: 10px 18px; border-radius: 30px;
  background: linear-gradient(135deg, var(--ms-blue), #1a60b8);
  color: #fff; font-size: 12.5px; font-weight: 700;
  border: none; cursor: pointer;
  box-shadow: 0 4px 18px rgba(45,125,210,0.45); transition: var(--ms-tr);
}
.ms-filter-fab:hover {
  background: linear-gradient(135deg, #3a8ae0, #2266cc);
  box-shadow: 0 6px 24px rgba(45,125,210,0.55); transform: translateY(-2px);
}
.ms-filter-panel {
  position: fixed; bottom: 80px; right: 24px; z-index: 410;
  background: #fff; border: 1px solid var(--ms-border);
  border-radius: 14px; padding: 16px;
  box-shadow: 0 12px 40px rgba(15,30,80,0.18);
  width: 260px; display: none;
  animation: dropIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
}
.ms-filter-panel.open { display: block; }
.ms-filter-panel label {
  font-size: 11px; font-weight: 700; color: var(--ms-muted);
  display: block; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px;
}
.ms-filter-panel input, .ms-filter-panel select {
  width: 100%; font-size: 12px; border: 1px solid var(--ms-border);
  border-radius: 7px; padding: 6px 10px; color: var(--ms-text);
  transition: var(--ms-tr); margin-bottom: 10px;
}
.ms-filter-panel input:focus, .ms-filter-panel select:focus {
  border-color: var(--ms-blue); outline: none;
  box-shadow: 0 0 0 3px rgba(45,125,210,0.12);
}
.ms-filter-panel-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;
}
.ms-filter-panel-header span { font-size: 12px; font-weight: 800; color: var(--ms-text); }
.ms-filter-panel-header button { background: none; border: none; cursor: pointer; color: var(--ms-muted); font-size: 15px; padding: 0; }

/* ── Scroll buttons ── */
.ms-scroll-btns {
  position: fixed; left: 24px; bottom: 28px; z-index: 400;
  display: flex; flex-direction: column; gap: 6px;
}
.ms-scroll-btn {
  width: 36px; height: 36px; border-radius: 50%;
  background: #fff; border: 1px solid var(--ms-border);
  color: var(--ms-blue); font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: var(--ms-tr);
  box-shadow: 0 2px 8px rgba(15,30,80,0.1);
}
.ms-scroll-btn:hover { background: var(--ms-blue); color: #fff; border-color: var(--ms-blue); transform: scale(1.08); }

/* ── Bulk action bar ── */
.ms-bulk-bar {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  background: #fff; border: 1px solid var(--ms-border);
  border-radius: 14px 14px 0 0;
  box-shadow: 0 -4px 24px rgba(15,30,80,0.12);
  padding: 10px 20px; display: flex; align-items: center; gap: 10px;
  z-index: 400; transition: var(--ms-tr);
}
.ms-bulk-bar.hidden { display: none; }
.ms-bulk-count {
  background: var(--ms-blue); color: #fff;
  border-radius: 20px; padding: 2px 9px;
  font-size: 11px; font-weight: 700;
}

/* ── Modal overrides ── */
.modal-content { border-radius: 14px !important; border: 1px solid var(--ms-border) !important; box-shadow: 0 12px 48px rgba(15,30,80,0.2) !important; overflow: hidden; }
.modal-header { background: linear-gradient(135deg, var(--ms-navy), var(--ms-navy2)) !important; border-bottom: none !important; padding: 14px 20px !important; }
.modal-title { color: #fff !important; font-size: 14px !important; font-weight: 700 !important; }
.modal-header .btn-close { filter: invert(1) !important; opacity: 0.6 !important; transition: opacity 0.15s !important; }
.modal-header .btn-close:hover { opacity: 1 !important; }
.modal-body { background: var(--ms-light) !important; padding: 18px 20px !important; }
.modal-footer { background: var(--ms-light) !important; border-top: 1px solid var(--ms-border) !important; padding: 12px 20px !important; }
.modal-footer .btn-primary { background: linear-gradient(135deg, var(--ms-blue), #1a60b8) !important; border: none !important; border-radius: 8px !important; font-weight: 600 !important; box-shadow: 0 2px 8px rgba(45,125,210,0.3) !important; }
.modal-footer .btn-secondary { border-radius: 8px !important; font-weight: 600 !important; }
.modal .form-control, .modal .form-select, .modal .form-floating .form-control { border-radius: 8px !important; border-color: var(--ms-border) !important; font-size: 12.5px !important; }
.modal .form-control:focus, .modal .form-select:focus { border-color: var(--ms-blue) !important; box-shadow: 0 0 0 3px rgba(45,125,210,0.12) !important; }
.modal .nav-tabs { border-bottom: 1px solid var(--ms-border) !important; }
.modal .nav-tabs .nav-link { font-size: 12.5px !important; font-weight: 600 !important; color: var(--ms-muted) !important; border: none !important; padding: 8px 14px !important; border-radius: 8px 8px 0 0 !important; }
.modal .nav-tabs .nav-link:hover { color: var(--ms-blue) !important; }
.modal .nav-tabs .nav-link.active { color: var(--ms-blue) !important; border-bottom: 2px solid var(--ms-blue) !important; background: rgba(45,125,210,0.06) !important; }
.modal .table thead { background: linear-gradient(135deg, rgba(45,125,210,0.12), rgba(45,125,210,0.06)) !important; }
.modal .table thead th { font-size: 10.5px !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.5px !important; color: var(--ms-muted) !important; background: transparent !important; border-bottom: 1px solid var(--ms-border) !important; padding: 9px 12px !important; }
.modal .table tbody tr { border-bottom: 1px solid #f0f4fc !important; }
.modal .table tbody tr:hover { background: #f7f9ff !important; }
.modal .table tbody td { font-size: 12px !important; padding: 8px 12px !important; }

/* ── Column action buttons ── */
.col-action-btn { width: 28px; height: 28px; border-radius: 8px; border: 1px solid var(--ms-border); background: #f8faff; cursor: pointer; display: flex; align-items: center; justify-content: center; position: relative; transition: all 0.2s cubic-bezier(0.34,1.56,0.64,1); }
.col-action-btn svg { transition: transform 0.2s; }
.col-select-btn:hover { background: #EAF3DE; border-color: #97C459; box-shadow: 0 0 0 3px rgba(99,153,34,0.15); transform: scale(1.12); }
.col-select-btn:hover svg { transform: scale(1.1); }
.col-unselect-btn:hover { background: #FCEBEB; border-color: #F09595; box-shadow: 0 0 0 3px rgba(226,75,74,0.15); transform: scale(1.12); }
.col-unselect-btn:hover svg { transform: scale(1.1); }
.col-btn-tip { position: absolute; bottom: -28px; left: 50%; transform: translateX(-50%); background: #1e2d45; color: #fff; font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 5px; white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.15s; z-index: 9999; }
.col-action-btn:hover .col-btn-tip { opacity: 1; }
</style>

<body>
<main class="ms-page">

<%
const bgMap = {
  "On Time":              "on-time",
  "Approaching Due Date": "approaching",
  "Due Today":            "due-today",
  "Delayed":              "delayed",
  "Escalation":           "escalation",
};
function dlvBadge(status) {
  if (!status) return '—';
  var cls = bgMap[status] || '';
  return '<span class="ms-delivery ' + cls + '"><i class="bi bi-circle-fill"></i>' + status + '</span>';
}
function statusBadge(s) {
  if (!s) return '<span class="ms-status">' + s + '</span>';
  var cls = s.toLowerCase().replace(/\s+.*/,'');
  return '<span class="ms-status ' + cls + '">' + s + '</span>';
}

let ytaCount = 0, ytsCount = 0, ongoingCount = 0, completedCount = 0;
const completedStatuses = ["Approved","Rejected","Reassigned","Cancel"];
const notOngoing = ["YTA","YTS","Approved","Rejected","Reassigned","Cancel"];
if(Object.values(Data).length > 0){
  for(let i=0; i<Object.values(Data).length; i++){
    const s = Data[i].Status;
    if(s === "YTA") ytaCount++;
    else if(s === "YTS") ytsCount++;
    else if(completedStatuses.includes(s)) completedCount++;
    else if(!notOngoing.includes(s)) ongoingCount++;
  }
}
const MainID = Customer === "AT&T" ? "CFAS_ID" : "JOB_ID";
%>

<!-- ── TOOLBAR ── -->
<div class="ms-toolbar">
  <div class="ms-toolbar-left">
    <div class="ms-page-title">
      <i class="bi bi-folder2-open"></i> Project List
    </div>
    <span class="customer-pill"><%= Customer %></span>

    <!-- Column toggle -->
    <div class="ms-field-selector" id="fieldSelector">
      <div class="ms-field-trigger" id="fieldTrigger">
        <i class="bi bi-layout-three-columns"></i> Columns
        <i class="bi bi-chevron-down" style="font-size:9px;"></i>
      </div>
      <div class="ms-field-panel" id="fieldPanel">
        <div class="ms-field-panel-header">
          <span>Show / Hide Columns</span>
          <div style="display:flex;gap:5px;">
            <button onclick="selectAllColumns()" class="col-action-btn col-select-btn" title="">
              <svg viewBox="0 0 16 16" fill="none" stroke="#639922" stroke-width="1.8" width="14" height="14">
                <rect x="1.5" y="1.5" width="5" height="5" rx="1.2"/>
                <rect x="9.5" y="1.5" width="5" height="5" rx="1.2"/>
