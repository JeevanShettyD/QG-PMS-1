<%- include('../partials/dependencies-js',{Notifications:Notifications}) %>
<script>
/* ══════════════════════════════════════
   PREVENT HEADER CARDS FROM CLOSING
   when clicking inside main page
══════════════════════════════════════ */
(function(){
  var mainEl = document.querySelector('main.ms-page');
  if(mainEl){
    mainEl.addEventListener('mousedown', function(e){
      var tag = e.target.tagName.toLowerCase();
      if(['a','button','input','select','label'].indexOf(tag) === -1){ e.stopPropagation(); }
    });
  }
})();

/* ══════════════════════════════════════
   TAB SWITCHING
══════════════════════════════════════ */
function switchTab(name, btn) {
  document.querySelectorAll('.ms-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.ms-tab-pane').forEach(function(p){ p.style.display = 'none'; });
  btn.classList.add('active');
  document.getElementById('pane-' + name).style.display = '';
}

/* ══════════════════════════════════════
   ROW EXPAND — fetch milestones on open
══════════════════════════════════════ */
function toggleDetail(toggleEl) {
  var dataRow   = toggleEl.closest('tr');
  var detailRow = dataRow.nextElementSibling;
  var icon      = toggleEl.querySelector('i');
  if(!detailRow || !detailRow.classList.contains('ms-detail-row')) return;

  var isHidden = (detailRow.style.display === 'none' || detailRow.style.display === '');
  detailRow.style.display = isHidden ? 'table-row' : 'none';
  icon.className = isHidden ? 'bi bi-dash-lg' : 'bi bi-plus-lg';
  toggleEl.style.background = isHidden ? 'var(--ms-blue)' : '';
  toggleEl.style.color      = isHidden ? '#fff' : '';

  if(isHidden){
    var loadingEl = detailRow.querySelector('[id^="ml-"]');
    var bodyEl    = detailRow.querySelector('[id^="mb-"]');
    if(!loadingEl || bodyEl.dataset.loaded) return;

    var jobLink = dataRow.querySelector('td:nth-child(2) a');
    if(!jobLink) return;
    var parts     = jobLink.getAttribute('href').split('/');
    var jobID     = parts[3];
    var idProject = parts[4];

    axios.get('/api/getMilestoneList', {
      params: { JOB_ID: jobID, idProjects: idProject, Customer: '<%- Customer %>' }
    }).then(function(res){
      loadingEl.style.display = 'none';
      var milestones = res.data.data;
      if(!milestones || milestones.length === 0){
        bodyEl.innerHTML = '<div class="ms-milestone-loading" style="color:var(--ms-muted)"><i class="bi bi-inbox me-2"></i>No milestones found</div>';
        bodyEl.style.display = 'block'; bodyEl.dataset.loaded = '1'; return;
      }
      var headerHtml = '<div class="ms-milestone-detail-header"><span>Milestone Name</span><span>Due Date</span><span>Owner</span><span>Submitted</span><span>Approved</span><span>Status</span></div>';
      var rowsHtml = milestones.map(function(m){
        return '<div class="ms-milestone-row">' +
          '<span><a href="/ViewMilestone/' + res.data.Customer + '/' + idProject + '/' + m.Milestone_Name + '">' + m.Milestone_Name + '</a></span>' +
          '<span>' + (m.Due_Date ? formatDate(m.Due_Date) : '—') + '</span>' +
          '<span>' + (m.Full_Name || '—') + '</span>' +
          '<span>' + (m.Submitted_Date ? formatDate(m.Submitted_Date) : '—') + '</span>' +
          '<span>' + (m.Approved_Date ? formatDate(m.Approved_Date) : '—') + '</span>' +
          '<span>' + (m.Milestone_Status || '—') + '</span>' +
        '</div>';
      }).join('');
      bodyEl.innerHTML = headerHtml + rowsHtml;
      bodyEl.style.display = 'block'; bodyEl.dataset.loaded = '1';
    }).catch(function(err){
      loadingEl.innerHTML = '<span style="color:#c02038;"><i class="bi bi-exclamation-circle me-1"></i>Error loading milestones</span>';
      console.error(err);
    });
  }
}

function formatDate(d){
  var dt = new Date(d);
  return (dt.getMonth()+1)+'/'+dt.getDate()+'/'+String(dt.getFullYear()).slice(-2);
}

/* ══════════════════════════════════════
   COLUMN SHOW / HIDE
   Uses CSS class names — immune to
   column-count differences across tabs.
   Completed has col-submitted; other
   tabs don't. The toggle just does
   nothing for that class on those tabs.
══════════════════════════════════════ */
(function(){
  // Each toggle class maps to the CSS column class it controls
  var colMap = {
    'col-sno-toggle':       'col-sno',
    'col-jobid-toggle':     'col-jobid',
    'col-jobname-toggle':   'col-jobname',
    'col-pasnumber-toggle': 'col-pasnumber',
    'col-sow-toggle':       'col-sow',
    'col-recvd-toggle':     'col-recvd',
    'col-due-toggle':       'col-due',
    'col-submitted-toggle': 'col-submitted',
    'col-owner-toggle':     'col-owner',
    'col-status-toggle':    'col-status',
    'col-delivery-toggle':  'col-delivery'
  };

  function applyCol() {
    Object.keys(colMap).forEach(function(toggleClass) {
      var cb = document.querySelector('.' + toggleClass);
      if (!cb) return;
      var show = cb.checked;
      document.querySelectorAll('.' + colMap[toggleClass]).forEach(function(cell) {
        cell.style.display = show ? '' : 'none';
      });
    });
  }

  document.querySelectorAll('.col-toggle').forEach(function(cb){
    cb.addEventListener('change', applyCol);
  });

  window.selectAllColumns = function(){
    document.querySelectorAll('.col-toggle').forEach(function(cb){ cb.checked = true; });
    applyCol();
  };
  window.unselectAllColumns = function(){
    document.querySelectorAll('.col-toggle').forEach(function(cb){ cb.checked = false; });
    applyCol();
  };
})();

/* Field panel toggle */
document.getElementById('fieldTrigger').addEventListener('click', function(e){
  e.stopPropagation();
  document.getElementById('fieldPanel').classList.toggle('open');
});
document.addEventListener('click', function(e){
  var fs = document.getElementById('fieldSelector');
  if(fs && !fs.contains(e.target)) document.getElementById('fieldPanel').classList.remove('open');
  var fp = document.getElementById('filterPanel');
  var ff = document.getElementById('filterFab');
  if(fp && ff && !fp.contains(e.target) && !ff.contains(e.target)) fp.classList.remove('open');
});

/* ══════════════════════════════════════
   COLUMN RESIZE
══════════════════════════════════════ */
(function(){
  var resizing = null, startX = 0, startW = 0;
  document.querySelectorAll('.col-resize-handle').forEach(function(h){
    h.addEventListener('mousedown', function(e){
      e.preventDefault(); resizing = h.parentElement; startX = e.pageX; startW = resizing.offsetWidth;
      document.body.style.cursor = 'col-resize'; document.body.style.userSelect = 'none';
    });
  });
  document.addEventListener('mousemove', function(e){
    if(!resizing) return;
    var nw = Math.max(60, startW + (e.pageX - startX));
    resizing.style.minWidth = nw + 'px'; resizing.style.width = nw + 'px';
  });
  document.addEventListener('mouseup', function(){
    if(resizing){ resizing = null; document.body.style.cursor = ''; document.body.style.userSelect = ''; }
  });
})();

/* ══════════════════════════════════════
   PURE JS COLUMN SORT
══════════════════════════════════════ */
(function(){
  document.querySelectorAll('.ms-table thead tr th').forEach(function(th){
    if(th.querySelector('.col-resize-handle') || th.querySelector('input')) return;
    th.addEventListener('click', function(){
      var tbl = th.closest('table'), idx = Array.from(th.parentElement.children).indexOf(th);
      var asc = th.dataset.sort !== 'asc';
      tbl.querySelectorAll('thead tr th').forEach(function(t){ t.dataset.sort = ''; });
      th.dataset.sort = asc ? 'asc' : 'desc';
      var rows = Array.from(tbl.querySelectorAll('tbody tr.ms-data-row'));
      rows.sort(function(a,b){
        var av = (a.cells[idx]||{}).textContent.trim();
        var bv = (b.cells[idx]||{}).textContent.trim();
        return asc ? av.localeCompare(bv,undefined,{numeric:true}) : bv.localeCompare(av,undefined,{numeric:true});
      });
      var tbody = tbl.querySelector('tbody');
      rows.forEach(function(row){
        var detail = row.nextElementSibling;
        tbody.appendChild(row);
        if(detail && detail.classList.contains('ms-detail-row')) tbody.appendChild(detail);
      });
    });
  });
})();

/* ══════════════════════════════════════
   FILTER PANEL
══════════════════════════════════════ */
document.getElementById('filterFab').addEventListener('click', function(){
  document.getElementById('filterPanel').classList.toggle('open');
});
document.getElementById('filterClose').addEventListener('click', function(){
  document.getElementById('filterPanel').classList.remove('open');
});

/* ══════════════════════════════════════
   BULK SELECTION + ORIGINAL FUNCTIONALITY
══════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', function(){
  var bulkBar = document.getElementById('bulkBar');
  var bulkCount = document.getElementById('bulkCount');
  var selectedRecords = [];

  function updateBulk(){
    selectedRecords.length = 0;
    document.querySelectorAll('.record-checkbox:checked').forEach(function(cb){
      selectedRecords.push(JSON.stringify({ Job: cb.value, ID: cb.getAttribute('data-id') }));
    });
    var count = selectedRecords.length;
    bulkCount.textContent = count;
    document.querySelectorAll('#ActiveCount').forEach(function(el){ el.innerText = count || ''; });
    bulkBar.classList.toggle('hidden', count === 0);
    document.getElementById('createMilestoneBarBtn').classList.toggle('visually-hidden', count === 0);
    if(count > 0){
      document.querySelectorAll('.job-id-container').forEach(function(container){
        container.innerHTML = '';
        selectedRecords.forEach(function(job, index){
          var t = JSON.parse(job);
          container.innerHTML += '<div class="d-flex align-items-center text-nowrap"><span>'+(index+1)+'-</span>' +
            '<input type="text" class="border-bottom bg-body-tertiary m-1" id="Project_ID" name="Project_ID" value="'+t.Job+'" readonly required>' +
            '<input type="hidden" name="ID" value="'+t.ID+'" readonly required></div>';
        });
      });
    }
  }

  ['yta','yts','ongoing','completed'].forEach(function(tab){
    var saEl = document.querySelector('.selectAll-' + tab);
    if(!saEl) return;
    saEl.addEventListener('change', function(){
      var pane = document.getElementById('pane-'+tab);
      if(pane) pane.querySelectorAll('.record-checkbox').forEach(function(cb){ cb.checked = saEl.checked; });
      updateBulk();
    });
  });

  document.querySelectorAll('.record-checkbox').forEach(function(cb){
    cb.addEventListener('change', updateBulk);
  });

  var params = getUrlParams();
  document.querySelectorAll('#filterPanel select').forEach(function(sel){
    for(var k in params){
      if(k === sel.name){ var opt = sel.querySelector('option[value="'+params[k]+'"]'); if(opt) opt.selected = true; }
    }
  });
  document.querySelectorAll('#filterPanel input[type="search"]').forEach(function(inp){
    for(var k in params){ if(k === inp.name) inp.value = params[k]; }
  });
});

/* ══════════════════════════════════════
   VIEW PROJECT (original function)
══════════════════════════════════════ */
function viewProject(id){
  axios.get('/api/projectInfo/<%= Customer %>', { params: { ID: id } }).then(function(res){
    var object = res.data.project[0];
    for(var key in object){
      if(!Object.prototype.hasOwnProperty.call(object, key)) continue;
      var element = object[key];
      try{
        if(key === 'Note'){
          var area = document.getElementById('Note');
          area.innerHTML = '<p><b>Comments</b></p>';
          element = JSON.parse(element);
          if(Object.keys(element).length){
            for(var group in element){
              var note = element[group], values = Object.values(note), attachmentName = values[4];
              area.innerHTML += '<div class="row m-1"><div class="col-sm-12"><p><small><span><i class="bi bi-person-fill"></i>&nbsp;'+values[3]+'</span> <b>|</b> <span><i class="bi bi-calendar3"></i>&nbsp;'+values[0]+'</span>'+(attachmentName?'<b> | </b><span><a href="../public/uploads/ReferenceDoc/'+attachmentName+'" class="text-decoration-none btn btn-outline-secondary border-0 btn-sm" download><i class="bi bi-paperclip"></i></a></span>':'')+'</small></p><p class="border comment-section p-2 m-0">'+values[1]+'</p></div></div>';
            }
          } else { area.innerHTML += '<div class="row m-1"><p class="mx-auto">No Comments</p></div>'; }
        } else if(key === 'idProjects'){
          document.getElementById('editButton').setAttribute('href', '/PMO/editProject/<%= Customer %>/'+object[key]);
        } else if(['ReceivedDate','DueDate','ApprovedDate','Owner'].includes(key)){
          /* skip */
        } else {
          if(key === 'JOB_ID'){ document.querySelectorAll('#JOB_ID').forEach(function(el){ el.innerText = element; }); }
          if(document.getElementById(key)) document.getElementById(key).innerText = element;
        }
      } catch(err){ console.log(err); }
    }
    var milestones = res.data.milestone, body = document.getElementById('milestoneBody');
    body.innerHTML = '';
    milestones.forEach(function(m, index){
      var row = body.insertRow(-1);
      row.insertCell(0).textContent = index+1;
      row.insertCell(1).innerHTML = '<a href="/ViewMilestone/<%= Customer %>/'+m.Milestone_Name+'">'+m.Milestone_Name+'</a>';
      row.insertCell(2).textContent = m.Prod_TGT_Start_Date;
      row.insertCell(3).textContent = m.Prod_ACT_Start_Date;
      row.insertCell(4).textContent = m.Prod_TGT_End_Date;
      row.insertCell(5).textContent = m.Prod_ACT_End_Date;
      row.insertCell(6).textContent = m.QC_TGT_Start_Date;
      row.insertCell(7).textContent = m.QC_ACT_Start_Date;
      row.insertCell(8).textContent = m.QC_TGT_End_Date;
      row.insertCell(9).textContent = m.QC_ACT_End_Date;
    });
  }).catch(function(err){ console.log(err); });
  $('#projectModal').modal('show');
}

/* Date validation — ORIGINAL UNCHANGED */
var Prod_TGT_Start_Date = document.getElementById('Prod_TGT_Start_Date');
var Prod_TGT_End_Date   = document.getElementById('Prod_TGT_End_Date');
var QC_TGT_Start_Date   = document.getElementById('QC_TGT_Start_Date');
var QC_TGT_End_Date     = document.getElementById('QC_TGT_End_Date');
[Prod_TGT_Start_Date, Prod_TGT_End_Date, QC_TGT_Start_Date, QC_TGT_End_Date].forEach(function(input){
  if(!input) return;
  input.addEventListener('change', function(){
    validateDate(Prod_TGT_Start_Date.value, Prod_TGT_End_Date.value, QC_TGT_Start_Date.value, QC_TGT_End_Date.value);
  });
});
function validateDate(PSDate, PEDate, QSDate, QEDate){
  if(PSDate && PEDate && QSDate && QEDate){
    if(!((new Date(PEDate)>=new Date(PSDate))&&(new Date(QEDate)>=new Date(QSDate))&&(new Date(QSDate)>=new Date(PEDate)))){
      Prod_TGT_Start_Date.value=''; Prod_TGT_End_Date.value='';
      QC_TGT_Start_Date.value=''; QC_TGT_End_Date.value='';
      toasts.push({title:'Error',content:'Please provide valid dates.',style:'error',dismissAfter:'10s'});
    }
  }
}

/* Status date toggle — ORIGINAL UNCHANGED */
var stEl = document.getElementById('ststus');
if(stEl){
  stEl.addEventListener('change', function(e){
    if(e.target.value==='Approved'||e.target.value==='Submitted - Awaiting Approval'){
      document.querySelector('.StatusDateContainer').classList.remove('visually-hidden');
      document.querySelector('#StatusDate').setAttribute('required','');
    } else {
      document.querySelector('.StatusDateContainer').classList.add('visually-hidden');
      document.querySelector('#StatusDate').removeAttribute('required');
    }
  });
}
</script>
