    <!-- ── Markup ── -->
    <div class="tab-pane fade" id="markup-tab-pane" role="tabpanel">
        <div class="section-card">
            <div class="section-card-header"><div class="section-card-title"><i class="bi bi-pencil-square"></i> Markup</div></div>
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead><tr><th>#</th><th>Markup Name</th><th>Task Name</th><th>Job ID</th><th>Owner</th><th>Start</th><th>End</th><th>Due</th><th>Status</th><th>Time</th><th>Delivery</th></tr></thead>
                    <tbody>
                        <% if (Object.values(markup).length>0) { %>
                        <% for(let index=0; index < Object.values(markup).length; index++) { %>
