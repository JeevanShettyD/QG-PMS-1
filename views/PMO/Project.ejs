                            <td><span class="Owner" style="max-width:140px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= Task[index].TaskLabel||'' %>"><%= Task[index].TaskLabel||'—' %></span></td>
