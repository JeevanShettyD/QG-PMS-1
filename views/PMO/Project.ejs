        for(let index=0; index < Object.values(Estimates).length; index++) {
            if(Estimates[index].Status!="Rejected" && Estimates[index].Status!="Credit"){
                TotalApproved += Estimates[index].Quantity * Estimates[index].UnitPrice;
                ApprovedQuantity += Estimates[index].Quantity;
                ApprovedUnitPrice += Estimates[index].UnitPrice;
                AmountReceived += Estimates[index]["Amount Received"];
            }
            if(Estimates[index].Status=="Invoiced"){ TotalInvoiced += Estimates[index].Quantity * Estimates[index].UnitPrice; }
            if(Estimates[index].Status=="Payment Received"){ TotalPaymentReceived += Estimates[index].Quantity * Estimates[index].UnitPrice; }
            if(Estimates[index].Status==="Rejected"){ RejectedTotal += Estimates[index].Quantity * Estimates[index].UnitPrice; RejectedQuantity += Estimates[index].Quantity; RejectedUnitPrice += Estimates[index].UnitPrice; }
        }
        for(let index=0; index < Object.values(MonthlyWorkdone).length; index++){
            TotalWorkDone += MonthlyWorkdone[index].Quantity * MonthlyWorkdone[index].UnitPrice;
        }
        function getIndianFinancialYearAndQuarter(dateString) {
            const date = new Date(new Date(dateString).toLocaleDateString("en-CA"));
            const year = date.getFullYear(); const month = date.getMonth() + 1;
            const fyStartYear = month >= 4 ? year : year - 1;
            const fyEndYear = fyStartYear + 1;
            const financialYear = `FY ${fyStartYear}-${fyEndYear}`;
            let quarter = "";
            if (month >= 4 && month <= 6) quarter = "Q1";
            else if (month >= 7 && month <= 9) quarter = "Q2";
            else if (month >= 10 && month <= 12) quarter = "Q3";
            else quarter = "Q4";
            return financialYear + "/" + quarter;
        }
