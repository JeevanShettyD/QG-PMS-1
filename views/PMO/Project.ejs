            <div class="section-card-header">
                <div class="section-card-title">
                    <i class="bi bi-check2-circle"></i> Work Done
                    <%if(userData.Designation=="Head-OSP Design" && userData.Role=="PMO"){%>
                    <span class="pill-summary pill-revenue ms-2">Revenue: <strong>$<%=parseFloat(TotalWorkDone).toFixed(2)%></strong></span>
                    <%}%>
                </div>
                <div class="section-card-actions <%= userData.Role!='PMO' ? 'visually-hidden' : '' %>">
                    <button type="button" class="btn-card-action visually-hidden" id="moveToEstimateBtn"><i class="bi bi-chevron-double-up"></i> Move to Estimates</button>
                    <% if (Object.values(MonthlyWorkdone).length>0) { %>
                    <a href="/api/downloadWorkDone/?WD_Customer=<%= encodeURIComponent(Customer) %>&WD_Program=<%= encodeURIComponent(ProjectData.Program) %>&Job_ID=<%= encodeURIComponent(ProjectData.CFAS_ID?ProjectData.CFAS_ID:ProjectData.JOB_ID) %>&idProjects=<%=encodeURIComponent(ProjectData.idProjects)%>" class="btn-card-action"><i class="bi bi-cloud-arrow-down-fill"></i> Export</a>
                    <%}%>
                    <button class="btn-card-action" data-bs-toggle="modal" data-bs-target="#WorkDoneDialog"><i class="bi bi-plus-circle"></i> Add</button>
                </div>
            </div>
