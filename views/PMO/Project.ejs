                            <td class="text-nowrap"><a href="/ViewTask/<%= subtask[index].Customer %>/<%= subtask[index].Milestone_Name %>/<%= subtask[index].Task_Name %>"><%= subtask[index].Task_Name %></a></td>
                            <td class="text-nowrap"><span class="Owner" style="max-width:110px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" data-UserID="<%= subtask[index].Owner %>"><%= subtask[index].Full_Name %></span></td>
