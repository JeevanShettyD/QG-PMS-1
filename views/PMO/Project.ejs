                            <td><%= Milestone[index].Milestone_Status||'—' %></td>
                            <td><%- deliveryBadge(mTemp) %></td>
                        </tr>
                        <% } %>
                        <% }else{ %><tr><td colspan="14" class="text-center py-4 text-muted">No milestones found</td></tr><% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

