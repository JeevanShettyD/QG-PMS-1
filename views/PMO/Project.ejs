                <%const noOfYes = MonthlyWorkdone.filter(item => item.MovedToEstimate == "No");%>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th><%if(noOfYes.length>1){%><input type="checkbox" name="WD-Select-All" id="WD-Select-All" class="form-check-input"><%}%></th>
                            <th>#</th><th>Item</th><th>Region</th><th>UOM</th><th>Description</th><th>QTY</th><th>Accounted Month</th>
                            <%if(userData.Designation=="Head-OSP Design" && userData.Role=="PMO"){%><th>Unit Price</th><th>Total Revenue</th><%}%>
                        </tr>
                    </thead>
                    <tbody>
                        <% slNo=1; for(let index=0; index < Object.values(MonthlyWorkdone).length; index++) {
                            let dots = MonthlyWorkdone[index].Description.substring(0,13).length > 12 ? "..." : "";
                        %>
                        <tr class="<% if(parseInt(MonthlyWorkdone[index].Quantity)<0){%>negative-qty<%}%>">
                            <td><% if(MonthlyWorkdone[index].MovedToEstimate==="No"){%><input type="checkbox" name="WD-Select" id="WD-Select-<%=slNo%>" class="WD-row-check form-check-input" data-id="<%=MonthlyWorkdone[index].idmonthlyworkdone%>" data-code="<%=MonthlyWorkdone[index].Item%>" data-qty="<%=MonthlyWorkdone[index].Quantity%>"><%}else{%><i class="bi bi-lock-fill text-muted"></i><%}%></td>
                            <td><%=slNo++%></td>
                            <td style="font-family:'DM Mono',monospace;font-size:11.5px;"><%=MonthlyWorkdone[index].Item%></td>
                            <td><%=MonthlyWorkdone[index].Region%></td>
                            <td><%=MonthlyWorkdone[index].UOM%></td>
                            <td title="<%=MonthlyWorkdone[index].Description%>"><%=MonthlyWorkdone[index].Description.substring(0,60)+dots%></td>
                            <td><%=MonthlyWorkdone[index].Quantity%></td>
                            <td><%=MonthlyWorkdone[index].month_year%></td>
                            <%if(userData.Designation=="Head-OSP Design" && userData.Role=="PMO"){%>
                            <td>$<%=parseFloat(MonthlyWorkdone[index].UnitPrice).toFixed(2)%></td>
                            <td>$<%=parseFloat(MonthlyWorkdone[index].Quantity*MonthlyWorkdone[index].UnitPrice).toFixed(2)%></td>
                            <%}%>
                        </tr>
                        <%}%>
                    </tbody>
                </table>
            </div>
            <%}else{%>
            <div class="empty-state"><i class="bi bi-check2-circle text-muted" style="font-size:40px;"></i><p>No work done records found</p></div>
            <%}%>
        </div>

        <!-- Comments -->
        <div class="section-card">
            <div class="section-card-header">
                <div class="section-card-title"><i class="bi bi-chat-dots"></i> Comments</div>
                <button class="btn-card-action" type="button" data-bs-toggle="modal" data-bs-target="#AddNoteDialog" id="AddNoteBtn"><i class="bi bi-plus-circle"></i> Add</button>
            </div>
            <div id="NoteArea">
                <% if (Object.keys(Comments).length) { %>
                <% Object.keys(Comments).forEach(function(groupKey) { %>
                <div class="comment-item">
                    <div class="comment-meta">
                        <span class="comment-author"><i class="bi bi-person-fill"></i> <%= Comments[groupKey].Author_Name %></span>
                        <span class="comment-date"><i class="bi bi-calendar3"></i> <%= Comments[groupKey].On %></span>
                        <% for (const key in Comments[groupKey]) { %>
                            <% if (key.startsWith('attachment') && Comments[groupKey][key]!='') { %>
                            <a href="/public/uploads/ReferenceDoc/<%= Comments[groupKey][key] %>" download class="text-decoration-none" style="font-size:12px;color:var(--text-muted);"><i class="bi bi-paperclip"></i></a>
                            <% } %>
                        <% } %>
                        <% if(userData.Employee_ID==Comments[groupKey].Author_ID) { %>
                        <i class="bi bi-trash3-fill deleteBtn" style="color:var(--danger);cursor:pointer;font-size:13px;" data-project-id="<%= ProjectData.idProjects %>" data-comment-id="<%= groupKey %>" data-customer="<%= Customer %>"></i>
                        <% } %>
                    </div>
                    <% for (const key in Comments[groupKey]) { %>
                        <% if (key.startsWith('Note')) { %>
                        <div class="comment-body <%= userData.Employee_ID==Comments[groupKey].Author_ID ? 'owner-comment' : '' %>"><%- Comments[groupKey][key] %></div>
                        <% } %>
                    <% } %>
                </div>
                <% }); %>
                <% }else{ %>
                <div class="empty-state"><img src="../../../static/images/co-workers-animate.svg" alt="No Comments" width="220"><p>No comments yet</p></div>
                <%}%>
            </div>
        </div>
    </div>

    <!-- ── Milestone ── -->
    <div class="tab-pane fade" id="milestone-tab-pane" role="tabpanel">
        <div class="section-card">
            <div class="section-card-header">
