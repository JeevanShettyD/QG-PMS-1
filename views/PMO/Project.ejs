                            <td class="text-nowrap"><%= Milestone[index].Prod_ACT_Start_Date||'—' %></td>
                            <td class="text-nowrap"><%= Milestone[index].Prod_ACT_End_Date||'—' %></td>
                            <td class="text-nowrap"><%= Milestone[index].QC_TGT_Start_Date||'—' %></td>
                            <td class="text-nowrap"><%= Milestone[index].QC_TGT_End_Date||'—' %></td>
