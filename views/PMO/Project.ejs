<%- include('../partials/dependencies-js',{Notifications:Notifications}) %>
<script src="/static/js/CreateProject.js"></script>
<script>
$(document).ready(function () {
    $(".QC_Due_Date_Container").hide();
    $("#ScoreContainer").hide();
    $('input[type="radio"][name="autoQC"]').on('click', function () {
        if ($(this).val() === '1') { $('.QC_Due_Date_Container').show(); $('#QC_Due_Date').attr('required', true); }
        else { $('.QC_Due_Date_Container').hide(); $('#QC_Due_Date').attr('required', false); }
    });
    $('input[type="radio"][name="ScoreRadio"]').on('click', function () {
        if ($(this).val() === '1') { $('#ScoreContainer').show(); $('#Score').attr('required', true); $('#Score').val(null); }
        else { $('#ScoreContainer').hide(); $('#Score').attr('required', false); $('#Score').val("Not-Scored"); }
    });
    $("#Score").change(function(){ if(parseFloat($(this).val())>=100){ alert("Customer Score can't exceed 100%."); $(this).val(null); } });

    let Customer="<%- Customer %>";
    let Project_ID='<%= ProjectData.JOB_ID?ProjectData.JOB_ID:ProjectData.CFAS_ID %>';
    let ID='<%=ProjectData.idProjects%>';
    setInterval(()=>{ socket.emit("getAllActiveStatus",{Project:Project_ID,Customer:Customer,ResponseFor:"Project",idProjects:ID}); },2000);

    const datalist = document.getElementById('item-list');
    const region = document.getElementById('Region');
    const input = document.getElementById('Item');
    input.addEventListener('blur', function () {
        const temp=region.value; const value=input.value.trim().toLowerCase();
        const normalizedOptions=Array.from(datalist.options).map(o=>o.value.toLowerCase());
        if (!normalizedOptions.includes(value)) { input.value=''; document.getElementById("AddEstimate").reset(); region.value=temp; }
    });
    let isEstimatesItemChanged=false;
    input.addEventListener('change', async function () {
        const temp=region.value; const value=input.value.trim().toLowerCase();
        const normalizedOptions=Array.from(datalist.options).map(o=>o.value.toLowerCase());
        if (!normalizedOptions.includes(value)) { input.value=''; document.getElementById("AddEstimate").reset(); region.value=temp; alert("Invalid Labor Code for the selected project."); }
        else {
            await axios.get("/api/getRateCardInfo",{params:{Item:input.value,Region:region.value}}).then(res=>{
                const {Description,UOM,idratecard}=res.data;
                document.getElementById("Description").value=Description; document.getElementById("UOM").value=UOM; document.getElementById("idratecard").value=idratecard; isEstimatesItemChanged=true;
            }).catch(er=>{ if(er.response.data=="Not Found") alert("Oops! We couldn't find that code in our system."); else { alert("Something Went Wrong, Try Again..!"); console.log(er); } document.getElementById("AddEstimate").reset(); });
        }
    });
    document.querySelector("#AddEstimate #Region").addEventListener('change',function(){ if(isEstimatesItemChanged){ document.getElementById("AddEstimate").reset(); isEstimatesItemChanged=false; } });

    let isWorkDoneItemChanged=false;
    document.getElementById("WD_Item").addEventListener('change',async function(e){
        const temp=document.querySelector("#AddWorkDone #Region").value;
        const value=document.querySelector("#AddWorkDone #WD_Item").value.trim().toLowerCase();
        const normalizedOptions=Array.from(document.querySelector("#AddWorkDone #WD_item-list").options).map(o=>o.value.toLowerCase());
        if (!normalizedOptions.includes(value)) { e.target.value=''; document.getElementById("AddWorkDone").reset(); region.value=temp; alert("Invalid Labor Code for the selected project."); }
        else {
            await axios.get("/api/getRateCardInfo",{params:{Item:e.target.value,Region:temp}}).then(res=>{
                const {Description,UOM,idratecard}=res.data;
                document.querySelector("#AddWorkDone #Description").value=Description; document.querySelector("#AddWorkDone #UOM").value=UOM; document.querySelector("#AddWorkDone #idratecard").value=idratecard; isWorkDoneItemChanged=true;
            }).catch(er=>{ if(er.response.data=="Not Found") alert("Oops! We couldn't find that code in our system."); else { alert("Something Went Wrong, Try Again..!"); console.log(er); } document.getElementById("AddWorkDone").reset(); });
        }
    });
    document.querySelector("#AddWorkDone #Region").addEventListener('change',function(){ if(isWorkDoneItemChanged){ document.getElementById("AddWorkDone").reset(); isWorkDoneItemChanged=false; } });

    const estimatesTriggerBtn=document.querySelectorAll(".estimatesTriggerBtn");
    let estimateApproveDate=null, estimateInvoicedDate=null, estimateInvoicedNumber=null;
    let estimatePaymentDate=null, estimateAmountReceived=null, estimateRejectedDate=null, estimateRejectedComment=null;
    let estimatesID=null, Action=null, TotalAmount=0;

    document.getElementById("estimateApproveDate").addEventListener("change",(e)=>{ estimateApproveDate=e.target.value; });
    document.getElementById("estimateInvoicedDate").addEventListener("change",(e)=>{ estimateInvoicedDate=e.target.value; });
    let isInvoiceExist=false, existingInvoicePath=null;
    document.getElementById("estimateInvoicedNumber").addEventListener("change",async(e)=>{
        isInvoiceExist=false;
        if(e.target.value.length>14){
            const invDetails=await axios.get("/api/getInvoice",{params:{invNo:e.target.value}});
            if(invDetails.status==200){
                isInvoiceExist=true; estimateInvoicedDate=invDetails.data.invDate; existingInvoicePath=invDetails.data.invoicePath;
                document.getElementById("estimateInvoicedDate").value=invDetails.data.invDate;
                document.getElementById("estimateInvoicedDate").setAttribute("disabled","");
                document.getElementById("invoiceFile").setAttribute("disabled",""); document.getElementById("invoiceFile").classList.add("visually-hidden");
                document.querySelector("label[for='invoiceFile']").classList.add("visually-hidden");
                document.getElementById("existingInvoice").setAttribute("href",invDetails.data.invoicePath); document.getElementById("existingInvoice").classList.remove("visually-hidden");
                document.getElementById("invMessage").classList.remove("visually-hidden");
            }else{
                isInvoiceExist=false; estimateInvoicedDate=null; existingInvoicePath=null;
                document.getElementById("estimateInvoicedDate").value=null; document.getElementById("estimateInvoicedDate").removeAttribute("disabled");
                document.getElementById("invMessage").classList.add("visually-hidden");
                document.getElementById("invoiceFile").removeAttribute("disabled"); document.getElementById("invoiceFile").classList.remove("visually-hidden");
                document.querySelector("label[for='invoiceFile']").classList.remove("visually-hidden");
                document.getElementById("existingInvoice").classList.add("visually-hidden"); document.getElementById("existingInvoice").setAttribute("href","#");
            }
        }
        estimateInvoicedNumber=e.target.value;
    });
    document.getElementById("estimatePaymentDate").addEventListener("change",(e)=>{ estimatePaymentDate=e.target.value; });
    document.getElementById("estimateRejectedDate").addEventListener("change",(e)=>{ estimateRejectedDate=e.target.value; });
    document.getElementById("estimateRejectedComment").addEventListener("change",(e)=>{ estimateRejectedComment=e.target.value; });

    document.getElementById("PaymentReceivedDialog").addEventListener('show.bs.modal',async event=>{
        const button=event.relatedTarget;
        const recipient=button.getAttribute('data-totalRevenue');
        const estID=button.dataset.estimatesid;
        const estDetails=await axios.get("/api/getEstimateDetails",{params:{Estimates_ID:estID}});
        const container=document.querySelector(".estimatesConfirmationContainer");
        container.innerHTML="";
        const header=["Sl.No","Item","Total Qty","Received Qty","Payment Received"];
        const headRow=document.createElement("div");
        headRow.classList.add("row","rounded","bg-primary","bg-gradient","border","m-1","fw-bold","text-light");
        header.forEach((text,index)=>{ const col=document.createElement("div"); col.className=`p-2 ${["col-2","col-3","col-2","col-2","col-3"][index]}`; col.textContent=text; headRow.appendChild(col); });
        container.appendChild(headRow);
        estDetails.data.forEach((estimate,index)=>{
            const div=document.createElement("div");
            div.classList.add("border","rounded","row","m-1","estimate-row","bg-gradient","bg-light","align-items-center");
            div.dataset.id=estimate.idestimates; div.dataset.totalQty=estimate.Quantity; div.dataset.totalValue=estimate.TotalValue;
            div.innerHTML=`<div class="col-2 p-2">${index+1}</div><div class="col-3 p-2">${estimate.Item}</div><div class="col-2 p-2">${parseFloat(estimate.Quantity).toFixed(2)}</div><div class="col-2 p-2"><input class="form-control form-control-sm bg-white border received-qty" type="number" min="1" value="${parseFloat(estimate.Quantity).toFixed(2)}" readonly><div class="valid-feedback qty-valid-msg"></div><div class="invalid-feedback qty-invalid-msg"></div></div><div class="col-3 p-2 input-group w-25"><span class="input-group-text px-2 py-1">$</span><input class="form-control form-control-sm bg-white border received-amount" type="number" min="1" value="${estimate.TotalValue}"><div class="valid-feedback amount-valid-msg"></div><div class="invalid-feedback amount-invalid-msg"></div></div>`;
            container.appendChild(div);
        });
        TotalAmount=parseFloat(recipient).toFixed(2);
        if(document.getElementById("TotalPaymentReceivedLabel")) document.getElementById("TotalPaymentReceivedLabel").innerText=TotalAmount;
        document.querySelectorAll(".received-amount").forEach(amountInput=>{
            amountInput.addEventListener("input",(e)=>{
                const col=e.target.closest(".col-3"); const Qty=col.parentElement.dataset.totalQty; const TotalValue=col.parentElement.dataset.totalValue; const unitPrice=TotalValue/Qty;
                const qtyInput=col?.previousElementSibling?.querySelector(".received-qty")||col?.nextElementSibling?.querySelector(".received-qty");
                if(qtyInput) qtyInput.value=e.target.value/unitPrice;
            });
        });
    });

    function collectAndValidate(){
        const rows=document.querySelectorAll(".estimate-row"); const errors=[], partials=[], payload=[];
        rows.forEach((row,index)=>{
            const inputQty=row.querySelector(".received-qty"), inputAmount=row.querySelector(".received-amount");
            const invalidQtyMsg=row.querySelector(".qty-invalid-msg"), validQtyMsg=row.querySelector(".qty-valid-msg");
            const invalidAmountMsg=row.querySelector(".amount-invalid-msg"), validAmountMsg=row.querySelector(".amount-valid-msg");
            const totalQty=Number(row.dataset.totalQty), totalValue=Number(row.dataset.totalValue);
            let receivedQty=Number(inputQty.value), receivedAmount=Number(inputAmount.value);
            inputQty.classList.remove("is-invalid","is-valid"); validQtyMsg.textContent=""; invalidQtyMsg.textContent="";
            inputAmount.classList.remove("is-invalid","is-valid"); validAmountMsg.textContent=""; invalidAmountMsg.textContent="";
            if(isNaN(receivedQty)) receivedQty=1;
            if(receivedQty<1){ errors.push(`Row ${index+1}: Qty must be > 0`); inputQty.classList.add("is-invalid"); invalidQtyMsg.textContent="Qty must be > 0"; return; }
            if(receivedAmount<1){ errors.push(`Row ${index+1}: Amount cannot be Zero/Negative`); inputAmount.classList.add("is-invalid"); invalidAmountMsg.textContent="Amount cannot be Zero/Negative"; return; }
            if(receivedQty>totalQty){ errors.push(`Row ${index+1}: Received qty exceeds total`); inputQty.classList.add("is-invalid"); invalidQtyMsg.textContent="Received qty exceeds total"; inputAmount.classList.add("is-invalid"); invalidAmountMsg.textContent="Received amount exceeds total value."; return; }
            if((receivedQty<totalQty)||(receivedAmount<totalValue)){ partials.push({id:row.dataset.id,Item:row.children[1].textContent,receivedQty,totalQty,totalValue}); inputQty.classList.add("is-invalid"); invalidQtyMsg.textContent="Partial Payment"; inputAmount.classList.add("is-invalid"); invalidAmountMsg.textContent="Partial Payment"; payload.push({id:row.dataset.id,receivedQty,totalQty,isPartial:true,pendingQty:totalQty-receivedQty}); return; }
            inputQty.classList.add("is-valid");
            payload.push({id:row.dataset.id,receivedQty,totalQty,isPartial:false});
        });
        return {errors,partials,payload};
    }

    let isPartialPaymentConfirmed=false;
    document.querySelectorAll(".estimateSubmitBtn").forEach(btn=>{
        btn.addEventListener("click",(e)=>{
            if(Action==="Reserved"||Action==="Bulk-Reserved"){
                if(!estimateApproveDate){ alert("Please fill all fields."); return; }
                axios.post("/api/updateEstimates",{ID:estimatesID,Action:Action,ApprovedDate:estimateApproveDate}).then(res=>{ window.location.reload(); }).catch(er=>{ console.log(er); toasts.push(er.response.data); });
            }
            if(Action==="Invoiced"||Action==="Bulk-Invoiced"){
                const pattern=/^[A-Z]{4}\/\d{2}-\d{2}\/\d{4}$/; const invoiceFile=document.getElementById("invoiceFile");
                if(invoiceFile.files.length===0 && isInvoiceExist==false){ alert('Please select an Invoice before submitting.'); return; }
                if(!estimateInvoicedDate||!estimateInvoicedNumber||!pattern.test(estimateInvoicedNumber)){ alert("Kindly fill all fields in the required format."); return; }
                const formData=new FormData();
                formData.append("ID",estimatesID); formData.append("Action",Action); formData.append("Invoice_Number",estimateInvoicedNumber); formData.append("Invoiced_Date",estimateInvoicedDate);
                if(isInvoiceExist) formData.append("invoicePath",existingInvoicePath);
                formData.append("invoicePdf",invoiceFile.files[0]);
                axios.post("/api/updateEstimates",formData).then(res=>{ window.location.reload(); }).catch(er=>{ console.log(er); toasts.push(er.response.data); });
            }
            if(Action==="Rejected"||Action==="Bulk-Rejected"){
                if(!estimateRejectedComment&&!estimateRejectedDate){ alert("Please fill all fields."); return; }
                axios.post("/api/updateEstimates",{ID:estimatesID,Action:Action,Rejection_Comment:estimateRejectedComment,Rejected_Date:estimateRejectedDate}).then(res=>{ window.location.reload(); }).catch(er=>{ console.log(er); toasts.push(er.response.data); });
            }
            if(Action==="Payment Received"||Action==="Bulk-Payment-Received"){
                if(!estimatePaymentDate){ alert("Please fill all mandatory fields..."); return; }
                const{errors,partials,payload}=collectAndValidate();
                if(errors.length) return;
                if(partials.length){
                    const tbody=document.getElementById("partialLineItemsBody"); tbody.innerHTML="";
                    partials.forEach((item,index)=>{ const unitPrice=item.totalValue/item.totalQty; const tr=document.createElement("tr"); tr.innerHTML=`<td>${index+1}</td><td>${item.Item}</td><td>${parseFloat(item.totalQty).toFixed(2)}</td><td>${parseFloat(item.totalValue).toFixed(2)}</td><td>${parseFloat(item.receivedQty).toFixed(2)}</td><td>${parseFloat(item.receivedQty*unitPrice).toFixed(2)}</td><td>${parseFloat(item.totalQty-item.receivedQty).toFixed(2)}</td><td>${parseFloat((item.totalQty-item.receivedQty)*unitPrice).toFixed(2)}</td>`; tbody.appendChild(tr); });
                    const modal=bootstrap.Modal.getOrCreateInstance(document.getElementById("partialPaymentModal")); modal.show();
                }
                if(partials.length&&isPartialPaymentConfirmed){
                    axios.post("/api/updateEstimates",{ID:estimatesID,Action:Action,Amount_Received:estimateAmountReceived,Payment_Received_Date:estimatePaymentDate,partialPayment:payload}).then(res=>{ window.location.reload(); }).catch(er=>{ console.log(er); toasts.push(er.response.data); });
                }else if(partials.length==0){
                    axios.post("/api/updateEstimates",{ID:estimatesID,Action:Action,Amount_Received:estimateAmountReceived,Payment_Received_Date:estimatePaymentDate}).then(res=>{ window.location.reload(); }).catch(er=>{ console.log(er); toasts.push(er.response.data); });
                }
            }
        });
    });
    estimatesTriggerBtn.forEach(button=>{ button.addEventListener("click",(e)=>{ Action=e.target.getAttribute("data-action"); estimatesID=e.target.getAttribute("data-estimatesId"); }); });
    document.getElementById("confirmPartialPayment").addEventListener("click",()=>{ isPartialPaymentConfirmed=true; document.getElementById("estimateSubmitBtn3").click(); });

    let ProjectDueDate=('<%= ProjectData.DueDate %>');
    let ProjectReceivedDate=('<%= ProjectData.ReceivedDate %>');
    var Prod_TGT_Start_Date=document.getElementById('Prod_TGT_Start_Date');
    var Prod_TGT_End_Date=document.getElementById('Prod_TGT_End_Date');
    var QC_TGT_Start_Date=document.getElementById('QC_TGT_Start_Date');
    var QC_TGT_End_Date=document.getElementById('QC_TGT_End_Date');
    var Milestone_Due_Date=document.getElementById('Due_Date');
    [Prod_TGT_Start_Date,Prod_TGT_End_Date,QC_TGT_Start_Date,QC_TGT_End_Date,Milestone_Due_Date].forEach(input=>{
        input.addEventListener('change',()=>{ validateDate(Milestone_Due_Date.value,Prod_TGT_Start_Date.value,Prod_TGT_End_Date.value,QC_TGT_Start_Date.value,QC_TGT_End_Date.value); });
    });
    function validateDate(MDueDate,PSDate,PEDate,QSDate,QEDate){
        if(MDueDate&&PSDate&&PEDate&&QSDate&&QEDate){
            if(!(new Date(QEDate)>=new Date(ProjectReceivedDate))&&(new Date(MDueDate)>=new Date(ProjectReceivedDate))&&(new Date(QEDate)>=new Date(QSDate))&&(new Date(QSDate)>=new Date(PEDate))&&(new Date(PEDate)>=new Date(PSDate))&&(new Date(PSDate)>=new Date(ProjectReceivedDate))){
                Prod_TGT_Start_Date.value=""; Prod_TGT_End_Date.value=""; QC_TGT_Start_Date.value=""; QC_TGT_End_Date.value=""; Milestone_Due_Date.value="";
                toasts.push({title:"Error",content:"Invalid dates.\nPlease provide dates on or after "+ProjectReceivedDate,style:"error",dismissAfter:'5s'});
            }
        }
    }

    const tgt=document.getElementById("createMilestoneForm");
    tgt.querySelector("#Milestone_Name").addEventListener("change",function(){
        if(this.value=="Permit"&&this.getAttribute("data-customer")=="AT&T") document.getElementById("PermitInfoContainer").classList.remove("visually-hidden");
        else document.getElementById("PermitInfoContainer").classList.add("visually-hidden");
    });

    $("#requiredQC").change(function(){
        if($(this).is(":checked")==false){
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Name").removeAttribute("required");
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Name").value=null;
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Name").parentElement.parentElement.classList.add("visually-hidden");
            document.getElementsByName("autoQC").forEach(e=>{ e.setAttribute("disabled",""); });
            document.getElementById("autoQC2").setAttribute("checked","checked");
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Due_Date").parentElement.parentElement.classList.add("visually-hidden");
            $('#QC_Due_Date').attr('required',false);
        }else{
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Name").setAttribute("required","");
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Name").parentElement.parentElement.classList.remove("visually-hidden");
            document.getElementById("create-Prot-Task-Modal").querySelector("#QC_Due_Date").parentElement.parentElement.classList.remove("visually-hidden");
            document.getElementsByName("autoQC").forEach(e=>{ e.removeAttribute("disabled"); });
            document.getElementById("autoQC2").removeAttribute("checked");
        }
    });

    document.addEventListener('DOMContentLoaded',function(){
        syncArchiveButton();
        const selectAllCheckbox=document.getElementById('selectAll');
        const recordCheckboxes=document.querySelectorAll('.record-checkbox');
        const selectedRecords=[];
        function updateSelectedRecords(){
            selectedRecords.length=0;
            recordCheckboxes.forEach(checkbox=>{ if(checkbox.checked) selectedRecords.push(checkbox.value); });
            if(selectedRecords.length==0) document.getElementById("zipDownload").classList.add("visually-hidden");
            else document.getElementById("zipDownload").classList.remove("visually-hidden");
        }
        if(selectAllCheckbox){ selectAllCheckbox.addEventListener('change',function(){ const isChecked=this.checked; recordCheckboxes.forEach(cb=>{ cb.checked=isChecked; }); updateSelectedRecords(); }); }
        if(recordCheckboxes){ recordCheckboxes.forEach(cb=>{ cb.addEventListener('change',function(){ if(!this.checked){ selectAllCheckbox.checked=false; }else{ let all=true; recordCheckboxes.forEach(c=>{ if(!c.checked) all=false; }); if(all) selectAllCheckbox.checked=true; } updateSelectedRecords(); }); }); }
        document.getElementById("zipDownload").addEventListener("click",()=>{
            if(selectedRecords.length){
                axios.post("/api/DocumentCenter/download",{params:{FileID:selectedRecords}},{responseType:'blob'}).then(res=>{
                    const url=window.URL.createObjectURL(new Blob([res.data],{type:'application/zip'})); const link=document.createElement('a'); link.href=url; link.setAttribute('download','files.zip'); document.body.appendChild(link); link.click(); document.body.removeChild(link);
                }).catch(er=>{ console.log(er); });
            }
        });
    });

    document.querySelector("#createQCTaskForm").querySelector("#Milestone_Name").addEventListener("change",(e)=>{
        if(e.target.value){
            axios.get("/api/GetValidProdTask",{params:{Milestone_Name:e.target.value}}).then(result=>{
                const selectBox=document.getElementById('Prod_Task'); selectBox.innerHTML='<option value="">Select a Production Task</option>';
                result.data.forEach(task=>{ const option=document.createElement('option'); option.value=task.TaskName; option.textContent=task.TaskName+" - "+task.TaskLabel; selectBox.appendChild(option); });
            }).catch(er=>{ console.log(er); alert("error"); });
        }
    });

    document.querySelector("#createMilestoneModal").querySelector("#Milestone_Name").addEventListener("change",async(e)=>{
        if(e.target.value){
            const Project_ID=document.querySelector("#createMilestoneModal").querySelector("#Project_ID").value;
            const idProject=document.querySelector("#createMilestoneModal").querySelector("#ID").value;
            axios.get("/api/checkMilestoneExisting",{params:{Milestone_Name:e.target.value,Project_ID:Project_ID,idProject:idProject}}).then(res=>{
                const container=document.getElementById("Billing_Category_Container");
                if(res.data===true){ container.classList.remove("visually-hidden"); container.parentElement.classList.add("justify-content-between"); container.querySelectorAll("input[type='radio']").forEach(el=>{ el.setAttribute("required",""); }); }
                else{ container.parentElement.classList.remove("justify-content-between"); container.classList.add("visually-hidden"); container.querySelectorAll("input[type='radio']").forEach(el=>{ el.removeAttribute("required",""); }); }
                if(res.data===false){ toasts.push({title:"Error",content:`${e.target.value} milestone is already open, new creation isn't allowed.`,style:"error",dismissAfter:'5s'}); e.target.value=null; }
            }).catch(er=>{ console.log(er); });
        }
    });

    let selected=[], consolidated;
    const WDSelectAll=document.getElementById("WD-Select-All");
    const WDRowChecks=document.querySelectorAll(".WD-row-check");
    WDSelectAll?.addEventListener("change",function(){
        selected.length=0; WDRowChecks.forEach(cb=>cb.checked=WDSelectAll.checked);
        const selectedWD=Array.from(WDRowChecks).filter(cb=>cb.checked);
        selectedWD.forEach(check=>{ selected.push({id:check.dataset.id,code:check.dataset.code,qty:Number(check.dataset.qty)}); });
        const grouped=selected.reduce((acc,item)=>{ if(!acc[item.code]) acc[item.code]={id:item.id,code:item.code,qty:0}; acc[item.code].qty+=item.qty; return acc; },{});
        consolidated=Object.values(grouped);
        if(selected.length===0) document.getElementById("moveToEstimateBtn").classList.add("visually-hidden");
        else document.getElementById("moveToEstimateBtn").classList.remove("visually-hidden");
    });
    document.addEventListener('change',function(e){
        if(!e.target.classList.contains('WD-row-check')) return;
        const row={id:e.target.dataset.id,code:e.target.dataset.code,qty:Number(e.target.dataset.qty)};
        if(e.target.checked) selected.push(row); else selected=selected.filter(item=>item.id!==row.id);
        const grouped={}; selected.forEach(item=>{ if(!grouped[item.code]) grouped[item.code]={id:item.id,code:item.code,qty:0}; grouped[item.code].qty+=item.qty; });
        consolidated=Object.values(grouped);
        const allChecked=Array.from(WDRowChecks).every(r=>r.checked); if(WDSelectAll) WDSelectAll.checked=allChecked;
        if(selected.length===0) document.getElementById("moveToEstimateBtn").classList.add("visually-hidden");
        else document.getElementById("moveToEstimateBtn").classList.remove("visually-hidden");
    });
    document.getElementById('moveToEstimateBtn').addEventListener('click',async()=>{
        if(selected.length===0){ alert("No rows selected"); return; }
        const invalidCodes=consolidated.filter(item=>item.qty<=0);
        try { if(invalidCodes.length>0){ alert("Invalid selection: Total qty ≤ 0 for: "+invalidCodes.map(i=>i.code).join(", ")); return; } const response=await axios.post('/api/moveWorkDoneToEstimate',{rows:consolidated,selected:selected,ReservedDate:null}); window.location.reload(); }
        catch(error){ console.error("Error moving to estimates:", error); alert("An error occurred."); window.location.reload(); }
    });

    const estSelectAll=document.getElementById("Est-Select-All");
    const estRowChecks=document.querySelectorAll(".Est-row-check");
    const bulkButtons=document.querySelectorAll(".estBulkBtn");
    const bulkActions={"Pending":["Reserved","Rejected"],"Reserved":["Invoiced"],"Invoiced":["Payment-Received"],"Rejected":[],"Payment Received":[]};
    let totalRevenueOfBulkSelected=0;
    estSelectAll?.addEventListener("change",function(){
        estRowChecks.forEach(cb=>cb.checked=estSelectAll.checked);
        const sel=Array.from(estRowChecks).filter(cb=>cb.checked);
        const Estimates_IDs=sel.map(cb=>cb.dataset.id);
        if(Estimates_IDs.length>0) bulkButtons.forEach(btn=>{ btn.setAttribute("data-estimatesid",Estimates_IDs.join(",")); });
        updateBulkButtonVisibility();
    });
    estRowChecks.forEach(cb=>{
        cb.addEventListener("change",function(){
            const allChecked=Array.from(estRowChecks).every(r=>r.checked); if(estSelectAll) estSelectAll.checked=allChecked;
            const sel=Array.from(estRowChecks).filter(cb=>cb.checked);
            const Estimates_IDs=sel.map(cb=>cb.dataset.id);
            if(Estimates_IDs.length>0) bulkButtons.forEach(btn=>{ btn.setAttribute("data-estimatesid",Estimates_IDs.join(",")); });
            totalRevenueOfBulkSelected=sel?.reduce((total,cb)=>{ return total+Number(cb.dataset.totalRevenue); },0);
            updateBulkButtonVisibility();
        });
    });
    function hideAllBulkButtons(){ bulkButtons.forEach(btn=>btn.classList.add("d-none")); }
    function updateBulkButtonVisibility(){
        hideAllBulkButtons();
        const sel=Array.from(estRowChecks).filter(cb=>cb.checked);
        TotalAmount=sel.filter(cb=>cb.dataset.status=="Invoiced").reduce((total,cb)=>{ return total+Number(cb.dataset.totalrevenue); },0);
        bulkButtons.forEach(btn=>{ btn.setAttribute("data-totalrevenue",TotalAmount.toFixed(2)); });
        if(sel.length===0) return;
        const statuses=sel.map(cb=>cb.dataset.status); const allSame=statuses.every(s=>s===statuses[0]);
        if(!allSame){ estRowChecks.forEach(cb=>cb.checked=false); if(estSelectAll){ estSelectAll.checked=false; bulkButtons.forEach(btn=>{ btn.setAttribute("data-estimatesid",""); }); } return; }
        const status=statuses[0]; const actions=bulkActions[status]||[];
        actions.forEach(action=>{ const btn=document.querySelector(`#estBulk-${action}-Btn`); if(btn) btn.classList.remove("d-none"); });
    }

    const addWorkDoneForm=document.getElementById("AddWorkDone");
    addWorkDoneForm.addEventListener("submit",async function(e){
        e.preventDefault(); const submitBtn=addWorkDoneForm.querySelector("button[type='submit']");
        const payload={idProject:addWorkDoneForm.querySelector("#idProject").value,Job_ID:addWorkDoneForm.querySelector("#Job_ID").value,Program:addWorkDoneForm.querySelector("#Program").value,idratecard:addWorkDoneForm.querySelector("#idratecard").value,Item:addWorkDoneForm.querySelector("#WD_Item").value,Quantity:addWorkDoneForm.querySelector("#Quantity").value,WorkedMonth:addWorkDoneForm.querySelector("#WorkedMonth").value};
        submitBtn.disabled=true; submitBtn.innerHTML=`<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Submitting...`;
        try{ const response=await axios.post("/api/addWorkDone",payload); alert("Please refresh the page to see updated Work Done."); submitBtn.innerText="Add Work Done"; }
        catch(er){ console.log(er); submitBtn.innerHTML=`Try Again <i class="bi bi-arrow-repeat"></i>`; }
        finally{ submitBtn.disabled=false; }
    });
    addWorkDoneForm.addEventListener("reset",function(){ addWorkDoneForm.querySelector("button[type='submit']").innerHTML="Add Work Done"; });

    const creditNoteModal=document.getElementById('creditNoteModal');
    if(creditNoteModal){
        creditNoteModal.addEventListener('show.bs.modal',event=>{
            const button=event.relatedTarget;
            creditNoteModal.querySelector("#invoiceNumber").value=button.getAttribute('data-invNumber');
            creditNoteModal.querySelector("#Estimates_ID").value=button.getAttribute('data-estID');
            creditNoteModal.querySelector("#Item").value=button.getAttribute('data-item');
            creditNoteModal.querySelector("#Qty").value=button.getAttribute('data-qty');
        });
        creditNoteModal.querySelector("#creditNoteForm").addEventListener("submit",async function(e){
            e.preventDefault(); const form=creditNoteModal.querySelector("#creditNoteForm"); const submitBtn=form.querySelector("button[type='submit']");
            const payload={Estimates_ID:form.querySelector("#Estimates_ID").value,creditNoteDate:form.querySelector("#creditNoteDate").value,creditNoteAmount:form.querySelector("#creditNoteAmount").value,creditNoteNumber:form.querySelector("#creditNoteNumber").value};
            submitBtn.disabled=true; submitBtn.innerHTML=`<span class="spinner-border spinner-border-sm"></span> Submitting...`;
            try{ const response=await axios.post("/api/addCreditNote",payload); alert("Please refresh to see updated Estimates."); submitBtn.innerText="Submit"; }
            catch(er){ console.log(er); submitBtn.innerHTML=`Try Again <i class="bi bi-arrow-repeat"></i>`; }
            finally{ submitBtn.disabled=false; }
        });
    }

    const creditNoteInfoModal=document.getElementById('creditNoteInfoModal');
    if(creditNoteInfoModal){
        creditNoteInfoModal.addEventListener('show.bs.modal',event=>{
            const button=event.relatedTarget;
            creditNoteInfoModal.querySelector("#invoiceNumber").value=button.getAttribute('data-invNumber');
            creditNoteInfoModal.querySelector("#Estimates_ID").value=button.getAttribute('data-estID');
            creditNoteInfoModal.querySelector("#Item").value=button.getAttribute('data-item');
            creditNoteInfoModal.querySelector("#Qty").value=button.getAttribute('data-qty');
            creditNoteInfoModal.querySelector("#creditNoteNumber").value=button.getAttribute('data-cnNumber');
            creditNoteInfoModal.querySelector("#creditNoteDate").value=button.getAttribute('data-cnDate');
            creditNoteInfoModal.querySelector("#creditNoteAttachment").setAttribute("href",button.getAttribute('data-cnAttachment'));
        });
    }

    /* ══ View Payment Modal ══ */
    const viewPaymentDialog=document.getElementById('ViewPaymentDialog');
    if(viewPaymentDialog){
        viewPaymentDialog.addEventListener('show.bs.modal', async event => {
            const button=event.relatedTarget;
            const estID=button.getAttribute('data-estimatesId');
            const tbody=document.getElementById('viewPaymentBody');
            const title=document.getElementById('viewPaymentTitle');
            tbody.innerHTML='<tr><td colspan="5" class="text-center py-4 text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Loading...</td></tr>';
            try {
                const res=await axios.get('/api/getPaymentDetails',{params:{Estimates_ID:estID}});
                const payments=res.data;
                const invoiceCount=new Set(payments.map(p=>p.Invoice_Number)).size;
                title.innerHTML=`<i class="bi bi-eye me-2"></i>Payment Details <small class="text-muted fw-normal" style="font-size:12px;">${payments.length} record${payments.length!==1?'s':''} | ${invoiceCount} invoice${invoiceCount!==1?'s':''}</small>`;
                if(!payments||payments.length===0){
                    tbody.innerHTML='<tr><td colspan="5" class="text-center py-4 text-muted">No payment records found</td></tr>';
                    return;
                }
                tbody.innerHTML=payments.map((p,i)=>`
                    <tr>
                        <td>${i+1}</td>
                        <td>${p.invoicePath?`<a href="${p.invoicePath}" target="_blank" class="d-inline-flex align-items-center gap-1">${p.Invoice_Number} <i class="bi bi-box-arrow-up-right" style="font-size:11px;"></i></a>`:(p.Invoice_Number||'—')}</td>
                        <td><strong>$${parseFloat(p.Amount_Received||0).toFixed(2)}</strong></td>
                        <td class="text-nowrap">${p.Payment_Received_Date||'—'}</td>
                        <td>${p.Remark||'full'}</td>
                    </tr>
                `).join('');
            } catch(er){
                console.log(er);
                tbody.innerHTML='<tr><td colspan="5" class="text-center py-4 text-danger">Error loading payment details</td></tr>';
            }
        });
    }
});

/* ── Collapsible section cards ── */
(function(){
    document.querySelectorAll('.section-card').forEach(function(card) {
        var header = card.querySelector('.section-card-header');
        if (!header) return;

        // Add toggle icon to header
        var icon = document.createElement('i');
        icon.className = 'bi bi-chevron-down collapse-icon';
        header.appendChild(icon);

        // Wrap all content after header in a collapsible div
        var children = Array.from(card.children).filter(function(el) {
            return !el.classList.contains('section-card-header');
        });
        var wrap = document.createElement('div');
        wrap.className = 'section-card-body-wrap';
        children.forEach(function(el) { wrap.appendChild(el); });
        card.appendChild(wrap);

        // Click to toggle
        header.addEventListener('click', function(e) {
            // Don't collapse if clicking a button/link inside header
            if (e.target.closest('button, a, input')) return;
            header.classList.toggle('collapsed');
            wrap.classList.toggle('collapsed');
        });
    });
})();
</script>
