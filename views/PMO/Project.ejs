                                            let dots = Estimates[index].Description.substring(0,30).length > 29 ? "..." : null;
                                %>
                                <tr>
                                    <td><%=slNo++%></td>
                                    <td style="font-family:'DM Mono',monospace;font-size:11.5px;"><%=Estimates[index].Item%></td>
                                    <td><%=Estimates[index].Region%></td>
                                    <td><%=Estimates[index].UOM%></td>
                                    <td class="text-end"><%=Estimates[index].Quantity%></td>
                                    <%if(userData.Designation=="Head-OSP Design" && userData.Role=="PMO"){%>
                                    <td class="text-end">$<%=parseFloat(Estimates[index].UnitPrice).toFixed(2)%></td>
                                    <td class="text-end">$<%=parseFloat(Estimates[index].Quantity*Estimates[index].UnitPrice).toFixed(2)%></td>
                                    <%}%>
                                    <td><span class="est-badge rejected"><%=Estimates[index].Status%></span></td>
                                    <td class="text-nowrap"><%=Estimates[index]["Rejected Date"]||'—'%></td>
                                    <td><%=Estimates[index]["Rejection Comment"]||'—'%></td>
                                </tr>
                                <%}%><% } %>
                                <%if(userData.Designation=="Head-OSP Design" && userData.Role=="PMO"){%>
                                <tr class="fw-bold" style="background:var(--primary-light);">
                                    <td colspan="5" class="text-center fw-bold">Total</td>
                                    <td class="text-end fw-bold"><%=RejectedQuantity%></td>
                                    <td class="text-end fw-bold">$<%=parseFloat(RejectedTotal).toFixed(2)%></td>
                                    <td colspan="4"></td>
                                </tr>
                                <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

