                            <td class="text-nowrap"><%= markup[index].EndDate||'—' %></td>
                            <td class="text-nowrap"><%= markup[index].DueDate||'—' %></td>
                            <td><%= markup[index].Status %></td>
                            <td class="text-nowrap"><%= secondsToMinutes(markup[index].TotalTime) %></td>
                            <td><%- deliveryBadge(mkTemp) %></td>
