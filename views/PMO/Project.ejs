                            <td class="text-nowrap"><span class="Owner" style="max-width:120px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" data-UserID="<%= Task[index].Owner %>"><%= Task[index].Full_Name %></span></td>
                            <td class="text-nowrap"><%= Task[index].StartDate||'—' %></td>
