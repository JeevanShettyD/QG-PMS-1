<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= Customer %> - Project</title>
    <%- include('../partials/dependencies') %>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary:        #1a56db;
            --primary-dark:   #1344b5;
            --primary-light:  #ebf0ff;
            --accent:         #0ea5e9;
            --success:        #10b981;
            --warning:        #f59e0b;
            --danger:         #ef4444;
            --info:           #6366f1;
            --surface:        #ffffff;
            --surface-2:      #f8fafc;
            --surface-3:      #f1f5f9;
            --border:         #e2e8f0;
            --border-strong:  #cbd5e1;
            --text-primary:   #0f172a;
            --text-secondary: #475569;
            --text-muted:     #94a3b8;
            --shadow-sm:      0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md:      0 4px 12px rgba(0,0,0,.07), 0 2px 6px rgba(0,0,0,.05);
            --shadow-lg:      0 10px 30px rgba(0,0,0,.09), 0 4px 12px rgba(0,0,0,.06);
            --radius-sm:      6px;
            --radius-md:      10px;
            --radius-lg:      14px;
        }
        * { box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--surface-2); color: var(--text-primary); font-size: 13px; line-height: 1.55; }

        /* ── Page Header ── */
        .page-header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 12px 20px; display: flex; align-items: center; justify-content: space-between; gap: 12px; position: sticky; top: 0; z-index: 50; box-shadow: var(--shadow-sm); }
        .page-header-left { display: flex; align-items: center; gap: 10px; }
        .page-header-icon { width: 38px; height: 38px; background: var(--primary-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 17px; flex-shrink: 0; }
        .job-id-label { font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; line-height: 1; margin-bottom: 2px; }
        .job-id-value { font-size: 15px; font-weight: 700; color: var(--text-primary); font-family: 'DM Mono', monospace; letter-spacing: -.01em; }
        .header-divider { width: 1px; height: 32px; background: var(--border); }
        .status-chip { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: .03em; }
        .status-chip.active    { background:#dcfce7; color:#15803d; }
        .status-chip.pending   { background:#fef3c7; color:#b45309; }
        .status-chip.completed { background:#dbeafe; color:#1d4ed8; }
        .status-chip.cancelled { background:#fee2e2; color:#b91c1c; }
        .status-chip::before { content:''; width:6px; height:6px; border-radius:50%; background: currentColor; }
        .btn-edit { display: inline-flex; align-items: center; gap: 5px; padding: 6px 14px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text-secondary); font-size: 12px; font-weight: 600; text-decoration: none; transition: all .15s; font-family: 'DM Sans', sans-serif; }
        .btn-edit:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); text-decoration: none; }

        /* ── Tab Navigation ── */
        .tab-nav-wrapper { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; overflow-x: auto; }
        .tab-nav-wrapper::-webkit-scrollbar { height: 0; }
        .nav-tabs-custom { display: flex; gap: 0; border: none; flex-wrap: nowrap; list-style: none; margin: 0; padding: 0; }
        .nav-tabs-custom .nav-item { flex-shrink: 0; }
        .nav-tabs-custom .nav-link { display: flex; align-items: center; gap: 5px; padding: 11px 16px; border: none; border-bottom: 2px solid transparent; background: none; color: var(--text-muted); font-size: 12px; font-weight: 500; white-space: nowrap; cursor: pointer; transition: all .15s; border-radius: 0; position: relative; }
        .nav-tabs-custom .nav-link:hover { color: var(--primary); background: var(--primary-light); }
        .nav-tabs-custom .nav-link.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 600; background: transparent; }

        /* ── Tab Content ── */
        .tab-content-wrapper { padding: 16px 20px; }

        /* ── Section Cards ── */
        .section-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); margin-bottom: 16px; overflow: hidden; }
        .section-card-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--border); background: linear-gradient(135deg, #1a56db 0%, #1344b5 100%); color: #fff; }
        .section-card-title { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; letter-spacing: .01em; }
        .section-card-actions { display: flex; align-items: center; gap: 6px; }
        .btn-card-action { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border: 1.5px solid rgba(255,255,255,.5); border-radius: var(--radius-sm); background: rgba(255,255,255,.12); color: #fff; font-size: 11px; font-weight: 500; cursor: pointer; transition: all .15s; text-decoration: none; font-family: 'DM Sans', sans-serif; }
        .btn-card-action:hover { background: rgba(255,255,255,.25); color: #fff; text-decoration: none; }
        .btn-card-action.d-none { display: none !important; }

        /* ── Info Grid ── */
        .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0; }
        .info-field { display: flex; align-items: flex-start; padding: 10px 16px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); gap: 10px; }
        .info-field:nth-child(even) { background: var(--surface-2); }
        .info-field-label { font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; min-width: 110px; padding-top: 1px; flex-shrink: 0; }
        .info-field-value { font-size: 13px; font-weight: 500; color: var(--text-primary); word-break: break-word; }

        /* ── Stats Row ── */
        .stats-row { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
        .stat-item { flex: 1; padding: 14px 18px; border-right: 1px solid var(--border); text-align: center; }
        .stat-item:last-child { border-right: none; }
        .stat-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; margin-bottom: 3px; }
        .stat-value { font-size: 16px; font-weight: 700; color: var(--text-primary); font-family: 'DM Mono', monospace; }
        .stat-value.revenue  { color: var(--primary); }
        .stat-value.invoiced { color: var(--warning); }
        .stat-value.received { color: var(--success); }

        /* ── Tables ── */
        .data-table-wrapper { overflow-x: auto; }
        .data-table-wrapper.scrollable { max-height: 340px; overflow-y: auto; }
        .data-table-wrapper.scrollable::-webkit-scrollbar { width: 5px; height: 5px; }
        .data-table-wrapper.scrollable::-webkit-scrollbar-track { background: var(--surface-3); }
        .data-table-wrapper.scrollable::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
        .data-table thead th { background: linear-gradient(135deg, #1a56db 0%, #1344b5 100%); color: #fff; font-size: 11px; font-weight: 600; padding: 10px 12px; text-align: left; white-space: nowrap; position: sticky; top: 0; z-index: 2; border: none; letter-spacing: .03em; }
        .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .1s; }
        .data-table tbody tr:last-child { border-bottom: none; }
        .data-table tbody tr:hover { background: var(--primary-light); }
        .data-table tbody tr.negative-qty { background: #fff5f5; }
        .data-table tbody tr.negative-qty:hover { background: #fee2e2; }
        .data-table td { padding: 9px 12px; vertical-align: middle; border: none; color: var(--text-primary); }
        .data-table td a { color: var(--primary); text-decoration: none; font-weight: 500; }
        .data-table td a:hover { text-decoration: underline; }

        /* ── Delivery Status Badges ── */
        .delivery-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 20px; font-size: 10.5px; font-weight: 600; white-space: nowrap; }
        .delivery-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
        .delivery-badge.on-time      { background:#dcfce7; color:#15803d; }
        .delivery-badge.approaching  { background:#fef3c7; color:#b45309; }
        .delivery-badge.due-today    { background:#dbeafe; color:#1d4ed8; }
        .delivery-badge.delayed      { background:#fee2e2; color:#b91c1c; }
        .delivery-badge.escalation   { background:#fce7f3; color:#9d174d; }

        /* ── Estimate Status ── */
        .est-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .est-badge.pending   { background:#fef3c7; color:#b45309; }
        .est-badge.reserved  { background:#dbeafe; color:#1d4ed8; }
        .est-badge.invoiced  { background:#f3e8ff; color:#7e22ce; }
        .est-badge.received  { background:#dcfce7; color:#15803d; }
        .est-badge.rejected  { background:#fee2e2; color:#b91c1c; }
        .est-badge.credit    { background:#e0f2fe; color:#0369a1; }

        /* ── Action Buttons in tables ── */
        .btn-tbl { display: inline-flex; align-items: center; gap: 3px; padding: 3px 9px; border-radius: var(--radius-sm); font-size: 11px; font-weight: 500; cursor: pointer; border: 1.5px solid transparent; transition: all .12s; white-space: nowrap; font-family: 'DM Sans', sans-serif; }
        .btn-tbl-success { border-color: var(--success); color: var(--success); background: transparent; }
        .btn-tbl-success:hover { background: #dcfce7; }
        .btn-tbl-danger  { border-color: var(--danger);  color: var(--danger);  background: transparent; }
        .btn-tbl-danger:hover  { background: #fee2e2; }
        .btn-tbl-primary { border-color: var(--primary); color: var(--primary); background: transparent; }
        .btn-tbl-primary:hover { background: var(--primary-light); }
        .btn-tbl-info    { border-color: var(--info); color: var(--info); background: transparent; }
        .btn-tbl-info:hover    { background: #ede9fe; }

        /* ── Footages Section ── */
        .footage-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; padding: 16px; }
        .footage-item { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 12px 14px; text-align: center; }
        .footage-item-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 4px; }
        .footage-item-value { font-size: 18px; font-weight: 700; color: var(--primary); font-family: 'DM Mono', monospace; }

        /* ── Comments ── */
        .comment-item { padding: 12px 16px; border-bottom: 1px solid var(--border); }
        .comment-item:last-child { border-bottom: none; }
        .comment-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
        .comment-author { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; color: var(--text-primary); }
        .comment-date { font-size: 11px; color: var(--text-muted); }
        .comment-body { padding: 8px 12px; border-radius: var(--radius-sm); font-size: 12.5px; line-height: 1.55; border-left: 3px solid var(--border); background: var(--surface-2); }
        .comment-body.owner-comment { border-left-color: var(--primary); background: var(--primary-light); }

        /* ── Attachments ── */
        .qg-tab { position: relative; }
        .qg-tab input[type="checkbox"] { position: absolute; opacity: 0; pointer-events: none; }
        .qg-tab__label { display: flex; align-items: center; gap: 6px; padding: 9px 16px; cursor: pointer; font-weight: 600; color: var(--text-primary); border-bottom: 1px solid var(--border); background: var(--surface-2); user-select: none; transition: background .12s; }
        .qg-tab__label:hover { background: var(--primary-light); }
        .qg-tab__content { display: none; background: var(--surface); }
        .qg-tab input[type="checkbox"]:checked ~ .qg-tab__content { display: block; }

        /* ── Empty State ── */
        .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 24px; text-align: center; }
        .empty-state img { opacity: .6; }
        .empty-state p { margin-top: 12px; color: var(--text-muted); font-size: 13px; }

        /* ── Sub-tabs ── */
        .sub-tabs { padding: 12px 16px 0; }
        .sub-nav-tabs { border-bottom: 1px solid var(--border); }
        .sub-nav-tabs .nav-link { font-size: 12px; padding: 7px 14px; color: var(--text-muted); border: none; border-bottom: 2px solid transparent; background: none; cursor: pointer; }
        .sub-nav-tabs .nav-link.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 600; }

        /* ── Inline pill summary ── */
        .pill-summary { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 600; }
        .pill-revenue  { background: #f8fafc; color: var(--text-primary); border: 1px solid var(--border); }
        .pill-invoiced { background: #fef3c7; color: #b45309; }
        .pill-received { background: #dcfce7; color: #15803d; }

        /* ── Checkbox improvements ── */
        .form-check-input { cursor: pointer; border-color: var(--border-strong); }
        .form-check-input:checked { background-color: var(--primary); border-color: var(--primary); }

        /* ── Modal improvements ── */
        .modal-content { border: none; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); font-family: 'DM Sans', sans-serif; }
        .modal-header { border-bottom: 1px solid var(--border); background: var(--surface-2); border-radius: var(--radius-lg) var(--radius-lg) 0 0; padding: 14px 18px; }
        .modal-title { font-weight: 700; font-size: 14px; }
        .modal-body { padding: 18px; }
        .modal-footer { border-top: 1px solid var(--border); padding: 12px 18px; }
        .form-label { font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; }
        .form-control, .form-select { font-size: 12.5px; border-color: var(--border); border-radius: var(--radius-sm); font-family: 'DM Sans', sans-serif; }
        .form-control:focus, .form-select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(26,86,219,.12); }

        /* ── Buttons ── */
        .btn-primary { background: var(--primary); border-color: var(--primary); font-size: 12.5px; font-weight: 600; font-family: 'DM Sans', sans-serif; border-radius: var(--radius-sm); }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
        .btn-secondary { font-size: 12.5px; font-weight: 500; font-family: 'DM Sans', sans-serif; border-radius: var(--radius-sm); }

        /* ── Score badge ── */
        .score-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; font-size: 11.5px; font-weight: 700; }
        .score-95   { background:#dcfce7; color:#15803d; }
        .score-90   { background:#d1fae5; color:#065f46; }
        .score-80   { background:#fef3c7; color:#b45309; }
        .score-75   { background:#ffedd5; color:#c2410c; }
        .score-low  { background:#fee2e2; color:#b91c1c; }
        .score-none { background:#f1f5f9; color:#64748b; }

        /* misc */
        p.col > span { font-weight: 600; }
        .file-progress { width:100%; background:#ddd; }
        .progress-bar { width:0; height:20px; background:#4CAF50; text-align:center; line-height:20px; color:#fff; }
        .data-table tbody tr:nth-child(even):not(:hover) { background: var(--surface-2); }
        .data-table tbody tr:nth-child(even).negative-qty:not(:hover) { background: #fff5f5; }

        @media (max-width:768px) {
            .tab-content-wrapper { padding: 12px; }
            .info-grid { grid-template-columns: 1fr; }
            .footage-grid { grid-template-columns: 1fr 1fr; }
            .stats-row { flex-wrap: wrap; }
            .stat-item { min-width: 120px; }
        }

        /* ── Collapsible section cards ── */
.section-card-header { cursor: pointer; user-select: none; }
.section-card-header .collapse-icon {
    margin-left: auto;
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    transition: transform 0.22s ease;
    flex-shrink: 0;
}
.section-card-header.collapsed .collapse-icon { transform: rotate(-90deg); }
.section-card-body-wrap {
    transition: max-height 0.3s ease, opacity 0.22s ease;
    overflow: hidden;
    max-height: 2000px;
    opacity: 1;
}
.section-card-body-wrap.collapsed {
    max-height: 0;
    opacity: 0;
}
    </style>
</head>

<% if (userData.Role=="Employee") { %>
    <%- include('../partials/Employee-header',{userData:userData}) %>
<% } else if(userData.Role=="Admin") { %>
    <%- include('../partials/Admin-header',{userData:userData}) %>
<% } else if(userData.Role=="PMO") { %>
    <%- include('../partials/PMO-header',{userData:userData}) %>
<% } if(userData.Role=="Manager") { %>
    <%- include('../partials/Manager-header',{userData:userData}) %>
<% } %>

<body>
<%
let bgColour = "";
let bgMap = {
    "On Time":              "on-time",
    "Approaching Due Date": "approaching",
    "Due Today":            "due-today",
    "Delayed":              "delayed",
    "Escalation":           "escalation",
};
function deliveryBadge(label) {
    if (!label) return '<span class="text-muted">—</span>';
    const cls = bgMap[label] || '';
    return `<span class="delivery-badge ${cls}">${label}</span>`;
}
%>

<!-- ══ Page Header ══ -->
<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon"><i class="bi bi-folder2-open"></i></div>
        <div>
            <div class="job-id-label"><%= Customer !== 'AT&T' ? 'Job ID' : 'CFAS ID' %></div>
            <div class="job-id-value">
                <% if(Customer !== 'AT&T') { %>
                    <span id="JOB_ID"><%= ProjectData.JOB_ID %><%= ProjectData.Job_Name ? ' — '+ProjectData.Job_Name : '' %></span>
                <% } else { %>
                    <span id="CFAS_ID"><%= ProjectData.CFAS_ID %><%= ProjectData.Job_Name ? ' — '+ProjectData.Job_Name : '' %></span>
                <% } %>
            </div>
        </div>
        <div class="header-divider"></div>
        <div>
            <div class="job-id-label">Status</div>
            <%
            const s = (ProjectData.Status||'').toLowerCase();
            let sClass = s.includes('active')||s.includes('ongoing') ? 'active'
                       : s.includes('complet') ? 'completed'
                       : s.includes('cancel') ? 'cancelled'
                       : 'pending';
            %>
            <span id="Status" class="status-chip <%= sClass %>"><%= ProjectData.Status %></span>
        </div>
    </div>
    <div>
        <a href="/PMO/editProject/<%= Customer %>/<%= ProjectData.idProjects %>" class="btn-edit" id="editButton">
            <i class="bi bi-pencil"></i> Edit
        </a>
    </div>
</div>

<!-- ══ Tab Navigation ══ -->
<div class="tab-nav-wrapper">
    <ol class="nav-tabs-custom" id="projectTab" role="tablist">
        <li class="nav-item"><button class="nav-link active" id="Project-Info-tab" data-bs-toggle="tab" data-bs-target="#projectInfo-tab-pane" type="button" role="tab" aria-selected="true"><i class="bi bi-info-circle"></i> Project Info</button></li>
        <li class="nav-item"><button class="nav-link" id="Milestine-tab" data-bs-toggle="tab" data-bs-target="#milestone-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-flag"></i> Milestone</button></li>
        <li class="nav-item"><button class="nav-link" id="Prod-tab" data-bs-toggle="tab" data-bs-target="#Prod-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-gear"></i> Production</button></li>
        <li class="nav-item"><button class="nav-link" id="QC-tab" data-bs-toggle="tab" data-bs-target="#qc-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-shield-check"></i> QC</button></li>
        <li class="nav-item"><button class="nav-link" id="Sub-Task-tab" data-bs-toggle="tab" data-bs-target="#sub-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-diagram-3"></i> Subtask</button></li>
        <li class="nav-item"><button class="nav-link" id="Markup-Task-tab" data-bs-toggle="tab" data-bs-target="#markup-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-pencil-square"></i> Markup</button></li>
        <li class="nav-item"><button class="nav-link" id="Task-tab" data-bs-toggle="tab" data-bs-target="#CQC-task-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-clipboard-check"></i> USQC/CQC</button></li>
        <li class="nav-item"><button class="nav-link" id="Timesheet-Task-tab" data-bs-toggle="tab" data-bs-target="#timeSheet-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-clock-history"></i> Time Sheet</button></li>
        <li class="nav-item"><button class="nav-link" id="Attachments-tab" data-bs-toggle="tab" data-bs-target="#Attachments-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-paperclip"></i> Attachments</button></li>
        <li class="nav-item"><button class="nav-link" id="Active-Task-tab" data-bs-toggle="tab" data-bs-target="#activeTask-tab-pane" type="button" role="tab" aria-selected="false"><i class="bi bi-lightning-charge"></i> Active Task</button></li>
    </ol>
</div>

<!-- ══ Tab Content ══ -->
<div class="tab-content tab-content-wrapper" id="myTabContent">

    <!-- ── Project Info ── -->
    <div class="tab-pane fade show active" id="projectInfo-tab-pane" role="tabpanel">

        <!-- Info Fields -->
        <div class="section-card">
            <div class="section-card-header">
                <div class="section-card-title"><i class="bi bi-card-list"></i> Project Details</div>
            </div>
            <% if(Customer == 'AT&T') { %>
            <div class="info-grid">
                <div class="info-field"><span class="info-field-label">CFAS-ID</span><span class="info-field-value" id="JOB_ID"><%= ProjectData.CFAS_ID %></span></div>
