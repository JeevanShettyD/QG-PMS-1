                            <td class="text-nowrap"><%= subtask[index].DueDate %></td>
                            <td><%= subtask[index].Status %></td>
                            <td class="text-nowrap"><%= secondsToMinutes(subtask[index].TotalTime) %></td>
                            <td><%- deliveryBadge(stTemp) %></td>
