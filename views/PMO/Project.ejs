    <!-- ── USQC/CQC ── -->
    <div class="tab-pane fade" id="CQC-task-tab-pane" role="tabpanel">
        <div class="section-card">
            <div class="section-card-header">
                <div class="section-card-title"><i class="bi bi-clipboard-check"></i> USQC / CQC Tasks</div>
                <div class="section-card-actions"><button class="btn-card-action <%if(userData.Role!='PMO'){%>d-none<%}%>" data-bs-toggle="modal" data-bs-target="#create-CQC-Task-Modal"><i class="bi bi-plus"></i> Add Task</button></div>
            </div>
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead><tr><th>#</th><th>Task ID</th><th>Task Name</th><th>Milestone</th><th>Owner</th><th>Start</th><th>End</th><th>Score</th><th>Status</th><th>Time</th><th>Delivery</th></tr></thead>
                    <tbody>
                        <% slNo=1; %>
                        <% for(let index=0; index < Object.values(Task).length; index++) { %>
                        <% if (Task[index].Type=='CQC' || Task[index].Type=='USQC') { %>
                        <% let cqcDue=Task[index].f_DueDate, cqcEnd=Task[index].f_EndDate?Task[index].f_EndDate:"", cqcTemp=compareDates(cqcDue,cqcEnd,Task[index].Status);
                        let scoreCls="score-none", tempScore=parseFloat(Task[index].Score);
                        if(!isNaN(tempScore)){ if(tempScore>=95) scoreCls="score-95"; else if(tempScore>=90) scoreCls="score-90"; else if(tempScore>=80) scoreCls="score-80"; else if(tempScore>=75) scoreCls="score-75"; else scoreCls="score-low"; } %>
                        <tr>
                            <td><%= slNo %></td>
                            <td class="text-nowrap"><img src="../../../static/icons/Gray-dot.png" width="12" height="12" id="TaskStatus-<%= Task[index].TaskName %>"> <a href="/ViewTask/<%= Customer %>/<%= Task[index].Milestone_Name %>/<%= Task[index].TaskName %>"><%= Task[index].TaskName %></a></td>
                            <td><span class="Owner" style="max-width:130px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= Task[index].TaskLabel||'—' %></span></td>
                            <td class="text-nowrap"><a href="/ViewMilestone/<%= Customer %>/<%= Task[index].idProjects %>/<%= Task[index].Milestone_Name %>"><%= Task[index].Milestone_Name %></a></td>
                            <td class="text-nowrap"><span class="Owner" style="max-width:110px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" data-UserID="<%= Task[index].Owner %>"><%= Task[index].Full_Name %></span></td>
                            <td class="text-nowrap"><%= Task[index].StartDate||'—' %></td>
                            <td class="text-nowrap"><%= Task[index].EndDate||'—' %></td>
                            <td><span class="score-badge <%=scoreCls%>"><%= Task[index].Score||'Not Scored' %></span></td>
                            <td><%= Task[index].Status %></td>
                            <td class="text-nowrap"><%= secondsToMinutes(Task[index].TotalTime) %></td>
                            <td><%- deliveryBadge(cqcTemp) %></td>
                        </tr>
                        <% slNo++; } %><% } %>
                        <% if(slNo===1){ %><tr><td colspan="11" class="text-center py-4 text-muted">No USQC/CQC tasks</td></tr><% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

