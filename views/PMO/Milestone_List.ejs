                <div class="form-floating w-50 m-2">
                  <input type="date" class="today-date form-control border" id="DueDate" name="DueDate" required>
                  <label>Task Due Date</label>
                </div>
              </div>
              <div class="col-md m-2">
                <input type="hidden" name="Type" id="Type" value="Production" required>
                <div class="form-floating">
                  <input type="text" class="form-control" id="Remark" name="Remark" placeholder="">
                  <label>Note/Remarks (If Applicable)</label>
                </div>
              </div>
              <div class="col-md text-center">
                <p class="from-label">Allow system to auto-create QC-Task when this production task completes?</p>
                <input type="radio" class="btn-check" name="autoQC" id="autoQC1" value="1" required>
                <label class="btn btn-outline-success" for="autoQC1">Yes</label>
                <input type="radio" class="btn-check" name="autoQC" id="autoQC2" value="0">
                <label class="btn btn-outline-danger" for="autoQC2">No</label>
              </div>
              <div class="QC_Due_Date_Container m-2">
                <div class="form-floating">
                  <input type="date" class="today-date form-control border" id="QC_Due_Date" name="QC_Due_Date">
                  <label>QC-Due Date</label>
                </div>
              </div>
            </div>
          </div></div>
        </div>
        <div class="modal-footer">
          <button type="reset" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="submit" class="btn btn-primary">Create</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/dependencies-js',{Notifications:Notifications}) %>

<script>
/* ══════════════════════════════════════
   TAB SWITCHING
══════════════════════════════════════ */
/* Prevent milestone page clicks from closing header cards */
(function(){
  var mainEl = document.querySelector('main.ms-page');
  if(mainEl){
    mainEl.addEventListener('mousedown', function(e){
      /* Don't stop propagation for links/buttons that need it */
      /* Only stop if the target is a general page area */
      var tag = e.target.tagName.toLowerCase();
      if(['a','button','input','select'].indexOf(tag) === -1){
        e.stopPropagation();
      }
    });
  }
})();
function switchTab(name, btn) {
  document.querySelectorAll('.ms-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.ms-tab-pane').forEach(p => p.style.display = 'none');
  btn.classList.add('active');
  document.getElementById('pane-' + name).style.display = '';
}

/* ══════════════════════════════════════
   ROW EXPAND / COLLAPSE
══════════════════════════════════════ */
function toggleDetail(toggleEl) {
  var dataRow   = toggleEl.closest('tr');
  var detailRow = dataRow.nextElementSibling;
  var icon      = toggleEl.querySelector('i');
  if (!detailRow || !detailRow.classList.contains('ms-detail-row')) return;

  var isHidden = (detailRow.style.display === 'none' || detailRow.style.display === '');
  detailRow.style.display = isHidden ? 'table-row' : 'none';

  /* On open: ensure td is visible and spans all visible columns */
  if (isHidden) {
    var td = detailRow.querySelector('td');
    if (td) {
      td.style.display = '';
      var visibleCount = 0;
      document.querySelectorAll('.col-toggle').forEach(function(cb){ if(cb.checked) visibleCount++; });
      td.colSpan = visibleCount || 11;
    }
  }

  icon.className = isHidden ? 'bi bi-dash-lg' : 'bi bi-plus-lg';
  toggleEl.style.background = isHidden ? 'var(--ms-blue)' : '';
  toggleEl.style.color      = isHidden ? '#fff' : '';
}

/* ══════════════════════════════════════
   COLUMN SHOW / HIDE — proper reflow
   Uses colgroup visibility so the table
   shrinks/expands naturally when fields
   are toggled on or off.
══════════════════════════════════════ */
(function(){
  /* Build a colgroup for every table once */
  document.querySelectorAll('.ms-table').forEach(function(tbl){
    var colCount = tbl.querySelector('thead tr:last-child').querySelectorAll('th').length;
    var cg = document.createElement('colgroup');
    for(var i = 0; i < colCount; i++){
      var col = document.createElement('col');
      col.setAttribute('data-colidx', i);
      cg.appendChild(col);
    }
    tbl.insertBefore(cg, tbl.firstChild);
  });

  function applyColVisibility(){
    /* Build a set of hidden column indexes */
    var hidden = {};
    document.querySelectorAll('.col-toggle').forEach(function(cb){
      if(!cb.checked) hidden[parseInt(cb.getAttribute('data-col'))] = true;
    });

    document.querySelectorAll('.ms-table').forEach(function(tbl){
      /* 1. Hide/show every cell in every row by column index */
      tbl.querySelectorAll('tr').forEach(function(row){
      /* Skip detail rows — only update colspan, never touch display */
        if(row.classList.contains('ms-detail-row')){
          var tdDetail = row.querySelector('td');
          if(tdDetail){
            var visibleCount = 0;
            document.querySelectorAll('.col-toggle').forEach(function(cb){ if(cb.checked) visibleCount++; });
            tdDetail.colSpan = visibleCount || 1;
          }
          return;
        }

        var cells = row.querySelectorAll('th, td');

        /* Header group row (first thead row) uses colspans — skip cell-by-cell */
        if(row.parentElement.tagName === 'THEAD' && row.rowIndex === 0) return;

        cells.forEach(function(cell, idx){
          cell.style.display = hidden[idx] ? 'none' : '';
        });
      });

      /* 2. Update header group row colspans dynamically */
      var groupRow = tbl.querySelector('thead tr:first-child');
      if(groupRow){
        var groupCells = groupRow.querySelectorAll('th');
        /* Groups: [0-3]=empty(4), [4-5]=ProdTGT(2), [6-7]=QCTGT(2), [8-10]=empty(3) */
        var groups = [
          { start:0, end:3 },  // S.No, Name, Project, Created
          { start:4, end:5 },  // Prod TGT
          { start:6, end:7 },  // QC TGT
          { start:8, end:10 }  // Due Date, Status, Delivery
        ];
        groups.forEach(function(g, gi){
          var visible = 0;
          for(var c = g.start; c <= g.end; c++){
            if(!hidden[c]) visible++;
          }
          if(groupCells[gi]){
            if(visible === 0){
              groupCells[gi].style.display = 'none';
            } else {
              groupCells[gi].style.display = '';
              groupCells[gi].colSpan = visible;
            }
          }
        });
      }
    });
  }

  /* Wire up all checkboxes */
  document.querySelectorAll('.col-toggle').forEach(function(cb){
    cb.addEventListener('change', applyColVisibility);
  });

  /* Select All button */
  window.selectAllColumns = function(){
    document.querySelectorAll('.col-toggle').forEach(function(cb){ cb.checked = true; });
    applyColVisibility();
  };
  window.unselectAllColumns = function(){
    document.querySelectorAll('.col-toggle').forEach(function(cb){ cb.checked = false; });
    applyColVisibility();
  };
})();

/* Field panel toggle */
document.getElementById('fieldTrigger').addEventListener('click', function(e) {
  e.stopPropagation();
  document.getElementById('fieldPanel').classList.toggle('open');
});
document.addEventListener('click', function(e) {
  /* Only close field panel — never touch header elements */
  var fieldSelector = document.getElementById('fieldSelector');
  if (fieldSelector && !fieldSelector.contains(e.target)) {
    document.getElementById('fieldPanel').classList.remove('open');
  }
  /* Also close filter panel if click is outside it and outside the FAB */
  var filterPanel = document.getElementById('filterPanel');
  var filterFab   = document.getElementById('filterFab');
  if (filterPanel && filterFab &&
      !filterPanel.contains(e.target) &&
      !filterFab.contains(e.target)) {
    filterPanel.classList.remove('open');
  }
});

/* ══════════════════════════════════════
   COLUMN RESIZE (Excel-like)
══════════════════════════════════════ */
(function() {
  var resizing = null;
  var startX   = 0;
  var startW   = 0;

  document.querySelectorAll('.col-resize-handle').forEach(function(handle) {
    handle.addEventListener('mousedown', function(e) {
      e.preventDefault();
      resizing = handle.parentElement;
      startX   = e.pageX;
      startW   = resizing.offsetWidth;
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
    });
  });

  document.addEventListener('mousemove', function(e) {
    if (!resizing) return;
    var newW = Math.max(60, startW + (e.pageX - startX));
    resizing.style.minWidth = newW + 'px';
    resizing.style.width    = newW + 'px';
  });

  document.addEventListener('mouseup', function() {
    if (resizing) {
      resizing = null;
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
    }
  });
})();

/* ══════════════════════════════════════
   SHOW MORE / LESS for long text
══════════════════════════════════════ */
(function() {
  var LIMIT = 40;
  document.querySelectorAll('.ms-table tbody td').forEach(function(td) {
    var text = td.textContent.trim();
    if (text.length > LIMIT && !td.querySelector('a') && !td.querySelector('input') && !td.querySelector('span')) {
      var full = text;
      td.innerHTML =
        '<span class="ms-text-cell collapsed">' + full.substring(0, LIMIT) + '…</span>' +
        '<button class="ms-show-more" onclick="toggleText(this)">Show More</button>';
    }
  });
})();

function toggleText(btn) {
  var cell = btn.previousElementSibling;
  if (cell.classList.contains('collapsed')) {
    cell.classList.remove('collapsed');
    btn.textContent = 'Show Less';
  } else {
    cell.classList.add('collapsed');
    btn.textContent = 'Show More';
  }
}

/* ══════════════════════════════════════
   FILTER PANEL
══════════════════════════════════════ */
document.getElementById('filterFab').addEventListener('click', function() {
  document.getElementById('filterPanel').classList.toggle('open');
});
document.getElementById('filterClose').addEventListener('click', function() {
  document.getElementById('filterPanel').classList.remove('open');
});

/* ══════════════════════════════════════
   BULK SELECTION
══════════════════════════════════════ */
$(document).ready(function () {
  $(".QC_Due_Date_Container").hide();
  $('input[type="radio"][name="autoQC"]').on('click', function () {
    if ($(this).val() === '1') {
      $('.QC_Due_Date_Container').show();
      $('#QC_Due_Date').attr('required', true);
    } else {
      $('.QC_Due_Date_Container').hide();
      $('#QC_Due_Date').attr('required', false);
    }
  });
});

document.addEventListener('DOMContentLoaded', function () {
  var selectAllYTS      = document.getElementById('selectAllYTS');
  var selectAllOngoing  = document.getElementById('selectAllOngoing');
  var cbYTS             = document.querySelectorAll('.record-checkbox');
  var cbOngoing         = document.querySelectorAll('.record-checkbox-ongoing');
  var selectedRecords   = [];
  var bulkBar           = document.getElementById('bulkBar');
  var bulkCount         = document.getElementById('bulkCount');

  function updateBulk() {
    selectedRecords.length = 0;
    cbYTS.forEach(function(cb) {
      if (cb.checked) selectedRecords.push(JSON.stringify({ Job: cb.value, ID: cb.getAttribute('data-id') }));
    });
    cbOngoing.forEach(function(cb) {
      if (cb.checked) selectedRecords.push(JSON.stringify({ Job: cb.value, ID: cb.getAttribute('data-id') }));
    });

    var count = selectedRecords.length;
    bulkCount.textContent = count;
    bulkBar.classList.toggle('hidden', count === 0);

    document.querySelectorAll('.ActiveCount').forEach(function(el) {
      el.innerText = count || '';
    });

    if (count > 0) {
      document.querySelectorAll('.milestone-container').forEach(function(c) {
        c.innerHTML = '';
        selectedRecords.forEach(function(job, idx) {
          var t = JSON.parse(job);
          c.innerHTML += '<div class="d-flex align-items-center">' +
            '<span>' + (idx+1) + '-</span>' +
            '<input type="text" class="border-bottom bg-body-tertiary m-1" name="Milestone_Name" value="' + t.Job + '" readonly required>' +
            '<input type="hidden" name="ID" value="' + t.ID + '" readonly required>' +
            '</div>';
        });
      });
    }
  }

  if (selectAllYTS) {
    selectAllYTS.addEventListener('change', function() {
      cbYTS.forEach(function(cb) { cb.checked = selectAllYTS.checked; });
      updateBulk();
    });
  }
  cbYTS.forEach(function(cb) {
    cb.addEventListener('change', function() {
      if (!cb.checked && selectAllYTS) selectAllYTS.checked = false;
      updateBulk();
    });
  });

  if (selectAllOngoing) {
    selectAllOngoing.addEventListener('change', function() {
      cbOngoing.forEach(function(cb) { cb.checked = selectAllOngoing.checked; });
      updateBulk();
    });
  }
  cbOngoing.forEach(function(cb) {
    cb.addEventListener('change', function() {
      if (!cb.checked && selectAllOngoing) selectAllOngoing.checked = false;
      updateBulk();
    });
  });

  /* Restore filter values from URL */
  var params = getUrlParams();
  document.querySelectorAll('select').forEach(function(sel) {
    for (var k in params) {
      if (k === sel.name) {
        var opt = sel.querySelector('option[value="' + params[k] + '"]');
        if (opt) opt.selected = true;
      }
    }
  });
  document.querySelectorAll('input[type="search"]').forEach(function(inp) {
    for (var k in params) {
      if (k === inp.name) inp.value = params[k];
    }
  });

  /* Update export link with current filters */
  var exportLink = document.getElementById('ExportLink');
  if (exportLink) {
    var base = exportLink.getAttribute('href');
    var qs   = '?';
    for (var k in params) { qs += k + '=' + params[k] + '&'; }
    exportLink.setAttribute('href', base + qs);
  }

  /* Pure CSS column sort — no DataTables needed */
  (function(){
    document.querySelectorAll('.ms-table thead tr:last-child th').forEach(function(th){
      if(th.querySelector('.col-resize-handle') || th.querySelector('input')) return;
      th.style.cursor = 'pointer';
      th.addEventListener('click', function(){
        var tbl  = th.closest('table');
        var idx  = Array.from(th.parentElement.children).indexOf(th);
        var asc  = th.dataset.sort !== 'asc';
        th.dataset.sort = asc ? 'asc' : 'desc';
        /* update arrow indicator */
        tbl.querySelectorAll('thead tr:last-child th').forEach(function(t){ t.dataset.sort = ''; });
        th.dataset.sort = asc ? 'asc' : 'desc';
        var rows = Array.from(tbl.querySelectorAll('tbody tr.ms-data-row'));
        rows.sort(function(a,b){
          /* each data row is followed by a detail row — keep pairs together */
          var av = (a.cells[idx] || {}).textContent.trim();
          var bv = (b.cells[idx] || {}).textContent.trim();
          return asc ? av.localeCompare(bv, undefined, {numeric:true}) :
                       bv.localeCompare(av, undefined, {numeric:true});
        });
        var tbody = tbl.querySelector('tbody');
        rows.forEach(function(row){
          var detail = row.nextElementSibling;
          tbody.appendChild(row);
          if(detail && detail.classList.contains('ms-detail-row')) tbody.appendChild(detail);
        });
      });
    });
  })();
});
</script>
