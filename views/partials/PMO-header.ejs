<%# ══════════════════════════════════════
     JAVASCRIPT — Search + Sidebar + Timezone
══════════════════════════════════════ %>
<script>
  /* ══════════════════════════════════════
     SEARCH — FULLY FUNCTIONAL
     • Opens/closes pill on icon click
     • Live filters as you type (debounced)
     • Tries /api/search?q= then falls back
       to scanning sidebar + ribbon links
     • Keyboard: ↑ ↓ Enter Escape
     • Clear btn (×) resets input
  ══════════════════════════════════════ */
  (function(){
    var wrap       = document.getElementById('ribbonSearch');
    var toggleBtn  = document.getElementById('searchToggleBtn');
    var clearBtn   = document.getElementById('searchClearBtn');
    var input      = document.getElementById('searchbox');
    var resultsBox = document.getElementById('searchResultsContainer');
    if (!wrap || !toggleBtn || !input || !resultsBox) return;

    var debounceTimer = null;
    var activeIdx     = -1;

    /* ── Open / Close ── */
    function openSearch() {
      wrap.classList.add('open');
      setTimeout(function(){ input.focus(); }, 320);
    }
    function closeSearch() {
      wrap.classList.remove('open');
      input.value = '';
      input.blur();
      hideResults();
    }
    function showResults() { resultsBox.classList.remove('visually-hidden'); }
    function hideResults() {
      resultsBox.classList.add('visually-hidden');
      activeIdx = -1;
    }

    /* ── Escape HTML ── */
    function esc(s) {
      return String(s || '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── Render list of result items ── */
    function renderResults(items) {
      activeIdx = -1;
      resultsBox.innerHTML = '';

      if (!items || items.length === 0) {
        resultsBox.innerHTML =
          '<div class="sr-placeholder">' +
            '<div class="sr-icon"><i class="bi bi-search"></i></div>' +
            '<span>No results found</span>' +
          '</div>';
        showResults();
        return;
      }

      var hdr = document.createElement('div');
      hdr.className = 'sr-header';
      hdr.textContent = 'Projects (' + items.length + ')';
      resultsBox.appendChild(hdr);

      items.forEach(function(item, idx) {
        var row      = document.createElement('a');
        row.className = 'search-result-row';
        row.href     = item.url || item.link || '#';
        row.setAttribute('data-idx', idx);

        var label    = esc(item.name || item.Job_ID || item.title || '');
        var sublabel = item.program  ? esc(item.program)  :
                       item.customer ? esc(item.customer) : '';

        row.innerHTML =
          '<div class="sr-icon"><i class="bi bi-folder-fill"></i></div>' +
          '<div class="sr-meta">' +
            '<span>' + label + '</span>' +
            (sublabel ? '<small>' + sublabel + '</small>' : '') +
          '</div>';

        /* mousedown prevents input blur before navigation fires */
        row.addEventListener('mousedown', function(e){
          e.preventDefault();
          window.location.href = row.href;
        });
        row.addEventListener('mouseover', function(){ setActive(idx); });

        resultsBox.appendChild(row);
      });

      showResults();
    }

    /* ── Keyboard highlight ── */
    function setActive(idx) {
      var rows = resultsBox.querySelectorAll('.search-result-row');
      rows.forEach(function(r){ r.classList.remove('sr-active'); });
      activeIdx = idx;
      if (idx >= 0 && rows[idx]) {
        rows[idx].classList.add('sr-active');
        rows[idx].scrollIntoView({ block: 'nearest' });
      }
    }

    /* ── Client-side fallback: scan all project links ── */
    function clientSearch(q) {
      var lq      = q.toLowerCase();
      var matched = [];
      var seen    = {};

      /* Sidebar nav links */
      document.querySelectorAll('#offcanvasScrolling a[href]').forEach(function(a){
        var text = (a.textContent || '').trim().replace(/\s+/g,' ');
        var href = a.getAttribute('href') || '';
        if (href && href !== '#' && text.toLowerCase().indexOf(lq) > -1 && !seen[href]) {
          seen[href] = 1;
          matched.push({ name: text, url: href });
        }
      });

      /* Ribbon dropdown links */
      document.querySelectorAll('.enhanced-ribbon .dropdown-item[href]').forEach(function(a){
        var text = (a.textContent || '').trim().replace(/\s+/g,' ');
        var href = a.getAttribute('href') || '';
        if (href && href !== '#' && text.toLowerCase().indexOf(lq) > -1 && !seen[href]) {
          seen[href] = 1;
          matched.push({ name: text, url: href });
        }
      });

      return matched.slice(0, 10);
    }

    /* ── Fetch API then fall back ── */
    function doSearch(q) {
      if (!q || !q.trim()) { hideResults(); return; }
      fetch('/api/search?q=' + encodeURIComponent(q.trim()))
        .then(function(r){ if (!r.ok) throw 0; return r.json(); })
        .then(function(data){
          var items = Array.isArray(data) ? data : (data.results || data.data || []);
          renderResults(items.length ? items : clientSearch(q));
        })
        .catch(function(){ renderResults(clientSearch(q)); });
    }

    /* ── Input → debounced search ── */
    input.addEventListener('input', function(){
      clearTimeout(debounceTimer);
      var q = input.value;
      if (!q || !q.trim()) { hideResults(); return; }
      debounceTimer = setTimeout(function(){ doSearch(q); }, 200);
    });

    /* ── Keyboard navigation ── */
    input.addEventListener('keydown', function(e){
      var rows = resultsBox.querySelectorAll('.search-result-row');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(activeIdx + 1, rows.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIdx - 1, 0));
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (activeIdx >= 0 && rows[activeIdx]) window.location.href = rows[activeIdx].href;
      } else if (e.key === 'Escape') {
        closeSearch();
      }
    });

    /* ── Toggle button ── */
    toggleBtn.addEventListener('click', function(e){
      e.stopPropagation();
      wrap.classList.contains('open') ? closeSearch() : openSearch();
    });

    /* ── Clear button ── */
    if (clearBtn) {
      clearBtn.addEventListener('click', function(e){
        e.stopPropagation();
        input.value = '';
        hideResults();
        input.focus();
      });
    }

    /* ── Click outside → close ── */
    document.addEventListener('click', function(e){
      if (!wrap.contains(e.target)) closeSearch();
    });
  })();

  /* ── Sidebar: close on nav-link click ── */
  (function(){
    var offcanvasEl = document.getElementById('offcanvasScrolling');
    if (!offcanvasEl) return;
    var links = offcanvasEl.querySelectorAll('.sidebar-close');
    for (var i = 0; i < links.length; i++){
      links[i].addEventListener('click', function(){
        var bsOffcanvas = bootstrap.Offcanvas.getInstance(offcanvasEl);
        if (bsOffcanvas) bsOffcanvas.hide();
      });
    }
  })();

  /* ── Timezone tooltip ── */
  (function updateTZ(){
    try {
      var n   = new Date();
      var tz  = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
      var off = n.getTimezoneOffset();
      var s   = off <= 0 ? '+' : '-', a = Math.abs(off);
      var offsetStr = 'UTC ' + s + String(Math.floor(a/60)).padStart(2,'0') + ':' + String(a%60).padStart(2,'0');
      var tzAbbr = 'IST';
      try {
        var parts = n.toLocaleTimeString('en-US',{timeZoneName:'short'}).split(' ');
        var last  = parts[parts.length - 1];
        if (last && last.length <= 5 && !/\d/.test(last)) { tzAbbr = last; }
        else if (off === -330) { tzAbbr = 'IST'; }
        else if (off === -300) { tzAbbr = 'EST'; }
        else if (off === -360) { tzAbbr = 'CST'; }
        else if (off === -480) { tzAbbr = 'PST'; }
        else                   { tzAbbr = offsetStr; }
      } catch(e){}
      var tzFullName = tz;
      if (tz === 'Asia/Kolkata' || tz === 'Asia/Calcutta') tzFullName = 'India Standard Time';
      else if (tz.indexOf('America/New_York') > -1)        tzFullName = 'Eastern Standard Time';
      else if (tz.indexOf('America/Chicago') > -1)         tzFullName = 'Central Standard Time';
      else if (tz.indexOf('America/Los_Angeles') > -1)     tzFullName = 'Pacific Standard Time';
      var el1 = document.getElementById('tzOffset');
      var el2 = document.getElementById('tzAbbr');
      var el3 = document.getElementById('tzFull');
      if (el1) el1.textContent = offsetStr;
      if (el2) el2.textContent = tzAbbr;
      if (el3) el3.textContent = tzFullName + ' (' + tzAbbr + ')';
    } catch(e){}
    setTimeout(updateTZ, 60000);
  })();
</script>

