<%# ═══════════════════════════════════════════════════════════════
     PMO-header.ejs — ENHANCED UI v3.0
     Drop-in replacement for: partials/PMO-header.ejs
═══════════════════════════════════════════════════════════════ %>

<%# ── Socket listeners (UNCHANGED) ── %>
<script type="text/javascript">
  socket.on('notification-<%-userData.Employee_ID%>', (info) => {
    Notification.requestPermission().then((permission) => {
      new Notification('QGMPS', { body: info, icon: '../static/icons/QG-Logo.png' });
      if (permission != 'granted') { Notification.requestPermission(); }
    })
  })
  socket.on('tostNotification-<%- userData.Employee_ID %>',(Notifications)=>{
    let notification = '<%- JSON.stringify(Notifications) %>';
    toasts.push(Notifications)
  });
  socket.on('AutoRefresh-<%- userData.Employee_ID %>',(Notifications)=>{
    setTimeout(function(){
      if($('.modal.show').length){ console.log("modal active"); }
      else { window.location.reload(); }
    },500)
  });
</script>

<style>
  /* ══════════════════════════════════════
     CSS VARIABLES — VIBRANT DESIGN SYSTEM
  ══════════════════════════════════════ */
  :root {
    --ribbon-h: 52px;
    --navy-900: #0f1e36;
    --navy-800: #152844;
    --navy-700: #1b3258;
    --navy-600: #1e3a5f;
    --blue-500: #2d7dd2;
    --blue-400: #4a96e8;
    --blue-300: #6eb0f5;
    --blue-glow: rgba(45,125,210,0.35);
    --accent-cyan: #00c6ff;
    --white-90: rgba(255,255,255,0.9);
    --white-70: rgba(255,255,255,0.7);
    --white-40: rgba(255,255,255,0.4);
    --white-12: rgba(255,255,255,0.12);
    --white-06: rgba(255,255,255,0.06);
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --shadow-md: 0 6px 20px rgba(0,0,0,0.14);
    --shadow-blue: 0 4px 20px rgba(45,125,210,0.3);
    --transition: all 0.22s cubic-bezier(0.4,0,0.2,1);
  }

  /* ══════════════════════════════════════
     RIBBON HEADER
  ══════════════════════════════════════ */
  header nav.enhanced-ribbon {
    background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-800) 50%, var(--navy-700) 100%) !important;
    height: var(--ribbon-h);
    padding: 0 16px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.28), 0 1px 0 rgba(255,255,255,0.04) inset;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(45,125,210,0.2);
    position: relative;
    z-index: 100;
  }
  header nav.enhanced-ribbon::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--blue-500) 30%, var(--accent-cyan) 60%, transparent 100%);
    opacity: 0.55;
  }

  /* ── Brand ── */
  .ribbon-brand {
    font-size: 17px;
    font-weight: 900;
    letter-spacing: 1.4px;
    background: linear-gradient(135deg, #ffffff 0%, #a8d4ff 50%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .ribbon-version {
    font-size: 9px;
    font-weight: 700;
    color: var(--accent-cyan);
    background: rgba(0,198,255,0.12);
    border: 1px solid rgba(0,198,255,0.3);
    padding: 2px 9px;
    border-radius: 20px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }
  .ribbon-divider {
    width: 1px;
    height: 24px;
    background: linear-gradient(to bottom, transparent, var(--white-12), transparent);
    margin: 0 6px;
    flex-shrink: 0;
  }

  /* ── Icon Buttons ── */
  .rb-icon {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--white-06);
    border: 1px solid var(--white-12);
    border-radius: var(--radius-sm);
    color: var(--white-70);
    font-size: 15px;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    outline: none;
    flex-shrink: 0;
  }
  .rb-icon:hover {
    background: rgba(45,125,210,0.22);
    border-color: rgba(45,125,210,0.45);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(45,125,210,0.28);
  }
  .rb-icon:active { transform: translateY(0) scale(0.95); box-shadow: none; }
  .rb-icon.accent {
    background: linear-gradient(135deg, rgba(45,125,210,0.35), rgba(45,125,210,0.15));
    border-color: rgba(45,125,210,0.5);
    color: var(--white-90);
    box-shadow: 0 2px 10px rgba(45,125,210,0.2);
  }
  .rb-icon.accent:hover {
    background: linear-gradient(135deg, rgba(45,125,210,0.55), rgba(45,125,210,0.25));
    box-shadow: 0 4px 18px rgba(45,125,210,0.4);
  }

  /* Tooltips */
  .rb-icon[data-tip]::after {
    content: attr(data-tip);
    position: absolute;
    bottom: -30px; left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background: #0a0f1a;
    color: #e0eeff;
    font-size: 10px; font-weight: 600;
    padding: 4px 9px;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0; pointer-events: none;
    transition: var(--transition);
    z-index: 9999;
    border: 1px solid rgba(45,125,210,0.25);
  }
  .rb-icon:hover[data-tip]::after { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ══════════════════════════════════════
     CREATE / PROJECTS DROPDOWNS — REDESIGNED
  ══════════════════════════════════════ */
  .enhanced-ribbon .dropdown-menu {
    border: 1px solid rgba(45,125,210,0.18) !important;
    border-radius: var(--radius-md) !important;
    box-shadow: 0 10px 36px rgba(0,0,0,0.16), 0 2px 8px rgba(0,0,0,0.1) !important;
    padding: 8px !important;
    margin-top: 8px !important;
    background: #ffffff !important;
    min-width: 215px !important;
    animation: rbDropIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes rbDropIn {
    from { opacity: 0; transform: translateY(-8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .enhanced-ribbon .dropdown-menu .dropdown-header {
    font-size: 9px; font-weight: 800;
    letter-spacing: 1px; text-transform: uppercase;
    color: #8a97b0; padding: 4px 10px 6px;
  }
  .enhanced-ribbon .dropdown-item {
    font-size: 12.5px; font-weight: 500;
    padding: 8px 12px !important;
    border-radius: var(--radius-sm) !important;
    transition: var(--transition);
    color: #1e2d45 !important;
    display: flex !important; align-items: center; gap: 8px;
    margin-bottom: 2px;
  }
  .enhanced-ribbon .dropdown-item:hover {
    background: linear-gradient(135deg, rgba(45,125,210,0.1), rgba(45,125,210,0.05)) !important;
    color: var(--blue-500) !important;
    transform: translateX(2px);
  }
  .enhanced-ribbon .dropdown-item:active {
    background: rgba(45,125,210,0.15) !important;
    transform: translateX(2px) scale(0.99);
  }
  .enhanced-ribbon .dropdown-item i { font-size: 13px; width: 18px; text-align: center; flex-shrink: 0; }
  .enhanced-ribbon .dropdown-divider { margin: 4px 8px !important; border-color: rgba(45,125,210,0.1) !important; }
  .dd-badge {
    margin-left: auto;
    font-size: 9px; font-weight: 700;
    padding: 2px 7px; border-radius: 20px;
    background: rgba(45,125,210,0.1); color: var(--blue-500);
    letter-spacing: 0.3px; flex-shrink: 0;
  }

  /* ══════════════════════════════════════
     SEARCH BAR — RESTORED + STYLED
     Exact same expand/collapse as original.
     Only visual styling is changed.
  ══════════════════════════════════════ */
  .ribbon-search {
    position: relative;
    display: flex;
    align-items: center;
  }

  /* Input: hidden by default, expands when .open is on the wrapper */
  .ribbon-search .search-field {
    background: rgba(255,255,255,0.1) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: var(--radius-sm) !important;
    color: #fff !important;
    font-size: 12.5px !important;
    padding: 5px 10px !important;
    width: 0;
    opacity: 0;
    pointer-events: none;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1), opacity 0.22s ease;
    margin-left: 4px;
  }
  .ribbon-search .search-field::placeholder { color: rgba(255,255,255,0.38) !important; }
  .ribbon-search .search-field:focus {
    outline: none !important;
    box-shadow: 0 0 0 2px rgba(45,125,210,0.4) !important;
    border-color: rgba(45,125,210,0.5) !important;
    background: rgba(255,255,255,0.13) !important;
  }

  /* Open state — field slides in next to the icon */
  .ribbon-search.open .search-field {
    width: 200px;
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Results dropdown — WHITE card, clean & eye-catching ── */
  .ribbon-search .search-results-container {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    min-width: 290px;
    z-index: 9999;
    background: linear-gradient(160deg, #152844 0%, #1b3258 100%);
    border: 1px solid rgba(45,125,210,0.35);
    border-radius: var(--radius-md);
    box-shadow: 0 4px 6px rgba(0,0,0,0.12),
                0 16px 40px rgba(10,20,50,0.45);
    overflow: hidden;
    animation: rbDropIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }

  /* "PROJECTS (n)" label at the top */
  .ribbon-search .search-results-container .sr-header {
    padding: 8px 14px 6px;
    font-size: 9.5px; font-weight: 800;
    letter-spacing: 1.1px; text-transform: uppercase;
    color: var(--accent-cyan);
    background: rgba(0,0,0,0.15);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  /* Each result row — default: navy bg, silver bold text */
  .ribbon-search .search-results-container .search-result-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    color: rgba(210,225,255,0.75);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background 0.15s, color 0.15s, border-left-color 0.15s;
    cursor: pointer;
    text-decoration: none !important;
    border-left: 3px solid transparent;
    background: transparent;
  }
  .ribbon-search .search-results-container .search-result-row:last-child {
    border-bottom: none;
  }

  /* Hover — same navy but slightly lighter + cyan left border */
  .ribbon-search .search-results-container .search-result-row:hover,
  .ribbon-search .search-results-container .search-result-row.sr-active {
    background: rgba(45,125,210,0.12) !important;
    color: #c8d8f0 !important;
    border-left-color: var(--accent-cyan) !important;
  }

  /* Folder icon pill */
  .ribbon-search .search-results-container .search-result-row .sr-icon {
    width: 32px; height: 32px;
    border-radius: 8px; flex-shrink: 0;
    background: rgba(45,125,210,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    color: var(--accent-cyan);
    transition: background 0.15s;
  }
  .ribbon-search .search-results-container .search-result-row:hover .sr-icon,
  .ribbon-search .search-results-container .search-result-row.sr-active .sr-icon {
    background: rgba(45,125,210,0.35);
    color: #fff;
  }

  /* Meta text sub-label */
  .ribbon-search .search-results-container .sr-meta { line-height: 1.35; }
  .ribbon-search .search-results-container .sr-meta small {
    font-size: 11px;
    color: rgba(160,185,230,0.55);
    display: block;
    font-weight: 500;
  }
  .ribbon-search .search-results-container .search-result-row:hover .sr-meta small,
  .ribbon-search .search-results-container .search-result-row.sr-active .sr-meta small {
    color: rgba(160,185,230,0.75);
  }

  /* "No results" & "Find Project" placeholder */
  .ribbon-search .search-results-container .sr-placeholder {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px;
    color: rgba(160,185,230,0.5);
    font-size: 12.5px; font-weight: 600;
    background: transparent;
  }
  .ribbon-search .search-results-container .sr-placeholder .sr-icon {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    background: rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: rgba(255,255,255,0.2);
  }

  /* ══════════════════════════════════════
     USER BADGE
  ══════════════════════════════════════ */
  .user-badge-wrap {
    display: flex; align-items: center; gap: 0;
    background: var(--white-06); border: 1px solid var(--white-12);
    border-radius: 10px; padding: 3px 5px 3px 3px;
    cursor: pointer;
    transition: max-width 0.38s cubic-bezier(0.4,0,0.2,1), gap 0.3s, background 0.22s, box-shadow 0.22s;
    overflow: hidden; max-width: 44px;
  }
  .user-badge-wrap:hover, .user-badge-wrap.expanded {
    max-width: 240px; gap: 8px; padding-right: 13px;
    background: rgba(45,125,210,0.18);
    border-color: rgba(45,125,210,0.38);
    box-shadow: 0 2px 14px rgba(45,125,210,0.22);
  }
  .user-badge-wrap .ub-avatar {
    width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: #fff;
    box-shadow: 0 2px 8px rgba(45,125,210,0.4); letter-spacing: 0.5px;
  }
  .user-badge-wrap .ub-name {
    font-size: 12px; font-weight: 600; color: var(--white-90);
    white-space: nowrap; opacity: 0;
    transition: opacity 0.2s ease 0.1s; overflow: hidden;
  }
  .user-badge-wrap:hover .ub-name, .user-badge-wrap.expanded .ub-name { opacity: 1; }

  /* ══════════════════════════════════════
   DATETIME CHIP
══════════════════════════════════════ */
.dt-chip-wrap { position: relative; z-index: 10001; }
.dt-chip {
  display: flex; align-items: center; gap: 8px;
  background: var(--white-06); border: 1px solid var(--white-12);
  border-radius: var(--radius-sm); padding: 5px 11px;
  cursor: default; transition: var(--transition);
  font-size: 12px; color: var(--white-90); font-weight: 600;
}
.dt-chip:hover {
  background: rgba(45,125,210,0.14);
  border-color: rgba(45,125,210,0.3);
  box-shadow: 0 2px 10px rgba(45,125,210,0.15);
}
.dt-chip i { font-size: 11px; color: var(--accent-cyan); }
.dt-chip .dt-sep { width: 1px; height: 13px; background: var(--white-12); }
.dt-chip .dt-time { font-weight: 700; color: #fff; font-variant-numeric: tabular-nums; }
.tz-tooltip {
  position: fixed;
  top: 58px;
  right: 90px;
  background: #0d1a2e; border: 1px solid rgba(45,125,210,0.25);
  border-radius: var(--radius-md); padding: 12px 16px; min-width: 195px;
  opacity: 0; pointer-events: none; transform: translateY(-6px);
  transition: var(--transition); z-index: 99999;
  box-shadow: 0 12px 32px rgba(0,0,0,0.4);
}
.tz-tooltip::before {
  content: ''; position: absolute; top: -5px; right: 18px;
  border-left: 5px solid transparent; border-right: 5px solid transparent;
  border-bottom: 5px solid #0d1a2e;
}
.dt-chip-wrap:hover .tz-tooltip { opacity: 1; pointer-events: auto; transform: translateY(0); }
.tz-row { display: flex; justify-content: space-between; padding: 3px 0; }
.tz-row .tz-label { font-size: 9.5px; font-weight: 700; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.5px; }
.tz-row .tz-val { font-size: 10.5px; font-weight: 600; color: var(--white-90); }
.tz-line { height: 1px; background: var(--white-06); margin: 5px 0; }
.tz-full { font-size: 9px; color: var(--white-40); text-align: center; margin-top: 3px; }

  /* ══════════════════════════════════════
     NOTIFICATION ICON
  ══════════════════════════════════════ */
  .rb-notif { position: relative; }
  .rb-notif .ndot {
    position: absolute; top: 5px; right: 5px;
    width: 8px; height: 8px;
    background: linear-gradient(135deg, #ff4e6e, #e74c5a);
    border-radius: 50%; border: 1.5px solid var(--navy-800);
    animation: pulseDot 2.2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%,100% { box-shadow: 0 0 0 0 rgba(231,76,90,0.5); }
    50%      { box-shadow: 0 0 0 5px rgba(231,76,90,0); }
  }

  /* ══════════════════════════════════════
     NOTIFICATION ALERT BANNER
  ══════════════════════════════════════ */
  #notification-alert {
    position: fixed; top: 48px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 14px;
    max-width: 480px; width: auto; padding: 10px 16px;
    background: linear-gradient(135deg, #f0f7ff, #e4effe);
    border: 1px solid #c8deff; border-radius: var(--radius-md);
    box-shadow: 0 8px 28px rgba(0,0,0,0.14);
    font-size: 13px; color: #1e3a5f; z-index: 9999;
  }
  #notification-alert .notif-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--blue-500), #1a60b8);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 15px; flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(45,125,210,0.4);
  }
  #notification-alert .notif-text { margin: 0; flex: 1; line-height: 1.45; }
  #notification-alert .notif-close { margin-left: 10px; transform: scale(0.85); opacity: 0.6; }
  #notification-alert .notif-close:hover { opacity: 1; }

  /* ══════════════════════════════════════
     SIDEBAR
  ══════════════════════════════════════ */
  #offcanvasScrolling {
    border: none !important;
    box-shadow: 6px 0 30px rgba(0,0,0,0.15) !important;
    background: #fafcff !important;
  }
  #offcanvasScrolling .offcanvas-header {
    border-bottom: 1px solid #e6ecf8;
    padding: 14px 18px;
    background: linear-gradient(135deg, var(--navy-900), var(--navy-800));
  }
  #offcanvasScrolling .offcanvas-header .btn-close { filter: invert(1); opacity: 0.6; }
  #offcanvasScrolling .offcanvas-header .btn-close:hover { opacity: 1; }
  #offcanvasScrolling .offcanvas-body.sidenav { padding: 10px 0; background: #fafcff; }

  /* Sidebar links */
  #offcanvasScrolling .offcanvas-body a,
  #offcanvasScrolling .offcanvas-body .dropdown-btn {
    display: flex !important; align-items: center; gap: 10px;
    padding: 10px 20px !important; font-size: 13px !important; font-weight: 500;
    color: #2c3a56 !important; transition: var(--transition);
    border: none; background: none !important; width: 100%; text-align: left;
    border-left: 3px solid transparent;
    margin: 1px 0 !important; border-radius: 0 !important; box-shadow: none !important;
  }
  #offcanvasScrolling .offcanvas-body a:hover,
  #offcanvasScrolling .offcanvas-body .dropdown-btn:hover {
    background: linear-gradient(90deg, rgba(45,125,210,0.08), transparent) !important;
    color: var(--blue-500) !important;
    border-left-color: var(--blue-500);
  }
  #offcanvasScrolling .offcanvas-body a i,
  #offcanvasScrolling .offcanvas-body .dropdown-btn i {
    font-size: 14px; color: #8a97b0;
    width: 20px; text-align: center;
    transition: color 0.15s; flex-shrink: 0;
  }
  #offcanvasScrolling .offcanvas-body a:hover i,
  #offcanvasScrolling .offcanvas-body .dropdown-btn:hover i { color: var(--blue-500); }
  #offcanvasScrolling .dropdown-btn { font-weight: 600 !important; color: #2c3a56 !important; }
  #offcanvasScrolling .dropdown-btn .bi-caret-down-fill {
    margin-left: auto; font-size: 10px !important; width: auto !important;
    transition: transform 0.22s;
  }
  #offcanvasScrolling .dropdown-btn.active .bi-caret-down-fill { transform: rotate(180deg); }

  /* Sub-items */
  #offcanvasScrolling .dropdown-container a {
    padding: 8px 20px 8px 50px !important;
    font-size: 12.5px !important; color: #6b7894 !important;
    border-left: none !important;
  }
  #offcanvasScrolling .dropdown-container a:hover {
    color: var(--blue-500) !important;
    background: rgba(45,125,210,0.05) !important;
    border-left: none !important;
  }

  /* Sidebar section divider */
  .sidenav-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, #e2e8f4, transparent);
    margin: 6px 16px;
  }

  /* ══════════════════════════════════════
     NOTIFICATION PANEL
  ══════════════════════════════════════ */
  .notification_card {
    width: 350px !important; max-height: 88vh;
    border-radius: var(--radius-lg) !important;
    border: 1px solid #e0e8f4 !important;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06), 0 20px 56px rgba(0,0,0,0.12) !important;
    overflow: hidden; background: #ffffff !important;
  }
  .notification_card .notif-panel-header {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-700)) !important;
    padding: 15px 20px !important; margin: 0;
    font-size: 14px; font-weight: 700; color: #ffffff;
    display: flex; align-items: center; gap: 9px; letter-spacing: 0.2px;
  }
  .notification_card .notif-panel-header i { font-size: 15px; color: var(--accent-cyan); }
  .notification_card #NotificationCardCloseBtn {
    top: 13px !important; right: 15px !important;
    filter: invert(1); opacity: 0.55; transition: opacity 0.15s;
  }
  .notification_card #NotificationCardCloseBtn:hover { opacity: 1; }
  .notification_card .notification-container { background: #ffffff; padding: 0 !important; }

  /* ══════════════════════════════════════
     PROFILE CARD
  ══════════════════════════════════════ */
  .profile_card {
    width: 370px; background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08),
                0 16px 48px rgba(15,30,80,0.22),
                0 0 0 1px rgba(45,125,210,0.12),
                0 0 0 6px rgba(45,125,210,0.06);
    overflow: visible;
    animation: fadeProfile 0.25s cubic-bezier(0.34,1.56,0.64,1);
    border: 1px solid #ccdcf8;
    margin-top: 1px;
  }
  @keyframes fadeProfile {
    from { opacity: 0; transform: translateY(-8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .profile-card-header {
    padding: 28px 20px 36px; position: relative;
    background: transparent;
  }
  .profile-card-header::after { display: none; }

  /* Gap between ribbon and profile card */
  .profile_card {
    top: calc(var(--ribbon-h) + 14px) !important;
  }

  /* Close button — styled circle, always visible */
  #ProfileCardCloseBtn {
    filter: none !important;
    opacity: 1 !important;
    top: 12px !important;
    right: 12px !important;
    width: 28px !important;
    height: 28px !important;
    background: #f0f4fc !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border: 1px solid #dce8ff !important;
    cursor: pointer !important;
    transition: background 0.15s, border-color 0.15s !important;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08) !important;
  }
  #ProfileCardCloseBtn:hover {
    background: #ffe4e4 !important;
    border-color: #ffb3b3 !important;
  }
  .profile-card-body { padding: 0 20px 18px; text-align: center; margin-top: -36px; }
  .profile-avatar { display: inline-block; margin-bottom: 10px; }
  .profile-avatar img {
    width: 68px; height: 68px; border-radius: 50%; object-fit: cover;
    border: 3px solid #fff; box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  }
  .avatar-fallback {
    width: 68px; height: 68px; border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    color: white; display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 20px;
    border: 3px solid #fff; box-shadow: 0 4px 14px rgba(45,125,210,0.35); margin: 0 auto;
  }
  .profile-name { font-weight: 700; font-size: 15px; margin: 6px 0 3px; color: #1a2d4a; }
  .profile-email { font-size: 12px; color: #6b7894; margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .profile-meta { font-size: 11.5px; color: #6b7894; display: flex; justify-content: center; align-items: center; gap: 6px; flex-wrap: wrap; }
  .meta-chip {
    background: rgba(45,125,210,0.08); border: 1px solid rgba(45,125,210,0.15);
    border-radius: 20px; padding: 3px 10px;
    font-size: 11px; color: var(--blue-500); font-weight: 600;
    display: flex; align-items: center; gap: 4px;
  }
  .profile-divider { margin: 12px 0; border-color: #eef2f8; }
  .profile-actions { display: flex; gap: 10px; }
  .profile-btn {
    flex: 1; padding: 8px; border-radius: var(--radius-sm);
    font-size: 12px; font-weight: 600;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    text-decoration: none; transition: var(--transition); border: none;
  }
  .profile-btn.manage {
    background: linear-gradient(135deg, #eef4ff, #e0ecff);
    color: #2d6ec0; border: 1px solid #c8deff;
  }
  .profile-btn.manage:hover {
    background: linear-gradient(135deg, #dde9ff, #cde0ff);
    transform: translateY(-1px); box-shadow: 0 3px 10px rgba(45,125,210,0.2);
  }
  .profile-btn.logout {
    background: linear-gradient(135deg, #fff0f0, #ffe4e4);
    color: #cc2222; border: 1px solid #ffc8c8;
  }
  .profile-btn.logout:hover {
    background: linear-gradient(135deg, #ffe4e4, #ffd0d0);
    transform: translateY(-1px); box-shadow: 0 3px 10px rgba(220,50,50,0.18);
  }

  /* ══════════════════════════════════════
     ENHANCED TABLE STYLES
  ══════════════════════════════════════ */
  .enhanced-table-wrap {
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 8px 28px rgba(0,0,0,0.06);
    overflow: hidden;
    border: 1px solid #e4ecf8;
  }
  .enhanced-table-wrap .table {
    margin: 0 !important;
    font-size: 13px;
    border-collapse: separate;
    border-spacing: 0;
  }
  .enhanced-table-wrap .table thead tr {
    background: linear-gradient(135deg, var(--navy-800), var(--navy-700)) !important;
  }
  .enhanced-table-wrap .table thead th,
  .enhanced-table-wrap .table thead td {
    color: rgba(255,255,255,0.85) !important;
    font-size: 11px !important; font-weight: 700 !important;
    letter-spacing: 0.6px !important; text-transform: uppercase !important;
    padding: 13px 16px !important; border: none !important;
    white-space: nowrap; background: transparent !important;
  }
  .enhanced-table-wrap .table thead th:first-child,
  .enhanced-table-wrap .table thead td:first-child { padding-left: 20px !important; }
  .enhanced-table-wrap .table tbody tr {
    border-bottom: 1px solid #f0f4fc !important;
    transition: background 0.15s, box-shadow 0.15s;
  }
  .enhanced-table-wrap .table tbody tr:hover {
    background: linear-gradient(90deg, rgba(45,125,210,0.04), rgba(45,125,210,0.02)) !important;
    box-shadow: inset 3px 0 0 var(--blue-500);
  }
  .enhanced-table-wrap .table tbody tr:last-child { border-bottom: none !important; }
  .enhanced-table-wrap .table tbody td {
    padding: 12px 16px !important; vertical-align: middle;
    color: #2c3a56; border: none !important;
  }
  .enhanced-table-wrap .table tbody td:first-child { padding-left: 20px !important; }

  /* Status badges for tables */
  .status-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.2px;
  }
  .status-badge::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; display: inline-block;
  }
  .status-badge.active    { background: #e6faf2; color: #0d9f6a; }
  .status-badge.pending   { background: #fff8ec; color: #d68a00; }
  .status-badge.completed { background: #eef3ff; color: #3a6ec0; }
  .status-badge.overdue   { background: #fff0f2; color: #d63050; }

  /* Contact Card */
  .contactCard {
    background: #fff !important; border: 1px solid #e0e8f4 !important;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12) !important;
    border-radius: var(--radius-md) !important;
  }

/* Notification + Profile card always on top of sticky table headers */
.notification_card,
.profile_card {
  z-index: 1070 !important;
}

/* Prevent sticky thead from bleeding through cards */
.ms-table thead tr th {
  z-index: 5 !important;  /* lower than card z-index */
}

</style>

