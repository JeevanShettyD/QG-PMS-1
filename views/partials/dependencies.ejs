<script type="text/javascript" crossorigin="anonymous">
    const socket = io();
    socket.on('Notification', (data) => {
        toasts.push(data)
    });
    socket.on("UpdateTaskStatus", async (data) => {
        updateLabel(data);
    });
    socket.on("AllActiveStatus", (data) => {
        updateActiveTask(data);
    });
    socket.on("MasterTaskList", (data) => {
        updateMasterActiveTask(data);
    });
    socket.on("UpdateProjectStatus", (data) => {
        UpdateProjectStatus(data);
    });
    socket.on("UpdateMilestoneStatus", (data) => {
        UpdateMilestoneStatus(data);
    });
    setInterval(() => {
        socket.emit("getActiveMilestoneStatus")
    }, 2000);
    setInterval(() => {
        socket.emit("getAllActiveStatus", { ResponseFor: "All", Customer: null })
    }, 2000);
</script>
