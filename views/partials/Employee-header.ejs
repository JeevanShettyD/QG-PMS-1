<%# ═══════════════════════════════════════════════════════════════
     Employee-header.ejs — ENHANCED UI (matches PMO v3.0)
═══════════════════════════════════════════════════════════════ %>

<%# ── Socket listeners (UNCHANGED) ── %>
<script type="text/javascript">
  socket.on('notification-<%-userData.Employee_ID%>', (info) => {
    Notification.requestPermission().then((permission) => {
      new Notification('QGMPS', { body: info, icon: '../static/icons/QG-Logo.png' });
      if (permission != 'granted') { Notification.requestPermission(); }
    })
  })
  socket.on('AutoRefresh-<%- userData.Employee_ID %>',(Notifications)=>{
    setTimeout(function(){
      if($('.modal.show').length){ console.log("modal active"); }
      else { window.location.reload(); }
    },500)
  });
</script>

<style>
  :root {
    --ribbon-h: 52px;
    --navy-900: #0f1e36;
    --navy-800: #152844;
    --navy-700: #1b3258;
    --navy-600: #1e3a5f;
    --blue-500: #2d7dd2;
    --blue-400: #4a96e8;
    --accent-cyan: #00c6ff;
    --white-90: rgba(255,255,255,0.9);
    --white-70: rgba(255,255,255,0.7);
    --white-40: rgba(255,255,255,0.4);
    --white-12: rgba(255,255,255,0.12);
    --white-06: rgba(255,255,255,0.06);
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --transition: all 0.22s cubic-bezier(0.4,0,0.2,1);
  }

  header nav.enhanced-ribbon {
    background: linear-gradient(135deg, var(--navy-900) 0%, var(--navy-800) 50%, var(--navy-700) 100%) !important;
    height: var(--ribbon-h);
    padding: 0 16px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.28), 0 1px 0 rgba(255,255,255,0.04) inset;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(45,125,210,0.2);
    position: relative;
    z-index: 100;
  }
  header nav.enhanced-ribbon::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--blue-500) 30%, var(--accent-cyan) 60%, transparent 100%);
    opacity: 0.55;
  }

  .ribbon-brand {
    font-size: 17px; font-weight: 900; letter-spacing: 1.4px;
    background: linear-gradient(135deg, #ffffff 0%, #a8d4ff 50%, var(--accent-cyan) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .ribbon-version {
    font-size: 9px; font-weight: 700; color: var(--accent-cyan);
    background: rgba(0,198,255,0.12); border: 1px solid rgba(0,198,255,0.3);
    padding: 2px 9px; border-radius: 20px; letter-spacing: 0.3px; text-transform: uppercase;
  }
  .ribbon-divider {
    width: 1px; height: 24px;
    background: linear-gradient(to bottom, transparent, var(--white-12), transparent);
    margin: 0 6px; flex-shrink: 0;
  }

  .rb-icon {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--white-06); border: 1px solid var(--white-12);
    border-radius: var(--radius-sm); color: var(--white-70); font-size: 15px;
    cursor: pointer; transition: var(--transition); position: relative; outline: none; flex-shrink: 0;
  }
  .rb-icon:hover {
    background: rgba(45,125,210,0.22); border-color: rgba(45,125,210,0.45);
    color: #fff; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(45,125,210,0.28);
  }
  .rb-icon:active { transform: translateY(0) scale(0.95); box-shadow: none; }
  .rb-icon[data-tip]::after {
    content: attr(data-tip); position: absolute; bottom: -30px; left: 50%;
    transform: translateX(-50%) translateY(-4px);
    background: #0a0f1a; color: #e0eeff; font-size: 10px; font-weight: 600;
    padding: 4px 9px; border-radius: 6px; white-space: nowrap;
    opacity: 0; pointer-events: none; transition: var(--transition);
    z-index: 9999; border: 1px solid rgba(45,125,210,0.25);
  }
  .rb-icon:hover[data-tip]::after { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* Search */
  .ribbon-search { position: relative; display: flex; align-items: center; }
  .ribbon-search .search-field {
    background: rgba(255,255,255,0.1) !important; border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: var(--radius-sm) !important; color: #fff !important;
    font-size: 12.5px !important; padding: 5px 10px !important;
    width: 0; opacity: 0; pointer-events: none;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1), opacity 0.22s ease; margin-left: 4px;
  }
  .ribbon-search .search-field::placeholder { color: rgba(255,255,255,0.38) !important; }
  .ribbon-search .search-field:focus {
    outline: none !important; box-shadow: 0 0 0 2px rgba(45,125,210,0.4) !important;
    border-color: rgba(45,125,210,0.5) !important; background: rgba(255,255,255,0.13) !important;
  }
  .ribbon-search.open .search-field { width: 200px; opacity: 1; pointer-events: auto; }
  .ribbon-search .search-results-container {
    position: absolute; top: calc(100% + 10px); left: 0; min-width: 290px; z-index: 9999;
    background: linear-gradient(160deg, #152844 0%, #1b3258 100%);
    border: 1px solid rgba(45,125,210,0.35); border-radius: var(--radius-md);
    box-shadow: 0 4px 6px rgba(0,0,0,0.12), 0 16px 40px rgba(10,20,50,0.45);
    overflow: hidden; animation: rbDropIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes rbDropIn {
    from { opacity: 0; transform: translateY(-8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .ribbon-search .search-results-container .sr-header {
    padding: 8px 14px 6px; font-size: 9.5px; font-weight: 800; letter-spacing: 1.1px;
    text-transform: uppercase; color: var(--accent-cyan);
    background: rgba(0,0,0,0.15); border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ribbon-search .search-results-container .search-result-row {
    display: flex; align-items: center; gap: 10px; padding: 10px 14px;
    color: rgba(210,225,255,0.75); font-size: 13px; font-weight: 700;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background 0.15s, color 0.15s, border-left-color 0.15s;
    cursor: pointer; text-decoration: none !important; border-left: 3px solid transparent; background: transparent;
  }
  .ribbon-search .search-results-container .search-result-row:hover,
  .ribbon-search .search-results-container .search-result-row.sr-active {
    background: rgba(45,125,210,0.12) !important; color: #c8d8f0 !important; border-left-color: var(--accent-cyan) !important;
  }
  .ribbon-search .search-results-container .search-result-row .sr-icon {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    background: rgba(45,125,210,0.2); display: flex; align-items: center; justify-content: center;
    font-size: 15px; color: var(--accent-cyan); transition: background 0.15s;
  }
  .ribbon-search .search-results-container .sr-meta { line-height: 1.35; }
  .ribbon-search .search-results-container .sr-meta small {
    font-size: 11px; color: rgba(160,185,230,0.55); display: block; font-weight: 500;
  }
  .ribbon-search .search-results-container .sr-placeholder {
    display: flex; align-items: center; gap: 10px; padding: 14px 16px;
    color: rgba(160,185,230,0.5); font-size: 12.5px; font-weight: 600;
  }
  .ribbon-search .search-results-container .sr-placeholder .sr-icon {
    width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
    background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: rgba(255,255,255,0.2);
  }

  /* User badge */
  .user-badge-wrap {
    display: flex; align-items: center; gap: 0;
    background: var(--white-06); border: 1px solid var(--white-12);
    border-radius: 10px; padding: 3px 5px 3px 3px; cursor: pointer;
    transition: max-width 0.38s cubic-bezier(0.4,0,0.2,1), gap 0.3s, background 0.22s, box-shadow 0.22s;
    overflow: hidden; max-width: 44px;
  }
  .user-badge-wrap:hover {
    max-width: 240px; gap: 8px; padding-right: 13px;
    background: rgba(45,125,210,0.18); border-color: rgba(45,125,210,0.38);
    box-shadow: 0 2px 14px rgba(45,125,210,0.22);
  }
  .user-badge-wrap .ub-avatar {
    width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: #fff;
    box-shadow: 0 2px 8px rgba(45,125,210,0.4); letter-spacing: 0.5px;
  }
  .user-badge-wrap .ub-name {
    font-size: 12px; font-weight: 600; color: var(--white-90);
    white-space: nowrap; opacity: 0; transition: opacity 0.2s ease 0.1s; overflow: hidden;
  }
  .user-badge-wrap:hover .ub-name { opacity: 1; }

  /* DateTime chip */
  .dt-chip-wrap { position: relative; z-index: 10001; }
  .dt-chip {
    display: flex; align-items: center; gap: 8px;
    background: var(--white-06); border: 1px solid var(--white-12);
    border-radius: var(--radius-sm); padding: 5px 11px;
    cursor: default; transition: var(--transition); font-size: 12px; color: var(--white-90); font-weight: 600;
  }
  .dt-chip:hover { background: rgba(45,125,210,0.14); border-color: rgba(45,125,210,0.3); box-shadow: 0 2px 10px rgba(45,125,210,0.15); }
  .dt-chip i { font-size: 11px; color: var(--accent-cyan); }
  .dt-chip .dt-time { font-weight: 700; color: #fff; font-variant-numeric: tabular-nums; }
  .tz-tooltip {
    position: fixed; top: 58px; right: 90px;
    background: #0d1a2e; border: 1px solid rgba(45,125,210,0.25);
    border-radius: var(--radius-md); padding: 12px 16px; min-width: 195px;
    opacity: 0; pointer-events: none; transform: translateY(-6px);
    transition: var(--transition); z-index: 99999; box-shadow: 0 12px 32px rgba(0,0,0,0.4);
  }
  .tz-tooltip::before {
    content: ''; position: absolute; top: -5px; right: 18px;
    border-left: 5px solid transparent; border-right: 5px solid transparent; border-bottom: 5px solid #0d1a2e;
  }
  .dt-chip-wrap:hover .tz-tooltip { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .tz-row { display: flex; justify-content: space-between; padding: 3px 0; }
  .tz-row .tz-label { font-size: 9.5px; font-weight: 700; color: var(--accent-cyan); text-transform: uppercase; letter-spacing: 0.5px; }
  .tz-row .tz-val { font-size: 10.5px; font-weight: 600; color: var(--white-90); }
  .tz-line { height: 1px; background: var(--white-06); margin: 5px 0; }
  .tz-full { font-size: 9px; color: var(--white-40); text-align: center; margin-top: 3px; }

  /* Notification dot */
  .rb-notif { position: relative; }
  .rb-notif .ndot {
    position: absolute; top: 5px; right: 5px; width: 8px; height: 8px;
    background: linear-gradient(135deg, #ff4e6e, #e74c5a);
    border-radius: 50%; border: 1.5px solid var(--navy-800);
    animation: pulseDot 2.2s ease-in-out infinite;
  }
  @keyframes pulseDot {
    0%,100% { box-shadow: 0 0 0 0 rgba(231,76,90,0.5); }
    50%      { box-shadow: 0 0 0 5px rgba(231,76,90,0); }
  }

  /* Notification alert */
  #notification-alert {
    position: fixed; top: 48px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 14px;
    max-width: 480px; width: auto; padding: 10px 16px;
    background: linear-gradient(135deg, #f0f7ff, #e4effe);
    border: 1px solid #c8deff; border-radius: var(--radius-md);
    box-shadow: 0 8px 28px rgba(0,0,0,0.14); font-size: 13px; color: #1e3a5f; z-index: 9999;
  }
  #notification-alert .notif-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--blue-500), #1a60b8);
    border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;
    color: white; font-size: 15px; flex-shrink: 0; box-shadow: 0 3px 10px rgba(45,125,210,0.4);
  }
  #notification-alert .notif-text { margin: 0; flex: 1; line-height: 1.45; }
  #notification-alert .notif-close { margin-left: 10px; transform: scale(0.85); opacity: 0.6; }
  #notification-alert .notif-close:hover { opacity: 1; }

  /* Sidebar */
  #offcanvasScrolling { border: none !important; box-shadow: 6px 0 30px rgba(0,0,0,0.15) !important; background: #fafcff !important; }
  #offcanvasScrolling .offcanvas-header { border-bottom: 1px solid #e6ecf8; padding: 14px 18px; background: linear-gradient(135deg, var(--navy-900), var(--navy-800)); }
  #offcanvasScrolling .offcanvas-header .btn-close { filter: invert(1); opacity: 0.6; }
  #offcanvasScrolling .offcanvas-body.sidenav { padding: 10px 0; background: #fafcff; }
  #offcanvasScrolling .offcanvas-body a {
    display: flex !important; align-items: center; gap: 10px;
    padding: 10px 20px !important; font-size: 13px !important; font-weight: 500;
    color: #2c3a56 !important; transition: var(--transition);
    border: none; background: none !important; width: 100%; text-align: left;
    border-left: 3px solid transparent; margin: 1px 0 !important; border-radius: 0 !important; box-shadow: none !important;
  }
  #offcanvasScrolling .offcanvas-body a:hover {
    background: linear-gradient(90deg, rgba(45,125,210,0.08), transparent) !important;
    color: var(--blue-500) !important; border-left-color: var(--blue-500);
  }
  #offcanvasScrolling .offcanvas-body a i { font-size: 14px; color: #8a97b0; width: 20px; text-align: center; transition: color 0.15s; flex-shrink: 0; }
  #offcanvasScrolling .offcanvas-body a:hover i { color: var(--blue-500); }
  .sidenav-divider { height: 1px; background: linear-gradient(90deg, transparent, #e2e8f4, transparent); margin: 6px 16px; }

  /* Notification + Profile cards */
  .notification_card {
    width: 350px !important; max-height: 88vh; border-radius: var(--radius-lg) !important;
    border: 1px solid #e0e8f4 !important;
    box-shadow: 0 4px 14px rgba(0,0,0,0.06), 0 20px 56px rgba(0,0,0,0.12) !important;
    overflow: hidden; background: #ffffff !important;
  }
  .notification_card .notif-panel-header {
    background: linear-gradient(135deg, var(--navy-900), var(--navy-700)) !important;
    padding: 15px 20px !important; margin: 0; font-size: 14px; font-weight: 700; color: #ffffff;
    display: flex; align-items: center; gap: 9px; letter-spacing: 0.2px;
  }
  .notification_card .notif-panel-header i { font-size: 15px; color: var(--accent-cyan); }
  .notification_card #NotificationCardCloseBtn { top: 13px !important; right: 15px !important; filter: invert(1); opacity: 0.55; }
  .notification_card .notification-container { background: #ffffff; padding: 0 !important; }

  .profile_card {
    width: 370px; background: #fff; border-radius: var(--radius-lg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), 0 16px 48px rgba(15,30,80,0.22), 0 0 0 1px rgba(45,125,210,0.12);
    overflow: visible; animation: fadeProfile 0.25s cubic-bezier(0.34,1.56,0.64,1);
    border: 1px solid #ccdcf8; margin-top: 1px; top: calc(var(--ribbon-h) + 14px) !important;
  }
  @keyframes fadeProfile { from { opacity:0; transform:translateY(-8px) scale(0.97); } to { opacity:1; transform:translateY(0) scale(1); } }
  .profile-card-header { padding: 28px 20px 36px; }
  #ProfileCardCloseBtn {
    filter: none !important; opacity: 1 !important; top: 12px !important; right: 12px !important;
    width: 28px !important; height: 28px !important; background: #f0f4fc !important;
    border-radius: 50% !important; display: flex !important; align-items: center !important;
    justify-content: center !important; border: 1px solid #dce8ff !important; cursor: pointer !important;
    transition: background 0.15s !important;
  }
  #ProfileCardCloseBtn:hover { background: #ffe4e4 !important; border-color: #ffb3b3 !important; }
  .profile-card-body { padding: 0 20px 18px; text-align: center; margin-top: -36px; }
  .profile-avatar { display: inline-block; margin-bottom: 10px; }
  .profile-avatar img { width: 68px; height: 68px; border-radius: 50%; object-fit: cover; border: 3px solid #fff; box-shadow: 0 4px 14px rgba(0,0,0,0.15); }
  .avatar-fallback {
    width: 68px; height: 68px; border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-400), var(--blue-500));
    color: white; display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 20px; border: 3px solid #fff; box-shadow: 0 4px 14px rgba(45,125,210,0.35); margin: 0 auto;
  }
  .profile-name { font-weight: 700; font-size: 15px; margin: 6px 0 3px; color: #1a2d4a; }
  .profile-email { font-size: 12px; color: #6b7894; margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .profile-meta { font-size: 11.5px; color: #6b7894; display: flex; justify-content: center; align-items: center; gap: 6px; flex-wrap: wrap; }
  .meta-chip { background: rgba(45,125,210,0.08); border: 1px solid rgba(45,125,210,0.15); border-radius: 20px; padding: 3px 10px; font-size: 11px; color: var(--blue-500); font-weight: 600; display: flex; align-items: center; gap: 4px; }
  .profile-divider { margin: 12px 0; border-color: #eef2f8; }
  .profile-actions { display: flex; gap: 10px; }
  .profile-btn { flex: 1; padding: 8px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 6px; text-decoration: none; transition: var(--transition); border: none; }
  .profile-btn.manage { background: linear-gradient(135deg, #eef4ff, #e0ecff); color: #2d6ec0; border: 1px solid #c8deff; }
  .profile-btn.manage:hover { background: linear-gradient(135deg, #dde9ff, #cde0ff); transform: translateY(-1px); }
  .profile-btn.logout { background: linear-gradient(135deg, #fff0f0, #ffe4e4); color: #cc2222; border: 1px solid #ffc8c8; }
  .profile-btn.logout:hover { background: linear-gradient(135deg, #ffe4e4, #ffd0d0); transform: translateY(-1px); }

  .notification_card, .profile_card { z-index: 1070 !important; }
  .ms-table thead tr th { z-index: 5 !important; }

  .contactCard { background: #fff !important; border: 1px solid #e0e8f4 !important; box-shadow: 0 8px 28px rgba(0,0,0,0.12) !important; border-radius: var(--radius-md) !important; }
</style>

<header>
  <nav class="d-flex align-items-center justify-content-between enhanced-ribbon">

    <%# ── LEFT ── %>
    <div class="d-flex align-items-center gap-1">
      <div class="rb-icon" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrolling" aria-controls="offcanvasScrolling" data-tip="Menu">
        <i class="bi bi-list"></i>
      </div>
      <a href="/" class="text-decoration-none mx-1"><span class="ribbon-brand">QGPMS</span></a>
      <span class="ribbon-version">V.2.12 Testing</span>
      <div class="ribbon-divider"></div>

      <%# Search %>
      <div class="search-container ribbon-search ms-1" id="ribbonSearch">
        <div class="rb-icon" id="searchToggleBtn" title="Search" style="cursor:pointer;">
          <i class="bi bi-search"></i>
        </div>
        <input type="search" class="search-field" tabindex="-1" placeholder="Search projects…" value="" name="searchbox" id="searchbox" title="Search in QGPMS:" />
        <div id="searchResultsContainer" class="search-results-container p-1 visually-hidden rounded-3 z-3">
          <img width="30" height="30" src="https://img.icons8.com/color-glass/48/search-folder--v1.png" alt="search"/>
          <span class="ms-2" style="font-size:13px;font-weight:500;color:rgba(255,255,255,0.7);">Find Project</span>
        </div>
      </div>
    </div>

    <%# ── CENTER: Ongoing Task ── %>
    <div id="OngoingTaskInfo">
      <a href="/" id="globalRedirectLink">
        <button type="button" class="btn text-light btn-sm" aria-expanded="false">
          <div class="spinner-grow spinner-grow-sm mx-1" role="status"></div>
          <span id="TaskName" class=""></span>
          <i class="bi bi-chevron-right"></i>
        </button>
      </a>
      <div class="dropdown-menu border-0 shadow-sm p-1 hidden" style="width:200px">
        <div class="w-100 d-flex justify-content-between align-items-center text-center">
          <p class="m-0 text-center" id="globalDisplay">00:00:00:00</p>
          <button type="button" id="globalStopBtn" class="btn btn-sm"><i class="bi bi-stop-circle"></i></button>
        </div>
        <div class="position-relative">
          <a href="/" id="globalRedirectLink" class="position-absolute top-0 start-50 translate-middle">
            <button type="button" class="btn border-0"><i class="bi bi-arrow-down-circle-fill fs-5 text-primary"></i></button>
          </a>
        </div>
      </div>
    </div>

    <%# ── RIGHT ── %>
    <div class="d-flex align-items-center gap-2">
      <div class="user-badge-wrap" title="<%= userData.Full_Name %>">
        <div class="ub-avatar">
          <%= userData.Full_Name ? userData.Full_Name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase() : 'U' %>
        </div>
        <span class="ub-name"><%= userData.Full_Name %></span>
      </div>

      <div class="dt-chip-wrap">
        <div class="dt-chip">
          <i class="bi bi-calendar3"></i>
          <span id="date-time-label">
            <%= new Date().toLocaleDateString('en-IN', {day:'2-digit', month:'2-digit', year:'numeric'}) %>,
            <span class="dt-time"><%= new Date().toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true}) %></span>
          </span>
        </div>
        <div class="tz-tooltip">
          <div class="tz-row"><span class="tz-label">Timezone</span><span class="tz-val" id="tzAbbr">—</span></div>
          <div class="tz-line"></div>
          <div class="tz-row"><span class="tz-label">UTC Offset</span><span class="tz-val" id="tzOffset">—</span></div>
          <div class="tz-line"></div>
