<script>
  /* Search */
  (function(){
    var wrap=document.getElementById('ribbonSearch'),toggleBtn=document.getElementById('searchToggleBtn'),input=document.getElementById('searchbox'),resultsBox=document.getElementById('searchResultsContainer');
    if(!wrap||!toggleBtn||!input||!resultsBox)return;
    var debounceTimer=null,activeIdx=-1;
    function openSearch(){wrap.classList.add('open');setTimeout(function(){input.focus();},320);}
    function closeSearch(){wrap.classList.remove('open');input.value='';input.blur();hideResults();}
    function showResults(){resultsBox.classList.remove('visually-hidden');}
    function hideResults(){resultsBox.classList.add('visually-hidden');activeIdx=-1;}
    function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
    function renderResults(items){activeIdx=-1;resultsBox.innerHTML='';if(!items||items.length===0){resultsBox.innerHTML='<div class="sr-placeholder"><div class="sr-icon"><i class="bi bi-search"></i></div><span>No results found</span></div>';showResults();return;}var hdr=document.createElement('div');hdr.className='sr-header';hdr.textContent='Results ('+items.length+')';resultsBox.appendChild(hdr);items.forEach(function(item,idx){var row=document.createElement('a');row.className='search-result-row';row.href=item.url||item.link||'#';row.innerHTML='<div class="sr-icon"><i class="bi bi-folder-fill"></i></div><div class="sr-meta"><span>'+esc(item.name||item.title||'')+'</span></div>';row.addEventListener('mousedown',function(e){e.preventDefault();window.location.href=row.href;});row.addEventListener('mouseover',function(){setActive(idx);});resultsBox.appendChild(row);});showResults();}
    function setActive(idx){var rows=resultsBox.querySelectorAll('.search-result-row');rows.forEach(function(r){r.classList.remove('sr-active');});activeIdx=idx;if(idx>=0&&rows[idx]){rows[idx].classList.add('sr-active');rows[idx].scrollIntoView({block:'nearest'});}}
    function clientSearch(q){var lq=q.toLowerCase(),matched=[],seen={};document.querySelectorAll('#offcanvasScrolling a[href]').forEach(function(a){var text=(a.textContent||'').trim().replace(/\s+/g,' '),href=a.getAttribute('href')||'';if(href&&href!=='#'&&text.toLowerCase().indexOf(lq)>-1&&!seen[href]){seen[href]=1;matched.push({name:text,url:href});}});return matched.slice(0,10);}
    function doSearch(q){if(!q||!q.trim()){hideResults();return;}fetch('/api/search?q='+encodeURIComponent(q.trim())).then(function(r){if(!r.ok)throw 0;return r.json();}).then(function(data){var items=Array.isArray(data)?data:(data.results||data.data||[]);renderResults(items.length?items:clientSearch(q));}).catch(function(){renderResults(clientSearch(q));});}
    input.addEventListener('input',function(){clearTimeout(debounceTimer);var q=input.value;if(!q||!q.trim()){hideResults();return;}debounceTimer=setTimeout(function(){doSearch(q);},200);});
    input.addEventListener('keydown',function(e){var rows=resultsBox.querySelectorAll('.search-result-row');if(e.key==='ArrowDown'){e.preventDefault();setActive(Math.min(activeIdx+1,rows.length-1));}else if(e.key==='ArrowUp'){e.preventDefault();setActive(Math.max(activeIdx-1,0));}else if(e.key==='Enter'){e.preventDefault();if(activeIdx>=0&&rows[activeIdx])window.location.href=rows[activeIdx].href;}else if(e.key==='Escape'){closeSearch();}});
    toggleBtn.addEventListener('click',function(e){e.stopPropagation();wrap.classList.contains('open')?closeSearch():openSearch();});
    document.addEventListener('click',function(e){if(!wrap.contains(e.target))closeSearch();});
  })();

  /* Timezone tooltip */
  (function updateTZ(){
    try{var n=new Date(),tz=Intl.DateTimeFormat().resolvedOptions().timeZone||'',off=n.getTimezoneOffset(),s=off<=0?'+':'-',a=Math.abs(off),offsetStr='UTC '+s+String(Math.floor(a/60)).padStart(2,'0')+':'+String(a%60).padStart(2,'0'),tzAbbr='IST';
    try{var parts=n.toLocaleTimeString('en-US',{timeZoneName:'short'}).split(' '),last=parts[parts.length-1];if(last&&last.length<=5&&!/\d/.test(last)){tzAbbr=last;}else if(off===-330){tzAbbr='IST';}else if(off===-300){tzAbbr='EST';}else if(off===-360){tzAbbr='CST';}else if(off===-480){tzAbbr='PST';}else{tzAbbr=offsetStr;}}catch(e){}
    var tzFullName=tz;if(tz==='Asia/Kolkata'||tz==='Asia/Calcutta')tzFullName='India Standard Time';
    var el1=document.getElementById('tzOffset'),el2=document.getElementById('tzAbbr'),el3=document.getElementById('tzFull');
    if(el1)el1.textContent=offsetStr;if(el2)el2.textContent=tzAbbr;if(el3)el3.textContent=tzFullName+' ('+tzAbbr+')';}catch(e){}
    setTimeout(updateTZ,60000);
  })();

  /* Tooltip alignment */
  (function(){
    var chip=document.querySelector('.dt-chip'),tooltip=document.querySelector('.tz-tooltip');
    if(!chip||!tooltip)return;
    chip.addEventListener('mouseenter',function(){var rect=chip.getBoundingClientRect();tooltip.style.right=(window.innerWidth-rect.right)+'px';tooltip.style.top=(rect.bottom+8)+'px';});
  })();
</script>
