<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task</title>
  <%- include('../partials/dependencies') %>
</head>

<% if (userData.Role=="Employee") { %>
  <%- include('../partials/Employee-header',{userData:userData}) %>
<% } else if(userData.Role=="Admin") { %>
  <%- include('../partials/Admin-header',{userData:userData}) %>
<% } else if(userData.Role=="PMO") { %>
  <%- include('../partials/PMO-header',{userData:userData}) %>
<% } if(userData.Role=="Manager") { %>
  <%- include('../partials/Manager-header',{userData:userData}) %>
<% } %>

<style>
  /* ══════════════════════════════════════
     EXACT SAME CSS AS MILESTONE LIST
  ══════════════════════════════════════ */
  :root {
    --ms-navy:    #0f1e36;
    --ms-blue:    #2d7dd2;
    --ms-cyan:    #00c6ff;
    --ms-light:   #f4f7fc;
    --ms-border:  #e2e8f4;
    --ms-text:    #1e2d45;
    --ms-muted:   #7a8aaa;
    --ms-radius:  10px;
    --ms-shadow:  0 2px 12px rgba(15,30,80,0.08), 0 8px 28px rgba(15,30,80,0.06);
    --ms-tr:      all 0.18s cubic-bezier(0.4,0,0.2,1);
  }

  body { background: #f0f4fa; }
  .ms-page { padding: 14px 18px 60px; }

  /* ── Toolbar ── */
  .ms-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 10px; margin-bottom: 10px;
  }
  .ms-toolbar-left  { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .ms-toolbar-right { display: flex; align-items: center; gap: 8px; }
  .ms-page-title { font-size: 15px; font-weight: 700; color: var(--ms-text); display: flex; align-items: center; gap: 8px; }
  .ms-page-title i { color: var(--ms-blue); font-size: 16px; }

  /* ── Buttons ── */
  .ms-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 8px;
    font-size: 12px; font-weight: 600; cursor: pointer;
    border: none; transition: var(--ms-tr); text-decoration: none;
  }
  .ms-btn-primary {
    background: linear-gradient(135deg, var(--ms-blue), #1a60b8);
    color: #fff; box-shadow: 0 2px 8px rgba(45,125,210,0.3);
  }
  .ms-btn-primary:hover {
    background: linear-gradient(135deg, #3a8ae0, #2266cc);
    box-shadow: 0 4px 14px rgba(45,125,210,0.4);
    transform: translateY(-1px); color: #fff;
  }
  .ms-btn-outline {
    background: #fff; color: var(--ms-blue);
    border: 1px solid var(--ms-border); box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .ms-btn-outline:hover { background: #eef5ff; border-color: var(--ms-blue); }

  /* ── Column selector ── */
  .ms-field-selector { position: relative; }
  .ms-field-trigger {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 13px; border-radius: 8px;
    background: #fff; border: 1px solid var(--ms-border);
    font-size: 12px; font-weight: 600; color: var(--ms-text);
    cursor: pointer; transition: var(--ms-tr);
    box-shadow: 0 1px 4px rgba(0,0,0,0.06); user-select: none;
  }
  .ms-field-trigger:hover { border-color: var(--ms-blue); background: #eef5ff; }
  .ms-field-trigger i { color: var(--ms-blue); }
  .ms-field-panel {
    position: absolute; top: calc(100% + 8px); left: 0;
    background: #fff; border: 1px solid var(--ms-border);
    border-radius: var(--ms-radius);
    box-shadow: 0 8px 32px rgba(15,30,80,0.14);
    z-index: 999; min-width: 220px; padding: 10px; display: none;
    animation: dropIn 0.18s cubic-bezier(0.34,1.56,0.64,1);
  }
  .ms-field-panel.open { display: block; }
  @keyframes dropIn {
    from { opacity:0; transform: translateY(-6px) scale(0.98); }
    to   { opacity:1; transform: translateY(0) scale(1); }
  }
  .ms-field-panel-header {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 8px; border-bottom: 1px solid var(--ms-border); margin-bottom: 8px;
  }
  .ms-field-panel-header span { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: var(--ms-muted); }
  .ms-field-panel-header button { font-size: 10px; color: var(--ms-blue); background: none; border: none; cursor: pointer; font-weight: 600; padding: 0; }
  .ms-field-item {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 4px; border-radius: 6px; font-size: 12px; color: var(--ms-text); cursor: pointer;
    transition: background 0.12s;
  }
  .ms-field-item:hover { background: #f0f6ff; }
  .ms-field-item input[type="checkbox"] { accent-color: var(--ms-blue); width: 14px; height: 14px; }

  /* ── Tabs ── */
  .ms-tabs-wrap { display: flex; justify-content: center; margin-bottom: 10px; }
  .ms-tabs {
    display: inline-flex; align-items: center;
    background: #fff; border: 1px solid var(--ms-border);
    border-radius: 12px; padding: 4px; gap: 3px;
    box-shadow: var(--ms-shadow);
  }
  .ms-tab {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 18px; border-radius: 9px;
    font-size: 12.5px; font-weight: 600; cursor: pointer;
    border: none; background: transparent; color: var(--ms-muted);
    transition: var(--ms-tr); white-space: nowrap;
  }
  .ms-tab i { font-size: 13px; }
  .ms-tab:hover { background: #f0f6ff; color: var(--ms-blue); }
  .ms-tab.active {
    background: linear-gradient(135deg, var(--ms-blue), #1a60b8);
    color: #fff; box-shadow: 0 3px 12px rgba(45,125,210,0.3);
  }
  .ms-tab .ms-tab-count {
    background: rgba(255,255,255,0.25); border-radius: 20px; padding: 1px 7px;
    font-size: 10px; font-weight: 700;
  }
  .ms-tab:not(.active) .ms-tab-count { background: rgba(45,125,210,0.1); color: var(--ms-blue); }

  /* ── Table card ── */
  .ms-table-card {
    background: #fff; border-radius: 12px;
    border: 1px solid var(--ms-border);
    box-shadow: 0 1px 4px rgba(15,30,80,0.06), 0 6px 20px rgba(15,30,80,0.07);
    overflow: hidden;
  }
  .ms-table-scroll { overflow-x: auto; overflow-y: visible; }
  .ms-table-scroll::-webkit-scrollbar { height: 5px; }
  .ms-table-scroll::-webkit-scrollbar-track { background: #f0f4fc; }
  .ms-table-scroll::-webkit-scrollbar-thumb { background: #c0cce0; border-radius: 3px; }
  .ms-table-scroll::-webkit-scrollbar-thumb:hover { background: var(--ms-blue); }

  /* ── Table ── */
  .ms-table { width: 100%; border-collapse: collapse; font-size: 12.5px; table-layout: auto; }

  /* Column header */
  .ms-table thead tr th {
    background: linear-gradient(135deg, #1a3060, #1e3a5f);
    color: rgba(255,255,255,0.9);
    font-size: 11px; font-weight: 700; letter-spacing: 0.2px;
    padding: 9px 12px; white-space: nowrap;
    border-bottom: 2px solid rgba(45,125,210,0.4);
    border-right: 1px solid rgba(255,255,255,0.06);
    position: sticky; top: 0; z-index: 10; cursor: pointer;
  }
  .ms-table thead tr th:last-child { border-right: none; }
  .ms-table thead tr th[data-sort="asc"]::after  { content: ' ↑'; opacity: 0.8; font-size: 10px; }
  .ms-table thead tr th[data-sort="desc"]::after { content: ' ↓'; opacity: 0.8; font-size: 10px; }
  .ms-table thead tr th:hover { background: linear-gradient(135deg, #1e3a6e, #244480); }

  /* Column resize */
  .ms-table thead th { position: relative; }
  .col-resize-handle {
    position: absolute; right: 0; top: 0; bottom: 0;
    width: 4px; cursor: col-resize; background: transparent; transition: background 0.15s;
  }
  .col-resize-handle:hover { background: rgba(0,198,255,0.6); }

  /* Data rows */
  .ms-table tbody tr.ms-data-row {
    border-bottom: 1px solid #edf1fa; transition: background 0.12s, box-shadow 0.12s;
  }
  .ms-table tbody tr.ms-data-row:hover {
    background: #f0f6ff !important; box-shadow: inset 3px 0 0 var(--ms-blue);
  }
  .ms-table tbody tr.ms-data-row:nth-child(4n+1) { background: #fff; }
  .ms-table tbody tr.ms-data-row:nth-child(4n+3) { background: #fafcff; }
  .ms-table tbody td {
    padding: 9px 12px; color: var(--ms-text); vertical-align: middle;
    border-right: 1px solid #f0f4fc;
  }
  .ms-table tbody td:last-child { border-right: none; }

  /* Detail expand row */
  .ms-table tbody tr.ms-detail-row td {
    background: #f4f8ff !important;
    padding: 12px 18px !important;
    border-top: none !important;
    border-bottom: 2px solid #d8e4f8 !important;
  }

  /* Row toggle button */
  .ms-row-toggle {
    width: 22px; height: 22px; border-radius: 6px;
    background: #eef4ff; border: 1px solid #d0e0f8;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: var(--ms-tr); flex-shrink: 0;
    color: var(--ms-blue); font-size: 10px;
  }
  .ms-row-toggle:hover { background: var(--ms-blue); color: #fff; }

  /* Detail grid */
  .ms-detail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .ms-detail-item { display: flex; flex-direction: column; gap: 2px; }
  .ms-detail-item label { font-size: 9.5px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.7px; color: var(--ms-muted); }
  .ms-detail-item span { font-size: 12.5px; font-weight: 500; color: var(--ms-text); }

  /* S.No cell */
  .td-sno { font-weight: 700; color: var(--ms-muted); font-size: 11px; text-align: center; width: 54px; padding-left: 14px !important; }

  /* Links */
  .ms-table a { color: var(--ms-blue); text-decoration: none; font-weight: 600; }
  .ms-table a:hover { text-decoration: underline; }

  /* Status badges */
  .ms-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 20px; font-size: 10.5px; font-weight: 700; white-space: nowrap;
  }
  .ms-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; display: block; flex-shrink: 0; }
  .ms-badge-yts       { background: #eef3ff; color: #3a6ec0; }
  .ms-badge-wip       { background: #fff8e6; color: #c07a00; }
  .ms-badge-completed { background: #e8faf2; color: #0d9f6a; }
  .ms-badge-other     { background: #f4f4f4; color: #666; }

  /* Delivery badges */
  .ms-delivery {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 20px; font-size: 10.5px; font-weight: 700; white-space: nowrap;
  }
  .ms-delivery i { font-size: 9px; }
  .ms-delivery.on-time    { background: #e8faf2; color: #0d9f6a; }
  .ms-delivery.approaching{ background: #fff8e6; color: #c07a00; }
  .ms-delivery.due-today  { background: #eef4ff; color: #2d6ec0; }
  .ms-delivery.delayed    { background: #fff0f2; color: #c02038; }
  .ms-delivery.escalation { background: #fff0f2; color: #c02038; }

  /* Empty state */
  .ms-empty { text-align: center; padding: 52px 20px; }
  .ms-empty .ms-empty-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: linear-gradient(135deg, rgba(45,125,210,0.1), rgba(45,125,210,0.05));
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px; font-size: 22px; color: rgba(45,125,210,0.4);
  }
  .ms-empty p { font-size: 13px; color: var(--ms-muted); font-weight: 500; margin: 0; }

  /* Filter FAB */
  .ms-filter-fab {
    position: fixed; bottom: 28px; right: 24px; z-index: 400;
    display: flex; align-items: center; gap: 7px;
    padding: 10px 18px; border-radius: 30px;
    background: linear-gradient(135deg, var(--ms-blue), #1a60b8);
    color: #fff; font-size: 12.5px; font-weight: 700;
    border: none; cursor: pointer;
    box-shadow: 0 4px 18px rgba(45,125,210,0.45); transition: var(--ms-tr);
  }
  .ms-filter-fab:hover {
    background: linear-gradient(135deg, #3a8ae0, #2266cc);
    box-shadow: 0 6px 24px rgba(45,125,210,0.55); transform: translateY(-2px);
  }

  /* Filter panel */
  .ms-filter-panel {
    position: fixed; bottom: 80px; right: 24px; z-index: 410;
    background: #fff; border: 1px solid var(--ms-border);
    border-radius: 14px; padding: 16px;
    box-shadow: 0 12px 40px rgba(15,30,80,0.18);
    width: 260px; display: none;
    animation: dropIn 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .ms-filter-panel.open { display: block; }
  .ms-filter-panel label { font-size: 11px; font-weight: 700; color: var(--ms-muted); display: block; margin-bottom: 4px; }
  .ms-filter-panel input, .ms-filter-panel select {
    width: 100%; font-size: 12px; border: 1px solid var(--ms-border);
    border-radius: 7px; padding: 6px 10px; color: var(--ms-text);
    transition: var(--ms-tr); margin-bottom: 10px;
  }
  .ms-filter-panel input:focus, .ms-filter-panel select:focus {
    border-color: var(--ms-blue); outline: none; box-shadow: 0 0 0 3px rgba(45,125,210,0.12);
  }
  .ms-filter-panel-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;
  }
  .ms-filter-panel-header span { font-size: 12px; font-weight: 800; color: var(--ms-text); }
  .ms-filter-panel-header button { background: none; border: none; cursor: pointer; color: var(--ms-muted); font-size: 15px; padding: 0; }
  .ms-filter-panel-header button:hover { color: var(--ms-text); }
</style>

<body>
<main class="ms-page">

<%
  let bgColour = "";
  let bgMap = {
    "On Time":              "on-time",
    "Approaching Due Date": "approaching",
    "Due Today":            "due-today",
    "Delayed":              "delayed",
    "Escalation":           "escalation",
  };

  let ytsCount = 0, ongoingCount = 0, completedCount = 0;
  if(Object.values(Task).length > 0){
    for(let i=0; i < Object.values(Task).length; i++){
      if(Task[i].Status === 'YTS') ytsCount++;
      else if(Task[i].Status === 'Completed' || Task[i].Status === 'Ready for QC' || Task[i].Status === 'IQC-WIP') completedCount++;
      else if(Task[i].Status !== 'YTS' && Task[i].Status !== 'Completed' && Task[i].Status !== 'Ready for QC' && Task[i].Status !== 'IQC-YTS' && Task[i].Status !== 'IQC-WIP') ongoingCount++;
    }
  }
%>

<!-- ── TOOLBAR ── -->
<div class="ms-toolbar">
  <div class="ms-toolbar-left">
    <div class="ms-page-title">
      <i class="bi bi-check2-square"></i>
      Task List
    </div>

    <!-- Column Selector -->
    <div class="ms-field-selector" id="fieldSelector">
      <div class="ms-field-trigger" id="fieldTrigger">
        <i class="bi bi-layout-three-columns"></i>
        Columns
        <i class="bi bi-chevron-down" style="font-size:9px;"></i>
      </div>
      <div class="ms-field-panel" id="fieldPanel">
        <div class="ms-field-panel-header">
          <span>Show / Hide Columns</span>
          <div style="display:flex;gap:6px;"><button onclick="selectAllColumns()">Select All</button><button onclick="unselectAllColumns()" style="color:#e53e3e;">Unselect All</button></div>
        </div>
        <div id="columnCheckboxes">
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="0" checked> S.No</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="1" checked> Task ID</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="2" checked> Task Name</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="3" checked> Milestone</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="4" checked> Start Date</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="5" checked> End Date</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="6" checked> Due Date</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="7" checked> Status</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="8" checked> Total Time</label>
          <label class="ms-field-item"><input type="checkbox" class="col-toggle" data-col="9" checked> Delivery Status</label>
        </div>
      </div>
    </div>
  </div>

  <div class="ms-toolbar-right">
    <div class="dropdown">
      <button class="ms-btn ms-btn-primary dropdown-toggle" data-bs-toggle="dropdown">
        <i class="bi bi-cloud-download"></i> Export
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 p-1">
        <li>
          <a href="/api/downloadTask" id="ExportLink" class="dropdown-item rounded-2" style="font-size:12.5px;">
            <i class="bi bi-filetype-xlsx text-success me-2"></i> Excel
          </a>
        </li>
      </ul>
    </div>
  </div>
</div>

<!-- ── TABS ── -->
<div class="ms-tabs-wrap">
  <div class="ms-tabs" id="msTabs">
    <button class="ms-tab active" data-tab="yts" onclick="switchTab('yts', this)">
      <i class="bi bi-hourglass-split"></i> YTS
      <span class="ms-tab-count" id="count-yts"><%= ytsCount %></span>
    </button>
    <button class="ms-tab" data-tab="ongoing" onclick="switchTab('ongoing', this)">
      <i class="bi bi-play-circle"></i> Ongoing
      <span class="ms-tab-count" id="count-ongoing"><%= ongoingCount %></span>
    </button>
    <button class="ms-tab" data-tab="completed" onclick="switchTab('completed', this)">
      <i class="bi bi-check-circle"></i> Completed
      <span class="ms-tab-count" id="count-completed"><%= completedCount %></span>
    </button>
  </div>
</div>

<!-- ══════════ YTS TAB ══════════ -->
<div class="ms-tab-pane" id="pane-yts">
  <div class="ms-table-card">
    <div class="ms-table-scroll">
      <table class="ms-table" id="TL_YTS">
        <thead>
          <tr>
            <th style="width:54px;">S.No <div class="col-resize-handle"></div></th>
            <th>Task ID <div class="col-resize-handle"></div></th>
            <th>Task Name <div class="col-resize-handle"></div></th>
            <th>Milestone <div class="col-resize-handle"></div></th>
            <th>Start Date <div class="col-resize-handle"></div></th>
            <th>End Date <div class="col-resize-handle"></div></th>
            <th>Due Date <div class="col-resize-handle"></div></th>
            <th>Status <div class="col-resize-handle"></div></th>
            <th>Total Time <div class="col-resize-handle"></div></th>
            <th>Delivery Status</th>
          </tr>
        </thead>
        <tbody>
          <% if(Object.values(Task).length > 0){ let slNo=1; %>
            <% for(let i=0; i < Object.values(Task).length; i++){ %>
              <% if(Task[i].Status === 'YTS'){ %>
                <%
                  let dueDate  = Task[i].f_DueDate;
                  let endDate  = Task[i].f_EndDate ? Task[i].f_EndDate : '';
                  let temp     = compareDates(dueDate, endDate, Task[i].Status);
                  let dlvCls   = temp ? bgMap[temp] : '';
                %>
                <tr class="ms-data-row">
                  <td class="td-sno">
                    <div class="d-flex align-items-center gap-1">
                      <div class="ms-row-toggle" onclick="toggleDetail(this)">
                        <i class="bi bi-plus-lg"></i>
                      </div>
                      <%= slNo %>
                    </div>
                  </td>
                  <td class="text-nowrap">
                    <a href="/ViewTask/<%= Task[i].Customer %>/<%= Task[i].Milestone_Name %>/<%= Task[i].TaskName %>">
                      <%= Task[i].TaskName %>
                    </a>
                  </td>
                  <td title="<%= Task[i].TaskLabel || '' %>">
                    <%= Task[i].TaskLabel ? Task[i].TaskLabel.slice(0,20) : '-' %>
                  </td>
                  <td class="text-nowrap">
                    <a href="/ViewMilestone/<%= Task[i].Customer %>/<%= Task[i].idProjects %>/<%= Task[i].Milestone_Name %>">
                      <%= Task[i].Milestone_Name %>
                    </a>
                  </td>
                  <td><%= Task[i].StartDate || '-' %></td>
                  <td><%= Task[i].EndDate || '-' %></td>
                  <td><%= Task[i].DueDate || '-' %></td>
                  <td><span class="ms-badge ms-badge-yts"><%= Task[i].Status %></span></td>
                  <td class="text-nowrap"><%= secondsToMinutes(Task[i].TotalTime) %></td>
                  <td>
                    <% if(temp){ %>
                      <span class="ms-delivery <%= dlvCls %>">
                        <i class="bi bi-circle-fill"></i><%= temp %>
                      </span>
                    <% } else { %> — <% } %>
                  </td>
                </tr>
                <tr class="ms-detail-row" style="display:none;">
                  <td colspan="10">
                    <div class="ms-detail-grid">
                      <div class="ms-detail-item"><label>Task ID</label><span><%= Task[i].TaskName %></span></div>
                      <div class="ms-detail-item"><label>Task Name</label><span><%= Task[i].TaskLabel || '-' %></span></div>
                      <div class="ms-detail-item"><label>Milestone</label><span><%= Task[i].Milestone_Name %></span></div>
                      <div class="ms-detail-item"><label>Customer</label><span><%= Task[i].Customer %></span></div>
                      <div class="ms-detail-item"><label>Type</label><span><%= Task[i].Type || '-' %></span></div>
                      <div class="ms-detail-item"><label>Status</label><span><%= Task[i].Status %></span></div>
                      <div class="ms-detail-item"><label>Due Date</label><span><%= Task[i].DueDate || '-' %></span></div>
                      <div class="ms-detail-item"><label>Total Time</label><span><%= secondsToMinutes(Task[i].TotalTime) %></span></div>
                    </div>
                  </td>
                </tr>
                <% slNo++; } %>
            <% } %>
          <% } %>
          <% if(ytsCount === 0){ %>
            <tr><td colspan="10">
              <div class="ms-empty">
